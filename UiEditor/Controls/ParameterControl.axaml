<UserControl
    x:Name="Root"
    x:Class="UiEditor.Controls.ParameterControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:UiEditor.ViewModels">
  <Grid DataContext="{Binding #Root}" RowDefinitions="Auto,*">
    <TextBlock
        Grid.Row="0"
        Margin="0,0,0,4"
        FontSize="12"
        FontWeight="SemiBold"
        Foreground="{Binding Foreground}"
        IsVisible="{Binding Presentation.HasLabel}"
        Opacity="0.72"
        Text="{Binding Presentation.Label}" />

    <Grid Grid.Row="1">
      <Grid IsVisible="{Binding Presentation.IsText}">
        <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
          <TextBlock VerticalAlignment="Bottom" FontFamily="Calibri" TextTrimming="CharacterEllipsis" FontSize="{Binding ValueFontSize}" FontWeight="Bold" Foreground="{Binding Foreground}" Text="{Binding Presentation.ValueText}" />
          <TextBlock Grid.Column="1" IsVisible="{Binding Presentation.ShowUnit}" MaxWidth="{Binding UnitWidth}" Margin="4,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontFamily="Calibri" TextAlignment="Right" TextTrimming="CharacterEllipsis" FontSize="{Binding UnitFontSize}" FontStyle="Italic" FontWeight="Normal" Foreground="{Binding Foreground}" Text="{Binding Presentation.UnitText}">
            <TextBlock.RenderTransform>
              <TranslateTransform Y="{Binding UnitBaselineOffset}" />
            </TextBlock.RenderTransform>
          </TextBlock>
        </Grid>
      </Grid>

      <StackPanel IsVisible="{Binding Presentation.IsColor}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <Border Width="72" Height="72" CornerRadius="12" Background="{Binding Presentation.ColorText}" BorderBrush="{Binding Foreground}" BorderThickness="1" />
        <TextBlock HorizontalAlignment="Center" FontSize="{Binding UnitFontSize}" Foreground="{Binding Foreground}" Text="{Binding Presentation.ColorText}" />
      </StackPanel>

      <StackPanel IsVisible="{Binding Presentation.IsBool}" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
        <ItemsControl ItemsSource="{Binding Presentation.BoolOptions}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="viewModels:ParameterChoiceState">
              <Border MinWidth="72" Padding="12,8" Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" BorderThickness="1" CornerRadius="8">
                <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{Binding Foreground}" Text="{Binding Label}" />
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <ItemsControl IsVisible="{Binding Presentation.IsBits}" ItemsSource="{Binding Presentation.BitOptions}" HorizontalAlignment="Stretch" VerticalAlignment="Center">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="{Binding BitColumns}" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="viewModels:ParameterChoiceState">
            <Button HorizontalAlignment="Stretch" Margin="0,0,6,6" Padding="10,6" Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" BorderThickness="1" CornerRadius="8" Click="OnBitChoiceClicked" Tag="{Binding Index}">
              <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{Binding Foreground}" Text="{Binding Label}" />
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>
  </Grid>
</UserControl>
