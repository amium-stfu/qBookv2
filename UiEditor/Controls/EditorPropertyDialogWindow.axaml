<Window
    x:Class="Amium.UiEditor.Controls.EditorPropertyDialogWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Controls"
    Width="540"
    MinWidth="540"
    MaxWidth="540"
    Height="820"
    MinHeight="560"
    CanResize="True"
    ShowInTaskbar="False"
    SystemDecorations="Full"
    WindowStartupLocation="CenterOwner"
    Title="{Binding EditorDialogTitle}"
    Background="{Binding DialogBackground}">
  <controls:EditorPropertyDialog Margin="16" />
</Window>