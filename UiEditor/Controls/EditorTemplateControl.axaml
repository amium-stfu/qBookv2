<controls:EditorTemplateControl
    x:Class="Amium.UiEditor.Controls.EditorTemplateControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Controls"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia">
  <Border
      Background="{Binding EffectiveBackgroundBrush}"
      BorderBrush="{Binding EffectiveBorderBrushValue}"
      BorderThickness="{Binding EffectiveBorderThickness}"
      CornerRadius="{Binding EffectiveCornerRadius}"
      Padding="8,4,8,4">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
      <Border Grid.Row="0" Background="{Binding EffectiveHeaderBackgroundBrush}" BorderBrush="{Binding EffectiveHeaderBorderBrush}" BorderThickness="{Binding EffectiveHeaderBorderThickness}" CornerRadius="{Binding EffectiveHeaderCornerRadius}" Padding="8,0" MinHeight="{Binding ItemHeaderHeight}" IsVisible="{Binding ShowControlCaption}">
        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
          <TextBlock
              VerticalAlignment="Center"
              FontSize="{Binding ItemControlCaptionFontSize}"
              FontWeight="Medium"
              Foreground="{Binding EffectiveHeaderForegroundBrush}"
              IsVisible="{Binding ShowControlCaption}"
              Text="{Binding ControlCaption}" />

          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <ContentPresenter Content="{Binding HeaderActionsContent, RelativeSource={RelativeSource AncestorType=controls:EditorTemplateControl}}" />
            <Button Classes="toolicon" Width="18" Height="18" MinWidth="18" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderBrush="Transparent" CornerRadius="0" Click="OnSettingsClicked" IsVisible="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=False, TargetNullValue=False}" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Settings">
              <Grid>
                <svg:Svg Width="12" Height="12" Path="avares://Amium.UiEditor/EditorIcons/cog.svg" Css="path { fill: #111827; }" IsVisible="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, Converter={StaticResource BoolNegationConverter}, FallbackValue=True, TargetNullValue=True}" />
                <svg:Svg Width="12" Height="12" Path="avares://Amium.UiEditor/EditorIcons/cog.svg" Css="path { fill: #FFFFFF; }" IsVisible="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=False, TargetNullValue=False}" />
              </Grid>
            </Button>
            <Button Classes="toolicon" Width="18" Height="18" MinWidth="18" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderBrush="Transparent" CornerRadius="0" Click="OnDeleteClicked" IsVisible="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=False, TargetNullValue=False}" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Löschen">
              <Grid>
                <svg:Svg Width="12" Height="12" Path="avares://Amium.UiEditor/EditorIcons/remove.svg" Css="path { fill: #111827; }" IsVisible="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, Converter={StaticResource BoolNegationConverter}, FallbackValue=True, TargetNullValue=True}" />
                <svg:Svg Width="12" Height="12" Path="avares://Amium.UiEditor/EditorIcons/remove.svg" Css="path { fill: #FFFFFF; }" IsVisible="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=False, TargetNullValue=False}" />
              </Grid>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <TextBlock
          Grid.Row="1"
          Margin="8,0,0,6"
          FontSize="{Binding ItemBodyCaptionFontSize}"
          FontWeight="SemiBold"
          Foreground="{Binding EffectiveBodyForegroundBrush}"
          IsVisible="{Binding BodyCaptionVisible}"
          Opacity="0.82"
          Text="{Binding BodyCaption}" />

      <Border Grid.Row="2" Margin="0,2,0,2" Padding="8,0,8,0" ClipToBounds="True" Background="{Binding EffectiveBodyBackgroundBrush}" BorderBrush="{Binding EffectiveBodyBorderBrush}" BorderThickness="{Binding EffectiveBodyBorderThickness}" CornerRadius="{Binding EffectiveBodyCornerRadius}">
        <ContentPresenter
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Content="{Binding BodyContent, RelativeSource={RelativeSource AncestorType=controls:EditorTemplateControl}}" />
      </Border>

      <Border Grid.Row="3" Margin="0,2,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{Binding EffectiveFooterBackgroundBrush}" BorderBrush="{Binding EffectiveFooterBorderBrush}" BorderThickness="{Binding EffectiveFooterBorderThickness}" CornerRadius="{Binding EffectiveFooterCornerRadius}" IsVisible="{Binding ShowFooter}">
        <TextBlock
            Margin="0,1,0,0"
            VerticalAlignment="Center"
            FontStyle="Italic"
            FontSize="13"
            Foreground="{Binding EffectiveFooterForegroundBrush}"
            Text="{Binding Footer}" />
      </Border>

      <StackPanel
          Grid.RowSpan="4"
          Panel.ZIndex="10"
          Margin="0,4,0,0"
          HorizontalAlignment="Right"
          Orientation="Horizontal"
          Spacing="4"
          VerticalAlignment="Top"
          IsVisible="{Binding ShowControlCaption, Converter={StaticResource BoolNegationConverter}}">
        <Button
            Classes="toolicon"
            Width="18"
            Height="18"
            MinWidth="18"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderBrush="Transparent"
            CornerRadius="0"
            Click="OnSettingsClicked"
            IsVisible="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=False, TargetNullValue=False}"
            PointerPressed="OnInteractivePointerPressed"
            ToolTip.Tip="Settings">
          <Grid>
            <svg:Svg Width="12" Height="12" Path="avares://Amium.UiEditor/EditorIcons/cog.svg" Css="path { fill: #111827; }" IsVisible="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, Converter={StaticResource BoolNegationConverter}, FallbackValue=True, TargetNullValue=True}" />
            <svg:Svg Width="12" Height="12" Path="avares://Amium.UiEditor/EditorIcons/cog.svg" Css="path { fill: #FFFFFF; }" IsVisible="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=False, TargetNullValue=False}" />
          </Grid>
        </Button>
        <Button
            Classes="toolicon"
            Width="18"
            Height="18"
            MinWidth="18"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderBrush="Transparent"
            CornerRadius="0"
            Click="OnDeleteClicked"
            IsVisible="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=False, TargetNullValue=False}"
            PointerPressed="OnInteractivePointerPressed"
            ToolTip.Tip="Löschen">
          <Grid>
            <svg:Svg Width="12" Height="12" Path="avares://Amium.UiEditor/EditorIcons/remove.svg" Css="path { fill: #111827; }" IsVisible="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, Converter={StaticResource BoolNegationConverter}, FallbackValue=True, TargetNullValue=True}" />
            <svg:Svg Width="12" Height="12" Path="avares://Amium.UiEditor/EditorIcons/remove.svg" Css="path { fill: #FFFFFF; }" IsVisible="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=False, TargetNullValue=False}" />
          </Grid>
        </Button>
      </StackPanel>
    </Grid>
  </Border>
</controls:EditorTemplateControl>
