<UserControl
    x:Name="Root"
    x:Class="UiEditor.Controls.EditorListControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UiEditor.Controls"
    xmlns:models="using:UiEditor.Models"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
    Width="{Binding Width}"
    Height="{Binding Height}">

  <Border Background="{Binding EffectiveBackgroundBrush}" BorderBrush="{Binding EffectiveBorderBrushValue}" BorderThickness="{Binding EffectiveBorderThickness}" CornerRadius="10" Padding="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid RowDefinitions="38,*" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
        <TextBlock Margin="0,0,12,0" VerticalAlignment="Center" FontSize="17" FontWeight="SemiBold" Foreground="{Binding EffectivePrimaryForegroundBrush}" Text="{Binding Title}" />
        <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" CornerRadius="8" Padding="8,4">
          <Button Classes="toolicon" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" Click="OnSettingsClicked" IsVisible="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="List Einstellungen">
            <svg:Svg Width="16" Height="16" Path="avares://UiEditor/EditorIcons/cog.svg" />
          </Button>
        </Border>
      </Grid>

      <Border x:Name="ListViewportBorder" Grid.Row="1" Margin="0,10,0,0" Background="{Binding EffectiveContainerBackground}" BorderBrush="{Binding EffectiveContainerBorderBrushValue}" BorderThickness="{Binding EffectiveContainerBorderThickness}" CornerRadius="8" ClipToBounds="True" Padding="10,0,10,0">
        <ListBox x:Name="ItemListBox" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="0" ItemsSource="{Binding Items}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0,2,16,2" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="BorderThickness" Value="0" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate DataType="models:PageItemModel">
              <Border Height="{Binding Height}" HorizontalAlignment="Stretch" PointerPressed="OnChildItemPointerPressed">
                <Grid HorizontalAlignment="Stretch" Height="{Binding Height}">
                  <controls:EditorButtonControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch" DataContext="{Binding}" IsVisible="{Binding IsButton}" />
                  <controls:EditorItemControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch" DataContext="{Binding}" IsVisible="{Binding IsItem}" />
                  <Border BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter=#F59E0B}" BorderThickness="2" CornerRadius="8" IsHitTestVisible="False" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </Grid>
  </Border>
</UserControl>


