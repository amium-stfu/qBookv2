<editorUi:EditorTemplateControl
    x:Class="Amium.UiEditor.Controls.UdlClientControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Controls"
    xmlns:editorUi="using:Amium.EditorUi.Controls"
    xmlns:viewModels="using:Amium.UiEditor.ViewModels">
  <controls:UdlClientControl.HeaderActionsContent>
    <Grid ColumnDefinitions="Auto,Auto">
          <Button Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Cursor="Hand"
              HorizontalAlignment="Left"
              IsEnabled="{Binding CanToggleConnection, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
              Click="OnToggleConnectionClicked"
              PointerPressed="OnInteractivePointerPressed">
      <Border Background="{Binding ConnectionStatusBackground, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
          CornerRadius="6"
          Padding="6,2">
        <TextBlock FontSize="11"
           FontWeight="SemiBold"
           Foreground="{Binding ConnectionStatusForeground, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}"
           Text="{Binding ConnectionStateText, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}" />
      </Border>
      </Button>

      <Border Grid.Column="1"
                          Margin="6,0,0,0"
                          Padding="6,2"
                          Background="#E0E0E0"
                          BorderBrush="{Binding CardBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}"
                          BorderThickness="1"
                          CornerRadius="6">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock FontSize="11"
                     Foreground="#111827"
                     Text="Modules" />
          <TextBlock FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="#111827"
                     Text="{Binding ItemCountText, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}" />
        </StackPanel>
      </Border>
    </Grid>
  </controls:UdlClientControl.HeaderActionsContent>

  <controls:UdlClientControl.BodyContent>
    <Border Padding="10,8"
            Background="{Binding EffectiveBodyBackgroundBrush}"
            BorderBrush="{Binding EffectiveBodyBorderBrush}"
            BorderThickness="{Binding EffectiveBodyBorderThickness}"
            CornerRadius="10">
      <Grid ColumnDefinitions="*">
        <StackPanel Spacing="2" VerticalAlignment="Center">
          <TextBlock FontSize="12" Foreground="{Binding EffectiveMutedForegroundBrush}" Text="Socket" />
          <TextBlock FontSize="16" FontWeight="Bold" Foreground="{Binding EffectiveBodyForegroundBrush}" Text="{Binding SocketText, RelativeSource={RelativeSource AncestorType=controls:UdlClientControl}}" />
        </StackPanel>
      </Grid>
    </Border>
  </controls:UdlClientControl.BodyContent>
</editorUi:EditorTemplateControl>