<editorUi:EditorTemplateControl
    x:Class="Amium.UiEditor.Controls.EditorButtonControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Controls"
  xmlns:editorUi="using:Amium.EditorUi.Controls"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia">
  <controls:EditorButtonControl.BodyContent>
    <Border
        Margin="0"
        Padding="12,4"
        Background="{Binding EffectiveButtonBodyBackgroundBrush}"
        BorderBrush="{Binding EffectiveBodyBorderBrush}"
        BorderThickness="{Binding EffectiveBodyBorderThickness}"
        CornerRadius="{Binding EffectiveBodyCornerRadius}"
        PointerReleased="OnButtonReleased">
      <Grid ClipToBounds="True">
        <editorUi:ThemeSvgIcon
            Width="{Binding ButtonIconSize}"
            Height="{Binding ButtonIconSize}"
            HorizontalAlignment="{Binding ButtonIconHorizontalAlignment}"
            VerticalAlignment="Center"
            IsVisible="{Binding ShowButtonIcon}"
          IconPath="{Binding EffectiveButtonIconPath}"
          TintColor="{Binding EffectiveButtonIconTintColor}" />
        <TextBlock
            HorizontalAlignment="{Binding ButtonTextHorizontalAlignment}"
            VerticalAlignment="Center"
            FontSize="{Binding ButtonBodyFontSize}"
            FontWeight="SemiBold"
            Foreground="{Binding EffectiveButtonBodyForegroundBrush}"
            IsVisible="{Binding ShowButtonText}"
            Text="{Binding EffectiveButtonText}"
            TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>
  </controls:EditorButtonControl.BodyContent>
</editorUi:EditorTemplateControl>
