<UserControl
    x:Name="Root"
    x:Class="Amium.UiEditor.Controls.EditorChartControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Controls"
    xmlns:ScottPlot="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
    Width="{Binding Width}"
    Height="{Binding Height}">

  <Border Background="{Binding EffectiveBackgroundBrush}" BorderBrush="{Binding EffectiveBorderBrushValue}" BorderThickness="{Binding EffectiveBorderThickness}" CornerRadius="{Binding EffectiveCornerRadius}" Padding="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid RowDefinitions="38,Auto,*,Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto" HorizontalAlignment="Stretch">
        <TextBlock Margin="0,0,12,0" VerticalAlignment="Center" FontSize="17" FontWeight="SemiBold" Foreground="{Binding EffectivePrimaryForegroundBrush}" Text="{Binding Title}" />
        <Border Grid.Column="1" Margin="0,0,8,0" Background="Transparent" CornerRadius="8" Padding="8,4">
          <Button x:Name="PauseButton" Classes="toolicon" Click="OnPauseClicked" Content="Pause" />
        </Border>
        <Border Grid.Column="2" Margin="0,0,8,0" Background="Transparent" CornerRadius="8" Padding="8,4">
          <Button Classes="toolicon" Click="OnClearClicked" Content="Clear" />
        </Border>
        <Border Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" CornerRadius="8" Padding="8,4">
          <Button Classes="toolicon" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=#F8FAFC, TargetNullValue=#F8FAFC}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=#CBD5E1, TargetNullValue=#CBD5E1}" Click="OnSettingsClicked" IsVisible="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}, FallbackValue=False, TargetNullValue=False}" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Chart Einstellungen">
            <svg:Svg Width="16" Height="16" Path="avares://Amium.UiEditor/EditorIcons/cog.svg" />
          </Button>
        </Border>
      </Grid>

      <TextBlock x:Name="StatusTextBlock" Grid.Row="1" Margin="0,10,0,0" Foreground="{Binding EffectiveMutedForeground}" />

      <Border Grid.Row="2" Margin="0,10,0,0" Background="{Binding EffectiveContainerBackground}" BorderBrush="{Binding EffectiveContainerBorderBrushValue}" BorderThickness="{Binding EffectiveContainerBorderThickness}" CornerRadius="{Binding EffectiveCornerRadius}" ClipToBounds="True" Padding="8">
        <Grid x:Name="PlotHost" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" PointerMoved="OnPlotPointerMoved" PointerExited="OnPlotPointerExited">
          <ScottPlot:AvaPlot x:Name="ChartPlot" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
          <Canvas x:Name="CrosshairOverlay" IsHitTestVisible="False" ClipToBounds="True">
            <Border x:Name="CrosshairVerticalLine" Width="1" Background="{Binding EffectivePrimaryForegroundBrush}" Opacity="0.55" IsVisible="False" />
            <Border x:Name="CrosshairHorizontalLine" Height="1" Background="{Binding EffectivePrimaryForegroundBrush}" Opacity="0.55" IsVisible="False" />
          </Canvas>
          <Border x:Name="CrosshairInfoBorder" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Padding="8,6" Background="{Binding EffectiveBackgroundBrush}" BorderBrush="{Binding EffectiveContainerBorderBrushValue}" BorderThickness="1" CornerRadius="6" Opacity="0.95" IsHitTestVisible="False" IsVisible="False">
            <TextBlock x:Name="CrosshairInfoTextBlock" FontFamily="Consolas" FontSize="12" Foreground="{Binding EffectivePrimaryForegroundBrush}" TextWrapping="NoWrap" />
          </Border>
        </Grid>
      </Border>

      <TextBlock Grid.Row="3" Margin="0,10,0,0" Foreground="{Binding EffectiveMutedForeground}" Text="{Binding Footer}" />
    </Grid>
  </Border>
</UserControl>


