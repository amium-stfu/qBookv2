<UserControl
    x:Name="Root"
    x:Class="UiEditor.Controls.EditorLogControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:UiEditor.Controls"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
    Width="{Binding Width}"
    Height="{Binding Height}">

  <Border Background="{Binding EffectiveBackgroundBrush}" BorderBrush="{Binding EffectiveBorderBrushValue}" BorderThickness="{Binding EffectiveBorderThickness}" CornerRadius="10" Padding="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid RowDefinitions="38,*,Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
        <TextBlock Margin="0,0,12,0" VerticalAlignment="Center" FontSize="17" FontWeight="SemiBold" Foreground="{Binding EffectivePrimaryForegroundBrush}" Text="{Binding Title}" />
        <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" CornerRadius="8" Padding="8,4">
          <Button Classes="toolicon" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" Click="OnSettingsClicked" IsVisible="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Log Einstellungen">
            <svg:Svg Width="16" Height="16" Path="avares://UiEditor/EditorIcons/cog.svg" />
          </Button>
        </Border>
      </Grid>

      <Border Grid.Row="1" Margin="0,10,0,0" Background="{Binding EffectiveContainerBackground}" BorderBrush="{Binding EffectiveContainerBorderBrushValue}" BorderThickness="{Binding EffectiveContainerBorderThickness}" CornerRadius="8" ClipToBounds="True" Padding="10,10,10,10">
        <ListBox x:Name="LogListBox" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="0" ItemsSource="{Binding LogEntries, ElementName=Root}" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0,0,0,4" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="BorderThickness" Value="0" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{Binding DataContext.EffectiveSecondaryForeground, ElementName=Root}" Text="{Binding}" TextWrapping="Wrap" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <TextBlock Grid.Row="2" Margin="0,10,0,0" Foreground="{Binding EffectiveMutedForeground}" Text="{Binding Footer}" />
    </Grid>
  </Border>
</UserControl>


