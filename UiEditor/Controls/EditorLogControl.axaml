<UserControl
    x:Name="Root"
    x:Class="Amium.UiEditor.Controls.EditorLogControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Controls"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
    Width="{Binding Width}"
    Height="{Binding Height}">

  <Border Background="{Binding EffectiveBackgroundBrush}" BorderBrush="{Binding EffectiveBorderBrushValue}" BorderThickness="{Binding EffectiveBorderThickness}" CornerRadius="10" Padding="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid RowDefinitions="38,*,Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
        <TextBlock Margin="0,0,12,0" VerticalAlignment="Center" FontSize="17" FontWeight="SemiBold" Foreground="{Binding EffectivePrimaryForegroundBrush}" Text="{Binding Title}" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="6">
          <Button x:Name="SettingsButton" Classes="toolicon" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" Click="OnSettingsClicked" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Log Einstellungen">
            <svg:Svg Width="16" Height="16" Path="avares://Amium.UiEditor/EditorIcons/cog.svg" />
          </Button>
        </StackPanel>
      </Grid>

      <Border Grid.Row="1" Margin="0,10,0,0" Background="{Binding EffectiveContainerBackgroundBrush}" BorderBrush="{Binding EffectiveContainerBorderBrushValue}" BorderThickness="{Binding EffectiveContainerBorderThickness}" CornerRadius="8" ClipToBounds="True" Padding="10,10,10,10">
        <ListBox x:Name="LogListBox" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="0" ItemsSource="{Binding LogEntries, ElementName=Root}" SelectionMode="Multiple" KeyDown="OnLogListBoxKeyDown" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0,0,0,4" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="BorderThickness" Value="0" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{Binding Foreground}" Text="{Binding Text}" TextWrapping="Wrap" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <Grid Grid.Row="2" Margin="0,10,0,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
        <TextBlock Foreground="{Binding EffectiveMutedForegroundBrush}" Text="{Binding Footer}" VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="6">
          <Button x:Name="DebugButton" Classes="toolicon" Width="30" Height="30" MinWidth="30" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" Click="OnDebugFilterClicked" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Debug ein/aus">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="D" />
          </Button>
          <Button x:Name="InfoButton" Classes="toolicon" Width="30" Height="30" MinWidth="30" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" Click="OnInfoFilterClicked" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Info ein/aus">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="I" />
          </Button>
          <Button x:Name="WarningButton" Classes="toolicon" Width="30" Height="30" MinWidth="30" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" Click="OnWarningFilterClicked" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Warning ein/aus">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="W" />
          </Button>
          <Button x:Name="ErrorButton" Classes="toolicon" Width="30" Height="30" MinWidth="30" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" Click="OnErrorFilterClicked" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Error ein/aus">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="E" />
          </Button>
          <Button x:Name="FatalButton" Classes="toolicon" Width="30" Height="30" MinWidth="30" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" Click="OnFatalFilterClicked" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Fatal ein/aus">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="F" />
          </Button>
          <Button x:Name="PauseButton" Classes="toolicon" Width="30" Height="30" MinWidth="30" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" Click="OnPauseClicked" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Live/Pause">
            <svg:Svg x:Name="PauseIcon" Width="14" Height="14" Path="avares://Amium.UiEditor/EditorIcons/pause.svg" />
          </Button>
          <Button x:Name="OpenFolderButton" Classes="toolicon" Width="30" Height="30" MinWidth="30" VerticalAlignment="Center" Background="{Binding DataContext.EditPanelButtonBackground, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" BorderBrush="{Binding DataContext.EditPanelButtonBorderBrush, RelativeSource={RelativeSource AncestorType=controls:PageEditorControl}}" Click="OnOpenFolderClicked" PointerPressed="OnInteractivePointerPressed" ToolTip.Tip="Log Verzeichnis oeffnen">
            <svg:Svg Width="14" Height="14" Path="avares://Amium.UiEditor/EditorIcons/folder.svg" />
          </Button>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</UserControl>


