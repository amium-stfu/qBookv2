<Window
    x:Class="UiEditor.LogWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="900"
    Height="620"
    MinWidth="700"
    MinHeight="420"
    Title="Host Log">
  <Grid RowDefinitions="Auto,Auto,*" Margin="12">
    <TextBlock FontSize="22" FontWeight="Bold" Text="Host Log" />

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,12,0,12">
      <StackPanel Spacing="4">
        <TextBlock VerticalAlignment="Center" Text="{Binding CurrentLogFilePath}" TextWrapping="Wrap" />
        <TextBlock Text="Anzeige aus dem gepufferten Host-Log-Sink. Kein direkter Dateizugriff." TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1" Classes="toolbar" Command="{Binding RefreshLogCommand}" Content="Refresh" />
    </Grid>

    <TextBox
        Grid.Row="2"
        IsReadOnly="True"
        AcceptsReturn="True"
        FontFamily="Consolas"
        TextWrapping="NoWrap"
        ScrollViewer.HorizontalScrollBarVisibility="Auto"
        ScrollViewer.VerticalScrollBarVisibility="Auto"
        VerticalContentAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        Text="{Binding CurrentLogText}" />
  </Grid>
</Window>
