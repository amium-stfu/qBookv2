<Window
    x:Name="Root"
    x:Class="Amium.UiEditor.LogWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Controls"
    Background="{Binding WindowBackground}"
    Foreground="{Binding PrimaryTextBrush}"
    Width="900"
    Height="620"
    MinWidth="700"
    MinHeight="420"
    Title="Host Log">
  <Grid Margin="12">
    <controls:EditorLogControl
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        ShowSettingsButton="False"
        DataContext="{Binding HostLogItem, ElementName=Root}" />
  </Grid>
</Window>
