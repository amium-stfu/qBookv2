<Window
    x:Class="Amium.UiEditor.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="1280"
    Height="820"
    MinWidth="1024"
    MinHeight="720"
    Background="{Binding WindowBackground}"
    Title="UI Editor PoC [Testbook Build]">
  <Grid RowDefinitions="Auto,*,Auto" Margin="8">
    <Border Grid.Row="0" Classes="card" Padding="18,14" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}">
      <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">

            <TextBlock FontSize="26" FontWeight="Bold" Foreground="{Binding PrimaryTextBrush}" Text="UI Editor" />
            <TextBlock Foreground="{Binding SecondaryTextBrush}" Text="Proof of concept fuer seitenorientierte Avalonia-Oberflaechen" />

        <Border
            Grid.Column="1"
            Padding="18,8"
            CornerRadius="24"
            Background="{Binding HeaderBadgeBackground}">
          <TextBlock FontSize="16" FontWeight="Bold" Foreground="{Binding HeaderBadgeForeground}" Text="amium" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="150,*" Margin="0,8,0,8">
      <Border Grid.Column="0" Classes="card" Margin="0,0,0,0" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="12">
            <TextBlock HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Control Panel" />
            <ToggleButton Classes="toolbar" IsChecked="{Binding IsEditMode}">
              <TextBlock HorizontalAlignment="Center" Text="Edit mode" />
            </ToggleButton>
            <ToggleButton Classes="toolbar" IsChecked="{Binding IsDarkTheme}">
              <TextBlock HorizontalAlignment="Center" Text="{Binding ThemeModeText}" />
            </ToggleButton>
            <Button Classes="toolbar" Command="{Binding SaveLayoutCommand}" Content="Save JSON" />
            <Button Classes="toolbar" Command="{Binding LoadLayoutCommand}" Content="Load JSON" />
            <Button Classes="toolbar" Click="LoadBook_Click" Content="Load" />
            <Button Classes="toolbar" Command="{Binding RebuildBookCommand}" Content="Rebuild" />
            <Button Classes="toolbar" Click="OpenVsCode_Click" Content="Open VS Code" />
            <Button Classes="toolbar" Click="OpenLogWindow_Click" Content="Open Log" />
            <TextBlock FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Layout-Datei" />
            <SelectableTextBlock TextWrapping="Wrap" Foreground="{Binding SecondaryTextBrush}" Text="{Binding LayoutFilePath}" />
            <TextBlock TextWrapping="Wrap" Foreground="{Binding SecondaryTextBrush}" Text="Im Editiermodus erscheint das Editpanel direkt im Canvas oben mittig. Dort findest du Raster, Snap und die Ausrichtungsfunktionen." />
            <TextBlock TextWrapping="Wrap" Foreground="{Binding SecondaryTextBrush}" Text="Tipp: Mehrfachauswahl nur mit gedrueckter Strg-Taste. Strg-Klick erweitert die Auswahl, Strg-Ziehen markiert mehrere Controls." />
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Border Grid.Column="1" Classes="card" Padding="0" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}">
        <TabControl
            x:Name="PageTabs"
            Margin="8,6,0,6"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Pages}"
            SelectedItem="{Binding SelectedPage}"
            TabStripPlacement="{Binding TabStripPlacement}">
          <TabControl.Styles>
            <Style Selector="TabControl#PageTabs /template/ ContentPresenter#PART_SelectedContentHost">
              <Setter Property="Margin" Value="0" />
            </Style>
            <Style Selector="TabControl#PageTabs /template/ DockPanel">
              <Setter Property="Margin" Value="0" />
            </Style>
            <Style Selector="TabControl#PageTabs /template/ TabStrip">
              <Setter Property="Margin" Value="0" />
              <Setter Property="VerticalAlignment" Value="Top" />
              <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>
            <Style Selector="TabControl#PageTabs TabItem">
              <Setter Property="Margin" Value="0" />
              <Setter Property="Padding" Value="0" />
            </Style>
            <Style Selector="TabControl#PageTabs TabItem /template/ ContentPresenter">
              <Setter Property="HorizontalAlignment" Value="{Binding #PageTabs.DataContext.TabHeaderHorizontalAlignment}" />
            </Style>
          </TabControl.Styles>
          <TabControl.ItemTemplate>
            <DataTemplate>
              <Border
                  Margin="0,0,0,0"
                  Padding="1"
                  CornerRadius="0">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Top" Command="{Binding #PageTabs.DataContext.SetTabStripPlacementCommand}" CommandParameter="Top" />
        
                    <MenuItem Header="Right" Command="{Binding #PageTabs.DataContext.SetTabStripPlacementCommand}" CommandParameter="Right" />
                  
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid ColumnDefinitions="48,200">
                  <Border Grid.ColumnSpan="2"
                          Background="{Binding DataContext.TabBackColor, RelativeSource={RelativeSource AncestorType=Window}}"
                          CornerRadius="0"
                          IsVisible="{Binding IsNotSelected}" />
                  <Border Grid.ColumnSpan="2"
                          Background="{Binding DataContext.TabSelectBackColor, RelativeSource={RelativeSource AncestorType=Window}}"
                          CornerRadius="0"
                          IsVisible="{Binding IsSelected}" />
                  <Border Grid.Column="0"
                          Background="{Binding DataContext.TabNumerBackColor, RelativeSource={RelativeSource AncestorType=Window}}"
                          CornerRadius="0"
                          MinHeight="52"
                          IsVisible="{Binding IsNotSelected}" />
                  <Border Grid.Column="0"
                          Background="{Binding DataContext.TabSelectNumerBackColor, RelativeSource={RelativeSource AncestorType=Window}}"
                          CornerRadius="0"
                          MinHeight="52"
                          IsVisible="{Binding IsSelected}" />
                  <TextBlock Grid.Column="0"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="22"
                             FontWeight="Bold"
                             Foreground="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}"
                             IsVisible="{Binding IsNotSelected}"
                             Text="{Binding Index}" />
                  <TextBlock Grid.Column="0"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="22"
                             FontWeight="Bold"
                             Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}"
                             IsVisible="{Binding IsSelected}"
                             Text="{Binding Index}" />
                  <TextBlock Grid.Column="1"
                             Margin="12,6"
                             VerticalAlignment="Center"
                             FontSize="18"
                             FontWeight="SemiBold"
                             Foreground="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}"
                             IsVisible="{Binding IsNotSelected}"
                             Text="{Binding TabTitle}" />
                  <TextBlock Grid.Column="1"
                             Margin="12,6"
                             VerticalAlignment="Center"
                             FontSize="18"
                             FontWeight="SemiBold"
                             Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}"
                             IsVisible="{Binding IsSelected}"
                             Text="{Binding TabTitle}" />
                </Grid>
              </Border>
            </DataTemplate>
          </TabControl.ItemTemplate>
          <TabControl.ContentTemplate>
            <DataTemplate>
              <controls:PageEditorControl
                  DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
            </DataTemplate>
          </TabControl.ContentTemplate>
        </TabControl>
      </Border>
    </Grid>

    <Border Grid.Row="2" Classes="card" Padding="16,10" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBlock VerticalAlignment="Center" Foreground="{Binding SecondaryTextBrush}" Text="{Binding FooterText}" />
          <TextBlock VerticalAlignment="Center" Foreground="{Binding SecondaryTextBrush}" Text="{Binding StatusText}" />
        </StackPanel>
        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Footer" />
      </Grid>
    </Border>
  </Grid>
</Window>




