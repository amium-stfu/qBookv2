<Window
    x:Class="Amium.UiEditor.Widgets.UdlDemoModulesDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Controls"
    xmlns:viewModels="using:Amium.UiEditor.Widgets"
    Width="980"
    MinWidth="900"
    Height="700"
    MinHeight="620"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="UDL Demo Modules"
    Background="{Binding DialogBackground}">
  <Window.Styles>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding ButtonBackground}" />
      <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeground}" />
    </Style>
  </Window.Styles>

  <controls:EditorShellControl Margin="16"
                               ShellBackground="{Binding DialogBackground}"
                               ShellBorderBrush="{Binding BorderColor}"
                               ShellBorderThickness="1"
                               ShellCornerRadius="10"
                               ShellPadding="16"
                               ShowHeader="True"
                               ShowFooter="True">
    <controls:EditorShellControl.HeaderContent>
      <StackPanel>
        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="UDL Demo Modules" />
        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="Configure simulated UDL modules for dynamic or set-driven demo mode." TextWrapping="Wrap" />
      </StackPanel>
    </controls:EditorShellControl.HeaderContent>

    <controls:EditorShellControl.BodyContent>
      <Grid ColumnDefinitions="300,*">
        <Border Grid.Column="0"
          Margin="0,0,12,0"
                Background="{Binding SectionBackground}"
                BorderBrush="{Binding BorderColor}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
          <Grid RowDefinitions="Auto,*">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="dialog-button" Content="Add" Click="OnAddClicked" />
              <Button Classes="dialog-button" Content="Remove" Click="OnRemoveClicked" IsEnabled="{Binding HasSelectedRow}" />
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Rows}"
                     SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                     Background="{Binding EditorBackground}"
                     BorderBrush="{Binding BorderColor}">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="viewModels:UdlDemoModuleEditorRow">
                  <Border Padding="8" Margin="0,0,0,6" CornerRadius="6" Background="Transparent">
                    <StackPanel Spacing="2">
                      <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" Text="{Binding Name}" />
                      <TextBlock FontSize="11" Foreground="{Binding DataContext.SecondaryTextBrush, ElementName=Root}" Text="{Binding Summary}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="{Binding SectionBackground}"
                BorderBrush="{Binding BorderColor}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
          <Grid>
            <TextBlock IsVisible="{Binding ShowEmptyState}"
                       Foreground="{Binding SecondaryTextBrush}"
                       Text="Add a module or select an existing one to edit its demo behavior." />

            <ScrollViewer IsVisible="{Binding HasSelectedRow}" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                  <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Name" />
                  <TextBox Grid.Column="1" Margin="10,0,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.Name, Mode=TwoWay}" />

                  <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Kind" />
                  <ComboBox Grid.Row="1" Grid.Column="1" Margin="10,8,0,0" ItemsSource="{Binding KindOptions}" SelectedItem="{Binding SelectedRow.SelectedKind, Mode=TwoWay}" />

                  <TextBlock Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Generator" IsVisible="{Binding SelectedRow.IsDynamic}" />
                  <ComboBox Grid.Row="2" Grid.Column="1" Margin="10,8,0,0" ItemsSource="{Binding GeneratorOptions}" SelectedItem="{Binding SelectedRow.SelectedGenerator, Mode=TwoWay}" IsVisible="{Binding SelectedRow.IsDynamic}" />

                  <TextBlock Grid.Row="3" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Unit" />
                  <TextBox Grid.Row="3" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.Unit, Mode=TwoWay}" />

                  <TextBlock Grid.Row="4" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Format" />
                  <TextBox Grid.Row="4" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.Format, Mode=TwoWay}" />

                  <TextBlock Grid.Row="5" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="BaseValue" />
                  <TextBox Grid.Row="5" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.BaseValueText, Mode=TwoWay}" />

                  <TextBlock Grid.Row="6" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Amplitude" IsVisible="{Binding SelectedRow.IsDynamic}" />
                  <TextBox Grid.Row="6" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.AmplitudeText, Mode=TwoWay}" IsVisible="{Binding SelectedRow.IsDynamic}" />

                  <TextBlock Grid.Row="7" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="PeriodSeconds" IsVisible="{Binding SelectedRow.IsDynamic}" />
                  <TextBox Grid.Row="7" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.PeriodSecondsText, Mode=TwoWay}" IsVisible="{Binding SelectedRow.IsDynamic}" />

                  <TextBlock Grid.Row="8" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="InitialValue" />
                  <TextBox Grid.Row="8" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.InitialValueText, Mode=TwoWay}" />

                  <TextBlock Grid.Row="9" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="SetScale" IsVisible="{Binding SelectedRow.IsSetDriven}" />
                  <TextBox Grid.Row="9" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.SetScaleText, Mode=TwoWay}" IsVisible="{Binding SelectedRow.IsSetDriven}" />

                  <TextBlock Grid.Row="10" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="SetOffset" IsVisible="{Binding SelectedRow.IsSetDriven}" />
                  <TextBox Grid.Row="10" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.SetOffsetText, Mode=TwoWay}" IsVisible="{Binding SelectedRow.IsSetDriven}" />

                  <TextBlock Grid.Row="11" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="SetTauSeconds" IsVisible="{Binding SelectedRow.IsSetDriven}" />
                  <TextBox Grid.Row="11" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.SetTauSecondsText, Mode=TwoWay}" IsVisible="{Binding SelectedRow.IsSetDriven}" />
                </Grid>

                <TextBlock FontSize="11"
                           Foreground="{Binding SecondaryTextBrush}"
                           Text="For SetDriven modules, SetTauSeconds simulates a first-order settling time. 0 means immediate jump, larger values mean slower approach to Set.Request.Value."
                           TextWrapping="Wrap"
                           IsVisible="{Binding SelectedRow.IsSetDriven}" />

                <Border Padding="10" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                  <StackPanel Spacing="8">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Noise Fault" />
                    <TextBlock FontSize="11"
                               Foreground="{Binding SecondaryTextBrush}"
                               Text="Enable any combination of jitter, sinus and peak noise. Amount controls jitter and sinus. PeakAmount controls the peak magnitude independently."
                               TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                      <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Enabled" />
                      <CheckBox Grid.Column="1" Margin="10,0,0,0" IsChecked="{Binding SelectedRow.NoiseFault.Enabled, Mode=TwoWay}" VerticalAlignment="Center" />

                      <TextBlock Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Max +/- offset" />
                      <TextBox Grid.Row="1" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.NoiseFault.AmountText, Mode=TwoWay}" />

                      <TextBlock Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Jitter" />
                      <CheckBox Grid.Row="2" Grid.Column="1" Margin="10,8,0,0" IsChecked="{Binding SelectedRow.NoiseFault.UseJitter, Mode=TwoWay}" VerticalAlignment="Center" />

                      <TextBlock Grid.Row="3" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Sinus" />
                      <CheckBox Grid.Row="3" Grid.Column="1" Margin="10,8,0,0" IsChecked="{Binding SelectedRow.NoiseFault.UseSine, Mode=TwoWay}" VerticalAlignment="Center" />

                      <TextBlock Grid.Row="4" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Peak" />
                      <CheckBox Grid.Row="4" Grid.Column="1" Margin="10,8,0,0" IsChecked="{Binding SelectedRow.NoiseFault.UsePeak, Mode=TwoWay}" VerticalAlignment="Center" />

                      <TextBlock Grid.Row="5" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="PeakAmount" IsVisible="{Binding SelectedRow.NoiseFault.UsesPeakDuration}" />
                      <TextBox Grid.Row="5" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.NoiseFault.PeakAmountText, Mode=TwoWay}" IsVisible="{Binding SelectedRow.NoiseFault.UsesPeakDuration}" />

                      <TextBlock Grid.Row="6" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="NoisePeriodSeconds" IsVisible="{Binding SelectedRow.NoiseFault.UsesSinePeriod}" />
                      <TextBox Grid.Row="6" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.NoiseFault.PeriodSecondsText, Mode=TwoWay}" IsVisible="{Binding SelectedRow.NoiseFault.UsesSinePeriod}" />

                      <TextBlock Grid.Row="7" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="PeakIntervalMs" IsVisible="{Binding SelectedRow.NoiseFault.UsesUpdateInterval}" />
                      <TextBox Grid.Row="7" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.NoiseFault.UpdateIntervalMsText, Mode=TwoWay}" IsVisible="{Binding SelectedRow.NoiseFault.UsesUpdateInterval}" />

                      <TextBlock Grid.Row="8" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="PeakLengthMs" IsVisible="{Binding SelectedRow.NoiseFault.UsesPeakDuration}" />
                      <TextBox Grid.Row="8" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.NoiseFault.DurationMsText, Mode=TwoWay}" IsVisible="{Binding SelectedRow.NoiseFault.UsesPeakDuration}" />
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Padding="10" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                  <StackPanel Spacing="8">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Freeze Fault" />
                    <TextBlock FontSize="11"
                               Foreground="{Binding SecondaryTextBrush}"
                               Text="Freezes the current output value in intervals. IntervalSeconds controls how often it starts, DurationMs how long the freeze lasts."
                               TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto">
                      <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Enabled" />
                      <CheckBox Grid.Column="1" Margin="10,0,0,0" IsChecked="{Binding SelectedRow.FreezeFault.Enabled, Mode=TwoWay}" VerticalAlignment="Center" />

                      <TextBlock Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="IntervalSeconds" />
                      <TextBox Grid.Row="1" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.FreezeFault.IntervalSecondsText, Mode=TwoWay}" />

                      <TextBlock Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="DurationMs" />
                      <TextBox Grid.Row="2" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.FreezeFault.DurationMsText, Mode=TwoWay}" />
                    </Grid>
                  </StackPanel>
                </Border>

                <TextBlock FontSize="12" Foreground="#B42318" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </controls:EditorShellControl.BodyContent>

    <controls:EditorShellControl.FooterContent>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Classes="dialog-button" Content="Save" Click="OnSaveClicked" />
        <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
      </StackPanel>
    </controls:EditorShellControl.FooterContent>
  </controls:EditorShellControl>
</Window>