<UserControl
    x:Class="Amium.UiEditor.Widgets.ButtonControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:editorUi="using:Amium.UiEditor.Controls">
    <Border
      x:Name="RootBorder"
      Margin="0,0,0,0"
      Padding="0"
      CornerRadius="8"
      BorderThickness="0"
      IsEnabled="{Binding Enabled}">
    <Border.Styles>
      <Style Selector="Border#RootBorder">
        <Setter Property="Background" Value="{Binding EffectiveButtonBodyBackgroundBrush}" />
        <Setter Property="Cursor" Value="Arrow" />
      </Style>
      <Style Selector="Border#RootBorder:pointerover">
        <Setter Property="Background" Value="{Binding EffectiveButtonHoverBackgroundBrush}" />
        <Setter Property="Cursor" Value="Hand" />
      </Style>
      <Style Selector="Border#RootBorder.pressed">
        <Setter Property="Background" Value="{Binding EffectiveButtonPressBackgroundBrush}" />
        <Setter Property="Cursor" Value="Hand" />
      </Style>
      <Style Selector="Border#RootBorder:disabled">
        <Setter Property="Cursor" Value="Arrow" />
      </Style>
    </Border.Styles>
            <Grid x:Name="HitTarget"
              ClipToBounds="True"
              ColumnDefinitions="Auto,*,Auto">
      <!-- Left icon -->
      <editorUi:ThemeSvgIcon
        Grid.Column="0"
        Margin="10,0,10,0"
        Width="{Binding ButtonIconSize}"
        Height="{Binding ButtonIconSize}"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        IsVisible="{Binding ShowLeftButtonIcon}"
        IconPath="{Binding EffectiveButtonIconPath}"
        TintColor="{Binding EffectiveButtonIconTintColor}" />

      <!-- Center text (hidden when OnlyIcon=true) -->
      <TextBlock
        Grid.Column="1"
        Margin="10,0,10,0"
        HorizontalAlignment="{Binding ButtonTextHorizontalAlignment}"
        VerticalAlignment="Center"
        FontSize="{Binding ButtonBodyFontSize}"
        FontWeight="SemiBold"
        Foreground="{Binding EffectiveButtonBodyForegroundBrush}"
        Text="{Binding EffectiveButtonText}"
        TextTrimming="CharacterEllipsis"
        IsVisible="{Binding ShowButtonText}" />

      <!-- Center icon for OnlyIcon=true -->
      <editorUi:ThemeSvgIcon
        Grid.Column="1"
        
        Width="{Binding ButtonIconSize}"
        Height="{Binding ButtonIconSize}"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        IsVisible="{Binding ShowCenterButtonIcon}"
        IconPath="{Binding EffectiveButtonIconPath}"
        TintColor="{Binding EffectiveButtonIconTintColor}" />

      <!-- Right icon -->
      <editorUi:ThemeSvgIcon
        Grid.Column="2"
        Margin="10,0,10,0"
        Width="{Binding ButtonIconSize}"
        Height="{Binding ButtonIconSize}"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        IsVisible="{Binding ShowRightButtonIcon}"
        IconPath="{Binding EffectiveButtonIconPath}"
        TintColor="{Binding EffectiveButtonIconTintColor}" />
    </Grid>
  </Border>
</UserControl>
