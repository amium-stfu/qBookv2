<Window
    x:Class="Amium.UiEditor.Widgets.AdjustmentCurveEditorDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shapes="clr-namespace:Avalonia.Controls.Shapes;assembly=Avalonia.Controls"
    Width="1120"
    MinWidth="980"
    Height="820"
    MinHeight="720"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="Adjustment Curve Editor"
    Background="{Binding DialogBackground}">
  <Window.Styles>
    <Style Selector="Button.section-toggle">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="{Binding DataContext.SectionHeaderForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
    </Style>
    <Style Selector="Button.section-toggle:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding DataContext.ButtonBackground, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="BorderBrush" Value="{Binding DataContext.ButtonBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="Foreground" Value="{Binding DataContext.ButtonForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Style>
    <Style Selector="TextBox.dialog-field">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{Binding DataContext.BorderColor, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="Background" Value="{Binding DataContext.EditorBackground, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="Foreground" Value="{Binding DataContext.EditorForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="CaretBrush" Value="{Binding DataContext.EditorForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Style>
    <Style Selector="ComboBox.dialog-field">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Background" Value="{Binding DataContext.EditorBackground, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="Foreground" Value="{Binding DataContext.EditorForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="BorderBrush" Value="{Binding DataContext.BorderColor, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Style>
    <Style Selector="TextBox.dialog-field:pointerover, ComboBox.dialog-field:pointerover">
      <Setter Property="BorderBrush" Value="{Binding DataContext.ParameterHoverColor, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Style>
    <Style Selector="TextBox.dialog-field:focus, ComboBox.dialog-field:focus">
      <Setter Property="BorderBrush" Value="{Binding DataContext.ParameterHoverColor, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Style>
    <Style Selector="TextBox.dialog-field /template/ Border, ComboBox.dialog-field /template/ Border">
      <Setter Property="Background" Value="{Binding DataContext.EditorBackground, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="BorderBrush" Value="{Binding DataContext.BorderColor, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Style>
    <Style Selector="TabItem.dialog-tab">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Background" Value="{Binding DataContext.TabBackColor, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="Foreground" Value="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="BorderBrush" Value="{Binding DataContext.BorderColor, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,7" />
    </Style>
    <Style Selector="TabItem.dialog-tab:selected">
      <Setter Property="Background" Value="{Binding DataContext.TabSelectBackColor, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="Foreground" Value="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" />
      <Setter Property="BorderBrush" Value="{Binding DataContext.ParameterHoverColor, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Style>
  </Window.Styles>

  <Border Margin="16" Padding="12" Background="{Binding DialogBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="10">
    <Grid RowDefinitions="*,Auto">
      <TabControl Grid.Row="0" Margin="0,0,0,12">
        <TabItem Classes="dialog-tab" Header="Curve">
          <Grid Margin="0,8,0,0" ColumnDefinitions="360,16,*" RowDefinitions="Auto,*">
            <Grid Grid.ColumnSpan="3" RowDefinitions="Auto,Auto">
              <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="{Binding DialogTitle}" />
              <TextBlock Grid.Row="1" Margin="0,4,0,0" FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="{Binding DialogDescription}" TextWrapping="Wrap" />
            </Grid>

            <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="0,12,0,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" AllowAutoHide="False">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="Auto,*">
                  <Button Grid.Column="0" Classes="section-toggle" Content="{Binding DataSectionToggleGlyph}" Click="OnDataSectionToggleClicked" />
                  <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{Binding SectionHeaderForeground}" Text="Data" />
                </Grid>

                <Border IsVisible="{Binding IsDataSectionExpanded}" Padding="12" Background="{Binding SectionContentBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                  <StackPanel Spacing="10">
                    <TextBlock Foreground="{Binding SecondaryTextBrush}" Text="{Binding EditorHint}" TextWrapping="Wrap" />

                    <StackPanel IsVisible="{Binding IsSplineEditor}" Spacing="8">
                      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                        <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Interpolation" />
                        <ComboBox Grid.Column="1"
                                  Margin="10,0,0,0"
                                  Classes="dialog-field"
                                  ItemsSource="{Binding SplineInterpolationModeOptions}"
                                  SelectedItem="{Binding SelectedSplineInterpolationMode, Mode=TwoWay}" />
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0" Foreground="{Binding SecondaryTextBrush}" Text="Linear keeps straight segments. Catmull-Rom creates a smooth curve through the same support points." TextWrapping="Wrap" />
                      </Grid>

                      <Border Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8">
                        <Grid RowDefinitions="Auto,*">
                          <Grid ColumnDefinitions="*,*,Auto" Margin="0,0,0,6">
                            <TextBlock FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Input" />
                            <TextBlock Grid.Column="1" Margin="8,0,0,0" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Output" />
                            <TextBlock Grid.Column="2" Margin="8,0,0,0" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Action" />
                          </Grid>

                          <ScrollViewer Grid.Row="1" MaxHeight="360" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SplineRows}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Grid ColumnDefinitions="*,*,Auto" Margin="0,0,0,6">
                                    <TextBox Classes="dialog-field"
                                             Foreground="{Binding DataContext.EditorForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                             Text="{Binding InputText, Mode=TwoWay}" />
                                    <TextBox Grid.Column="1"
                                             Margin="8,0,0,0"
                                             Classes="dialog-field"
                                             Foreground="{Binding DataContext.EditorForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                             Text="{Binding OutputText, Mode=TwoWay}" />
                                    <Button Grid.Column="2"
                                            Margin="8,0,0,0"
                                            Classes="dialog-button"
                                            Foreground="{Binding DataContext.ButtonForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Content="Remove"
                                            Click="OnRemoveSplinePointClicked" />
                                  </Grid>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </ScrollViewer>
                        </Grid>
                      </Border>

                      <Button HorizontalAlignment="Left" Classes="dialog-button" Content="Add Point" Click="OnAddSplinePointClicked" />
                    </StackPanel>

                  </StackPanel>
                </Border>

                <TextBlock Foreground="{Binding ErrorBrush}" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
              </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0" Spacing="10">
              <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Classes="section-toggle" Content="{Binding PreviewSectionToggleGlyph}" Click="OnPreviewSectionToggleClicked" />
                <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{Binding SectionHeaderForeground}" Text="Preview" />
              </Grid>

              <Border IsVisible="{Binding IsPreviewSectionExpanded}" Padding="12" Background="{Binding SectionContentBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                  <Border Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid>
                            <Canvas x:Name="PreviewCanvas"
                              Width="{Binding PlotWidth}"
                              Height="{Binding PlotHeight}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              PointerMoved="OnPreviewCanvasPointerMoved"
                              PointerReleased="OnPreviewCanvasPointerReleased"
                              PointerCaptureLost="OnPreviewCanvasPointerCaptureLost">
                        <ItemsControl x:Name="HorizontalGridLinesItemsControl" ItemsSource="{Binding PlotHorizontalGridLines}" IsHitTestVisible="False" Width="{Binding PlotWidth}" Height="{Binding PlotHeight}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <Canvas />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.Styles>
                            <Style Selector="ItemsControl#HorizontalGridLinesItemsControl > ContentPresenter">
                              <Setter Property="Canvas.Left" Value="0" />
                              <Setter Property="Canvas.Top" Value="{Binding Offset}" />
                            </Style>
                          </ItemsControl.Styles>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Width="{Binding DataContext.PlotWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Height="1"
                                      Background="{Binding DataContext.PlotGridBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Opacity="0.5" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl x:Name="VerticalGridLinesItemsControl" ItemsSource="{Binding PlotVerticalGridLines}" IsHitTestVisible="False" Width="{Binding PlotWidth}" Height="{Binding PlotHeight}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <Canvas />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.Styles>
                            <Style Selector="ItemsControl#VerticalGridLinesItemsControl > ContentPresenter">
                              <Setter Property="Canvas.Left" Value="{Binding Offset}" />
                              <Setter Property="Canvas.Top" Value="0" />
                            </Style>
                          </ItemsControl.Styles>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Width="1"
                                      Height="{Binding DataContext.PlotHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Background="{Binding DataContext.PlotGridBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Opacity="0.5" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Width="2" Height="{Binding PlotHeight}" Background="{Binding PlotAxisBrush}" Canvas.Left="{Binding PlotAxisX}" Canvas.Top="0" Opacity="0.95" />
                        <Border Width="{Binding PlotWidth}" Height="2" Background="{Binding PlotAxisBrush}" Canvas.Left="0" Canvas.Top="{Binding PlotAxisY}" Opacity="0.95" />
                        <ItemsControl x:Name="HorizontalMarkerGuidesItemsControl" ItemsSource="{Binding PlotHorizontalMarkerGuides}" IsHitTestVisible="False" Width="{Binding PlotWidth}" Height="{Binding PlotHeight}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <Canvas />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.Styles>
                            <Style Selector="ItemsControl#HorizontalMarkerGuidesItemsControl > ContentPresenter">
                              <Setter Property="Canvas.Left" Value="{Binding Left}" />
                              <Setter Property="Canvas.Top" Value="{Binding Top}" />
                            </Style>
                          </ItemsControl.Styles>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Width="{Binding Width}"
                                      Height="{Binding Height}"
                                      Background="{Binding DataContext.PlotGuideBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Opacity="0.9" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl x:Name="VerticalMarkerGuidesItemsControl" ItemsSource="{Binding PlotVerticalMarkerGuides}" IsHitTestVisible="False" Width="{Binding PlotWidth}" Height="{Binding PlotHeight}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <Canvas />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.Styles>
                            <Style Selector="ItemsControl#VerticalMarkerGuidesItemsControl > ContentPresenter">
                              <Setter Property="Canvas.Left" Value="{Binding Left}" />
                              <Setter Property="Canvas.Top" Value="{Binding Top}" />
                            </Style>
                          </ItemsControl.Styles>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Width="{Binding Width}"
                                      Height="{Binding Height}"
                                      Background="{Binding DataContext.PlotGuideBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Opacity="0.9" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <shapes:Polyline Points="{Binding PlotPoints}" Stroke="{Binding PlotLineBrush}" StrokeThickness="2.5" />
                        <Border IsVisible="{Binding ShowPlotOriginMarker}"
                          Width="14"
                          Height="14"
                          Background="{Binding DataContext.PlotAxisBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                          BorderBrush="{Binding DataContext.EditorBackground, RelativeSource={RelativeSource AncestorType=Window}}"
                          BorderThickness="2"
                          CornerRadius="7"
                          Canvas.Left="{Binding PlotOriginX}"
                          Canvas.Top="{Binding PlotOriginY}" />
                        <ItemsControl x:Name="PlotMarkersItemsControl" ItemsSource="{Binding PlotMarkers}" Width="{Binding PlotWidth}" Height="{Binding PlotHeight}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <Canvas />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.Styles>
                            <Style Selector="ItemsControl#PlotMarkersItemsControl > ContentPresenter">
                              <Setter Property="Canvas.Left" Value="{Binding X}" />
                              <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                          </ItemsControl.Styles>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <StackPanel Spacing="3">
                                <Border Width="14"
                                        Height="14"
                                        Background="{Binding DataContext.PlotMarkerBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                        BorderBrush="{Binding DataContext.PlotAxisBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                        BorderThickness="1.5"
                                        CornerRadius="7"
                                        Cursor="Hand"
                                  PointerPressed="OnPreviewMarkerPointerPressed" />
                                <TextBlock Margin="-10,0,0,0"
                                           FontSize="10"
                                           Foreground="{Binding DataContext.PrimaryTextBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Text="{Binding InputLabel}" />
                              </StackPanel>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl x:Name="XAxisLabelsItemsControl" ItemsSource="{Binding PlotXAxisLabels}" IsHitTestVisible="False" Width="{Binding PlotWidth}" Height="{Binding PlotHeight}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <Canvas />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.Styles>
                            <Style Selector="ItemsControl#XAxisLabelsItemsControl > ContentPresenter">
                              <Setter Property="Canvas.Left" Value="{Binding Left}" />
                              <Setter Property="Canvas.Top" Value="{Binding Top}" />
                            </Style>
                          </ItemsControl.Styles>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Width="{Binding Width}"
                                         Height="{Binding Height}"
                                         FontSize="10"
                                         TextAlignment="{Binding Alignment}"
                                         Foreground="{Binding DataContext.SecondaryTextBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                         Text="{Binding Text}" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl x:Name="YAxisLabelsItemsControl" ItemsSource="{Binding PlotYAxisLabels}" IsHitTestVisible="False" Width="{Binding PlotWidth}" Height="{Binding PlotHeight}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <Canvas />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.Styles>
                            <Style Selector="ItemsControl#YAxisLabelsItemsControl > ContentPresenter">
                              <Setter Property="Canvas.Left" Value="{Binding Left}" />
                              <Setter Property="Canvas.Top" Value="{Binding Top}" />
                            </Style>
                          </ItemsControl.Styles>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Width="{Binding Width}"
                                         Height="{Binding Height}"
                                         FontSize="10"
                                         TextAlignment="{Binding Alignment}"
                                         Foreground="{Binding DataContext.SecondaryTextBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                         Text="{Binding Text}" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Canvas>

                      <TextBlock IsVisible="{Binding IsPreviewEmpty}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 FontSize="15"
                                 Foreground="{Binding SecondaryTextBrush}"
                                 Text="{Binding PreviewEmptyMessage}"
                                 TextWrapping="Wrap" />
                    </Grid>
                  </Border>

                  <TextBlock Foreground="{Binding SecondaryTextBrush}" Text="{Binding PlotSummary}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </TabItem>
      </TabControl>

      <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Classes="dialog-button" Content="Save" Click="OnSaveClicked" />
        <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
      </StackPanel>
    </Grid>
  </Border>
</Window>