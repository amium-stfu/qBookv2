<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:Amium.EditorUi.Converters"
             x:Class="Amium.UiEditor.App"
             RequestedThemeVariant="Default">
  <Application.Resources>
    <converters:BoolToBrushConverter x:Key="BoolToBrushConverter" />
    <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#2563EB" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#1D4ED8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12" />
    </Style>
    <Style Selector="Button.toolbar">
      <Setter Property="MinWidth" Value="120" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#C7CDD8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.toolbar:pointerover">
      <Setter Property="Background" Value="#E5E7EB" />
      <Setter Property="BorderBrush" Value="#C7CDD8" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleButton.toolbar">
      <Setter Property="MinWidth" Value="120" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#C7CDD8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleButton.toolbar:pointerover">
      <Setter Property="Background" Value="#E5E7EB" />
      <Setter Property="BorderBrush" Value="#C7CDD8" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleButton.toolbar:checked">
      <Setter Property="Background" Value="#F59E0B" />
      <Setter Property="BorderBrush" Value="#D97706" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.toolicon">
      <Setter Property="Width" Value="38" />
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="MinWidth" Value="38" />
      <Setter Property="Background" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#C7CDD8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.toolicon:pointerover">
      <Setter Property="Background" Value="#E5E7EB" />
      <Setter Property="BorderBrush" Value="#C7CDD8" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.toolicon:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#E5E7EB" />
    </Style>
    <Style Selector="Button.toolicon:pressed">
      <Setter Property="Background" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#C7CDD8" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleButton.toolicon">
      <Setter Property="Width" Value="38" />
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="MinWidth" Value="38" />
      <Setter Property="Background" Value="#F3F4F6" />
      <Setter Property="BorderBrush" Value="#C7CDD8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleButton.toolicon:pointerover">
      <Setter Property="Background" Value="#E5E7EB" />
      <Setter Property="BorderBrush" Value="#C7CDD8" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleButton.toolicon:checked">
      <Setter Property="Background" Value="#F59E0B" />
      <Setter Property="BorderBrush" Value="#D97706" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.headericon">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.headericon:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="0.8" />
    </Style>
    <Style Selector="Button.headericon:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="0.65" />
    </Style>
    <Style Selector="Button.legendedit">
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.legendedit:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.legendedit:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.legendedit /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.legendedit:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.legendedit:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleButton.headericon">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleButton.headericon:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="0.8" />
    </Style>
    <Style Selector="ToggleButton.headericon:checked">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="TextElement.Foreground" Value="#111827" />
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="TextElement.Foreground" Value="#111827" />
    </Style>
    <Style Selector="ToggleButton:pointerover /template/ ContentPresenter">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="TextElement.Foreground" Value="#111827" />
    </Style>
    <Style Selector="ToggleButton:pressed /template/ ContentPresenter">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="TextElement.Foreground" Value="#111827" />
    </Style>
    <Style Selector="TextBox.listheight">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox.listheight:focus">
      <Setter Property="BorderBrush" Value="#60A5FA" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#111827" />
    </Style>
  </Application.Styles>
</Application>
