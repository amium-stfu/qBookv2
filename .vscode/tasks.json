{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "restore-automationexplorer",
      "type": "process",
      "command": "dotnet",
      "args": ["restore", "${workspaceFolder}/AutomationExplorer/AutomationExplorer.csproj"],
      "problemMatcher": []
    },
    {
      "label": "build-automationexplorer-debug",
      "type": "process",
      "command": "dotnet",
      "args": ["build", "${workspaceFolder}/AutomationExplorer/AutomationExplorer.csproj", "-c", "Debug"],
      "problemMatcher": "$msCompile",
      "dependsOn": ["restore-automationexplorer"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "run-automationexplorer",
      "type": "process",
      "command": "dotnet",
      "args": ["run", "--project", "${workspaceFolder}/AutomationExplorer/AutomationExplorer.csproj", "-c", "Debug"],
      "problemMatcher": []
    }
  ]
}
