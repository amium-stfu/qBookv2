<Window
    x:Class="Amium.UiEditor.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Amium.UiEditor.Widgets;assembly=Amium.Editor"
    xmlns:models="clr-namespace:Amium.UiEditor.Models;assembly=Amium.Editor"
    xmlns:viewModels="clr-namespace:Amium.UiEditor.ViewModels;assembly=AmiumStudio"
    xmlns:editorUi="clr-namespace:Amium.EditorUi.Controls;assembly=Amium.Editor"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:CompileBindings="False"
    x:DataType="viewModels:AmiumStudioMainWindowViewModel"
    Width="1280"
    Height="820"
    MinWidth="1024"
    MinHeight="720"
    Background="{Binding WindowBackground}"
    Title="AmiumStudio">
  <Grid RowDefinitions="Auto,*,Auto" Margin="8">
    <Grid Grid.Row="0">
      <Border Classes="card" Padding="12,6" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" IsVisible="{Binding IsHeaderCollapsed, Converter={StaticResource BoolNegationConverter}, FallbackValue=True, TargetNullValue=True}">
        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,8,0">
            <Button Classes="headericon" Background="Transparent" BorderBrush="Transparent" ToolTip.Tip="User level">
              <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <editorUi:ThemeSvgIcon Width="22" Height="22" IconPath="avares://Amium.Editor/EditorIcons/user.svg" TintColor="{Binding CurrentUserColor}" />
                <TextBlock Width="120" FontSize="14" FontWeight="SemiBold" Foreground="{Binding CurrentUserColor}" Text="{Binding CurrentUserCaption}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="headericon" Command="{Binding ToggleHeaderCollapsedCommand}" ToolTip.Tip="Kopfbereich einklappen">
              <TextBlock FontSize="16" FontWeight="Bold" Foreground="{Binding PrimaryTextBrush}" Text="^" />
            </Button>
            <TextBlock FontSize="24" FontWeight="Bold" Foreground="{Binding PrimaryTextBrush}" Text="AmiumStudio" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Margin="8,0,0,0">
            <Button Classes="headericon" Background="Transparent" BorderBrush="Transparent" Click="LoadBook_Click" ToolTip.Tip="Load">
              <editorUi:ThemeSvgIcon Width="24" Height="24" IconPath="avares://Amium.Editor/EditorIcons/openBook.svg" TintColor="{Binding PrimaryTextBrush}" />
            </Button>

            <ToggleButton Classes="headericon" Background="Transparent" BorderBrush="Transparent" IsChecked="{Binding IsDarkTheme}" ToolTip.Tip="Theme Switch">
              <editorUi:ThemeSvgIcon Width="24" Height="24" IconPath="avares://Amium.Editor/EditorIcons/theme.svg" TintColor="{Binding PrimaryTextBrush}" />
            </ToggleButton>

            <Button Classes="headericon" Background="Transparent" BorderBrush="Transparent" Click="OpenVsCode_Click" ToolTip.Tip="Open VS Code">
              <editorUi:ThemeSvgIcon Width="26" Height="26" IconPath="avares://Amium.Editor/EditorIcons/csharp.svg" TintColor="{Binding PrimaryTextBrush}" />
            </Button>

            <Button Classes="headericon" Background="Transparent" BorderBrush="Transparent" Click="OpenLogWindow_Click" ToolTip.Tip="Open Log">
              <editorUi:ThemeSvgIcon Width="22" Height="22" IconPath="avares://Amium.Editor/EditorIcons/log.svg" TintColor="{Binding PrimaryTextBrush}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <Border Classes="card" Padding="0,2" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}" IsVisible="{Binding IsHeaderCollapsed}">
        <Button Classes="headericon" HorizontalAlignment="Center" Background="Transparent" BorderBrush="Transparent" Command="{Binding ToggleHeaderCollapsedCommand}" ToolTip.Tip="Kopfbereich ausklappen">
          <TextBlock FontSize="16" FontWeight="Bold" Foreground="{Binding PrimaryTextBrush}" Text="v" />
        </Button>
      </Border>
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="*" Margin="0,8,0,8">
      <Border Grid.Column="0" Classes="card" Padding="0" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}">
        <Grid Margin="8,6,0,6" RowDefinitions="Auto,*">
          <Border Grid.Row="0" IsVisible="{Binding IsTopTabStripPlacement}" Background="Transparent">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding Pages}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="Auto,Auto">
                      <Button Grid.Column="0"
                              Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0"
                              Margin="0">
                        <Button.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Top" Click="OnTabPlacementTopClicked" />
                            <MenuItem Header="Right" Click="OnTabPlacementRightClicked" />
                          </ContextMenu>
                        </Button.ContextMenu>
                        <Grid ColumnDefinitions="48,200">
                          <Border Grid.ColumnSpan="2" Background="{Binding DataContext.TabBackColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" />
                          <Border Grid.ColumnSpan="2" Background="{Binding DataContext.TabSelectBackColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" />
                          <Border Grid.Column="0" Background="{Binding DataContext.TabNumerBackColor, RelativeSource={RelativeSource AncestorType=Window}}" MinHeight="52" IsVisible="{Binding IsNotSelected}" />
                          <Border Grid.Column="0" Background="{Binding DataContext.TabSelectNumerBackColor, RelativeSource={RelativeSource AncestorType=Window}}" MinHeight="52" IsVisible="{Binding IsSelected}" />
                          <TextBlock Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" Text="{Binding Index}" />
                          <TextBlock Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" Text="{Binding Index}" />
                          <TextBlock Grid.Column="1" Margin="12,6" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" Text="{Binding TabTitle}" />
                          <TextBlock Grid.Column="1" Margin="12,6" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" Text="{Binding TabTitle}" />
                        </Grid>
                      </Button>
                      <Button Grid.Column="1"
                              Classes="headericon"
                              Width="68"
                              Height="34"
                              MinWidth="68"
                              Margin="0,0,8,0"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              Command="{Binding DataContext.ToggleEditModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              IsVisible="{Binding IsSelected}"
                              ToolTip.Tip="Edit mode umschalten">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                          <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" Text="Edit" />
                          <editorUi:ThemeSvgIcon Width="14" Height="14" IconPath="avares://Amium.Editor/EditorIcons/pencil.svg" TintColor="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </StackPanel>
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>

          <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
            <controls:CachedPageHostControl DataContext="{Binding}" />

            <Border Grid.Column="1" IsVisible="{Binding IsRightTabStripPlacement}" Background="Transparent">
              <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Pages}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                      <DataTemplate>
                      <Grid ColumnDefinitions="Auto,Auto">
                        <Button Grid.Column="0"
                                Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Margin="0">
                          <Button.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="Top" Click="OnTabPlacementTopClicked" />
                              <MenuItem Header="Right" Click="OnTabPlacementRightClicked" />
                            </ContextMenu>
                          </Button.ContextMenu>
                          <Grid ColumnDefinitions="48,200">
                            <Border Grid.ColumnSpan="2" Background="{Binding DataContext.TabBackColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" />
                            <Border Grid.ColumnSpan="2" Background="{Binding DataContext.TabSelectBackColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" />
                            <Border Grid.Column="0" Background="{Binding DataContext.TabNumerBackColor, RelativeSource={RelativeSource AncestorType=Window}}" MinHeight="52" IsVisible="{Binding IsNotSelected}" />
                            <Border Grid.Column="0" Background="{Binding DataContext.TabSelectNumerBackColor, RelativeSource={RelativeSource AncestorType=Window}}" MinHeight="52" IsVisible="{Binding IsSelected}" />
                            <TextBlock Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" Text="{Binding Index}" />
                            <TextBlock Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" Text="{Binding Index}" />
                            <TextBlock Grid.Column="1" Margin="12,6" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" Text="{Binding TabTitle}" />
                            <TextBlock Grid.Column="1" Margin="12,6" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" Text="{Binding TabTitle}" />
                          </Grid>
                        </Button>
                        <Button Grid.Column="1"
                                Classes="headericon"
                                Width="68"
                                Height="34"
                                MinWidth="68"
                                Margin="0,0,8,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Command="{Binding DataContext.ToggleEditModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                IsVisible="{Binding IsSelected}"
                                ToolTip.Tip="Edit mode umschalten">
                          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" Text="Edit" />
                            <editorUi:ThemeSvgIcon Width="14" Height="14" IconPath="avares://Amium.Editor/EditorIcons/pencil.svg" TintColor="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" />
                          </StackPanel>
                        </Button>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Classes="card" Padding="16,10" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBlock VerticalAlignment="Center" Foreground="{Binding SecondaryTextBrush}" Text="{Binding FooterText}" />
          <TextBlock VerticalAlignment="Center" Foreground="{Binding SecondaryTextBrush}" Text="{Binding StatusText}" />
        </StackPanel>
        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Footer" />
      </Grid>
    </Border>
  </Grid>
</Window>