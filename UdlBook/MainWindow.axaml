<Window
    x:Class="UdlBook.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Widgets"
    xmlns:models="using:Amium.UiEditor.Models"
    xmlns:viewModels="using:UdlBook.ViewModels"
    xmlns:editorUi="using:Amium.EditorUi.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:CompileBindings="False"
    x:DataType="viewModels:MainWindowViewModel"
    Width="1280"
    Height="820"
    MinWidth="1024"
    MinHeight="720"
    Background="{Binding WindowBackground}"
    Title="UdlBook">
  <Grid RowDefinitions="Auto,*,Auto" Margin="8">
    <Grid Grid.Row="0">
      <Border Classes="card" Padding="12,6" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}">
        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
          <!-- Linke Seite: MainMenu + Demo-Buttons -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0" Spacing="4">
            <Button x:Name="MainMenuButton"
                    Classes="headericon"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="OnMainMenuButtonClick"
                    ToolTip.Tip="Main menu">
              <editorUi:ThemeSvgIcon Width="24" Height="24" IconPath="avares://Amium.Editor/EditorIcons/menu.svg" TintColor="{Binding PrimaryTextBrush}" />
              <Button.ContextMenu>
                <ContextMenu>
                  <!-- Gruppe 1: User -->
                  <MenuItem Header="Login" Click="UserLogin_Click" IsVisible="{Binding !IsLogoutAvailable}"/>
                  <MenuItem Header="Logout" Click="Logout_Click" IsVisible="{Binding IsLogoutAvailable}" />
                  <MenuItem Header="Change password" Click="ChangePassword_Click" IsVisible="{Binding IsChangePasswordAvailable}" />
                  <MenuItem Header="Reset passwords" Click="ResetPasswords_Click" IsVisible="{Binding IsResetPasswordsAvailable}" />
                  <Separator />

                  <!-- Gruppe 2: Layout / Dateiaktionen -->
                  <MenuItem Header="New Book" Click="NewBook_Click" />
                  <MenuItem Header="Load Book" Click="LoadBook_Click" />
                  <MenuItem Header="Save Book" Click="SaveLayout_Click" IsVisible="{Binding CanSaveLayout}" />
                  <MenuItem Header="Save Book As" Click="SaveLayoutAs_Click" IsVisible="{Binding HasLayout}" />
                  <MenuItem Header="Set as start Book" Click="SetStartLayout_Click" IsVisible="{Binding HasLayout}" />
                  <Separator />

                  <!-- Gruppe 3: Theme, Log -->
                  <MenuItem Header="Theme switch" Click="ToggleTheme_Click" />
                  <MenuItem Header="Open log" Click="OpenLogWindow_Click" />
                  <Separator />

                  <!-- Gruppe 4: Edit (Platzhalter) -->
                  <MenuItem Header="Edit (coming soon)" IsEnabled="False" />
                </ContextMenu>
              </Button.ContextMenu>
            </Button>

                    <!-- Demo buttons for global input dialogs -->
                    <Button Content="TextInput"
                      Margin="8,0,0,0"
                      Padding="8,4"
                      Click="OnDemoTextInputClicked" />
                    <Button Content="HexInput"
                      Margin="4,0,0,0"
                      Padding="8,4"
                      Click="OnDemoHexInputClicked" />
                    <Button Content="NumInt(0)"
                      Margin="4,0,0,0"
                      Padding="8,4"
                      Click="OnDemoNumericIntClicked" />
                    <Button Content="NumDbl(0.00)"
                      Margin="4,0,0,0"
                      Padding="8,4"
                      Click="OnDemoNumericDoubleClicked" />
                    <Button Content="TextPwd"
                      Margin="12,0,0,0"
                      Padding="8,4"
                      Click="OnDemoPasswordTextClicked" />
                    <Button Content="NumPwd"
                      Margin="4,0,0,0"
                      Padding="8,4"
                      Click="OnDemoNumericPasswordClicked" />
          </StackPanel>

          <!-- Mitte: Dateiname / Bookname -->
          <TextBlock Grid.Column="1"
                     FontSize="24"
                     FontWeight="Bold"
                     Foreground="{Binding PrimaryTextBrush}"
                     Text="{Binding HeaderTitle}"
                     HorizontalAlignment="Stretch"
                     TextAlignment="Center"
                     VerticalAlignment="Center" />

          <!-- Rechts: amium Logo -->
          <editorUi:ThemeSvgIcon Grid.Column="2"
                                 Width="110"
                                 Height="24"
                                 IconPath="avares://Amium.Editor/EditorIcons/amium.svg"
                                 TintColor="{Binding PrimaryTextBrush}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Right" />
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="*" Margin="0,8,0,8">
      <Border Grid.Column="0" Classes="card" Padding="0" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}">
        <Grid Margin="8,6,0,6" RowDefinitions="Auto,*">
          <Border Grid.Row="0" IsVisible="{Binding IsTopTabStripPlacement}" Background="Transparent">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding Pages}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="models:PageModel">
                    <Grid ColumnDefinitions="Auto,Auto">
                      <Button Grid.Column="0"
                              Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0"
                              Margin="0">
                        <Button.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Top" Click="OnTabPlacementTopClicked" />
                            <MenuItem Header="Right" Click="OnTabPlacementRightClicked" />
                          </ContextMenu>
                        </Button.ContextMenu>
                        <Grid ColumnDefinitions="48,200">
                          <Border Grid.ColumnSpan="2" Background="{Binding DataContext.TabBackColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" />
                          <Border Grid.ColumnSpan="2" Background="{Binding DataContext.TabSelectBackColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" />
                          <Border Grid.Column="0" Background="{Binding DataContext.TabNumerBackColor, RelativeSource={RelativeSource AncestorType=Window}}" MinHeight="52" IsVisible="{Binding IsNotSelected}" />
                          <Border Grid.Column="0" Background="{Binding DataContext.TabSelectNumerBackColor, RelativeSource={RelativeSource AncestorType=Window}}" MinHeight="52" IsVisible="{Binding IsSelected}" />
                          <TextBlock Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" Text="{Binding Index}" />
                          <TextBlock Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" Text="{Binding Index}" />
                          <TextBlock Grid.Column="1" Margin="12,6" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" Text="{Binding TabTitle}" />
                          <TextBlock Grid.Column="1" Margin="12,6" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" Text="{Binding TabTitle}" />
                        </Grid>
                      </Button>
                      <Button Grid.Column="1"
                              Classes="legendedit"
                              Width="52"
                              MinWidth="52"
                              Margin="0,0,8,0"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Background="{Binding DataContext.TabSelectBackColor, RelativeSource={RelativeSource AncestorType=Window}}"
                              BorderBrush="{Binding DataContext.TabSelectBackColor, RelativeSource={RelativeSource AncestorType=Window}}"
                              Command="{Binding DataContext.ToggleEditModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              IsVisible="{Binding IsSelected}"
                              ToolTip.Tip="Edit mode umschalten">
                        <editorUi:ThemeSvgIcon Width="20" Height="20" IconPath="avares://Amium.Editor/EditorIcons/pencil.svg" TintColor="{Binding DataContext.LegendEditIconColor, RelativeSource={RelativeSource AncestorType=Window}}" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>

          <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
            <controls:CachedPageHostControl DataContext="{Binding}" />

            <Border Grid.Column="1" IsVisible="{Binding IsRightTabStripPlacement}" Background="Transparent">
              <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Pages}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:PageModel">
                      <Grid ColumnDefinitions="Auto,Auto">
                        <Button Grid.Column="0"
                                Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Margin="0">
                          <Button.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="Top" Click="OnTabPlacementTopClicked" />
                              <MenuItem Header="Right" Click="OnTabPlacementRightClicked" />
                            </ContextMenu>
                          </Button.ContextMenu>
                          <Grid ColumnDefinitions="48,200">
                            <Border Grid.ColumnSpan="2" Background="{Binding DataContext.TabBackColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" />
                            <Border Grid.ColumnSpan="2" Background="{Binding DataContext.TabSelectBackColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" />
                            <Border Grid.Column="0" Background="{Binding DataContext.TabNumerBackColor, RelativeSource={RelativeSource AncestorType=Window}}" MinHeight="52" IsVisible="{Binding IsNotSelected}" />
                            <Border Grid.Column="0" Background="{Binding DataContext.TabSelectNumerBackColor, RelativeSource={RelativeSource AncestorType=Window}}" MinHeight="52" IsVisible="{Binding IsSelected}" />
                            <TextBlock Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" Text="{Binding Index}" />
                            <TextBlock Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" Text="{Binding Index}" />
                            <TextBlock Grid.Column="1" Margin="12,6" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding DataContext.TabForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsNotSelected}" Text="{Binding TabTitle}" />
                            <TextBlock Grid.Column="1" Margin="12,6" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding DataContext.TabSelectForeColor, RelativeSource={RelativeSource AncestorType=Window}}" IsVisible="{Binding IsSelected}" Text="{Binding TabTitle}" />
                          </Grid>
                        </Button>
                        <Button Grid.Column="1"
                                Classes="legendedit"
                                Width="52"
                                MinWidth="52"
                                Margin="0,0,8,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="{Binding DataContext.TabSelectBackColor, RelativeSource={RelativeSource AncestorType=Window}}"
                                BorderBrush="{Binding DataContext.TabSelectBackColor, RelativeSource={RelativeSource AncestorType=Window}}"
                                Command="{Binding DataContext.ToggleEditModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                IsVisible="{Binding IsSelected}"
                                ToolTip.Tip="Edit mode umschalten">
                          <editorUi:ThemeSvgIcon Width="20" Height="20" IconPath="avares://Amium.Editor/EditorIcons/pencil.svg" TintColor="{Binding DataContext.LegendEditIconColor, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </Button>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Classes="card" Padding="16,10" Background="{Binding CardBackground}" BorderBrush="{Binding CardBorderBrush}">
      <Grid>
        <TextBlock VerticalAlignment="Center" Foreground="{Binding SecondaryTextBrush}" Text="{Binding LoadedBookSummary}" />
      </Grid>
    </Border>
  </Grid>
</Window>