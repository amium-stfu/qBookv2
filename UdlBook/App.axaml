<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UdlBook.App"
             RequestedThemeVariant="Default">
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Button.headericon">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.headericon:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="0.8" />
    </Style>

    <Style Selector="Button.headericon:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="0.65" />
    </Style>

    <Style Selector="ToggleButton.headericon">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="ToggleButton.headericon:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="0.8" />
    </Style>

    <Style Selector="ToggleButton.headericon:checked">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
  </Application.Styles>
</Application>