<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:Amium.EditorUi.Converters"
             xmlns:local="using:UdlBook"
             x:Class="UdlBook.App"
             RequestedThemeVariant="Default">
  <Application.Resources>
    <converters:BoolToBrushConverter x:Key="BoolToBrushConverter" />
    <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <Style Selector="Button.headericon">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.headericon:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="0.8" />
    </Style>

    <Style Selector="Button.headericon:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="0.65" />
    </Style>

    <Style Selector="ToggleButton.headericon">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.legendedit">
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Height" Value="52" />
      <Setter Property="MinHeight" Value="52" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="ToggleButton.headericon:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="0.8" />
    </Style>

    <Style Selector="ToggleButton.headericon:checked">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Opacity" Value="1" />
    </Style>
  </Application.Styles>
</Application>