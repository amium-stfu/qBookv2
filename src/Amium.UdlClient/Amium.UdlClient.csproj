  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\HornetStudio.Contracts\HornetStudio.Contracts.csproj" />
    <ProjectReference Include="..\Amium.Item\Amium.Item.csproj" />
  </ItemGroup>
</Project>
