<Window
    x:Class="HornetStudio.ItemTreeWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:HornetStudio.ViewModels"
    Width="760"
    Height="860"
    MinWidth="560"
    MinHeight="420"
    Title="{Binding WindowTitle}"
    Background="{Binding WindowBackground}"
    Foreground="{Binding PrimaryTextBrush}"
    ShowInTaskbar="True">
  <Window.Styles>
    <Style Selector="TreeView.item-tree">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" />
    </Style>
    <Style Selector="TreeView.item-tree TreeViewItem">
      <Setter Property="Foreground" Value="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,1,0,1" />
    </Style>
    <Style Selector="TreeView.item-tree TreeViewItem:selected">
      <Setter Property="Foreground" Value="{Binding DataContext.TabSelectForeColor, ElementName=Root}" />
      <Setter Property="Background" Value="{Binding DataContext.TabSelectBackColor, ElementName=Root}" />
    </Style>
    <Style Selector="TreeView.item-tree ToggleButton">
      <Setter Property="Foreground" Value="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
  </Window.Styles>
  <Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto">
    <Border Padding="12"
            Background="{Binding CardBackground}"
            BorderBrush="{Binding CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
      <StackPanel Spacing="4">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{Binding PrimaryTextBrush}"
                   Text="{Binding WindowTitle}" />
        <TextBlock FontSize="12"
                   Foreground="{Binding SecondaryTextBrush}"
                   Text="{Binding ScopeDescription}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Margin="0,10,0,10"
            Padding="10"
            Background="{Binding CardBackground}"
            BorderBrush="{Binding CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
      <StackPanel Spacing="4">
        <TextBlock FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="Scope" />
        <TextBlock FontSize="12" Foreground="{Binding PrimaryTextBrush}" Text="{Binding ScopePath}" TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Border Grid.Row="2"
            Background="{Binding CardBackground}"
            BorderBrush="{Binding CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="10">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="3*,2*" Margin="0,0,14,8">
          <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Path" />
          <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Value" />
        </Grid>
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
          <TreeView Classes="item-tree"
                    ItemsSource="{Binding RootNodes}"
                    SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
            <TreeView.ItemTemplate>
              <TreeDataTemplate DataType="viewModels:ItemTreeNodeViewModel" ItemsSource="{Binding Children}">
                <Grid ColumnDefinitions="3*,2*" Margin="0,1,0,1">
                  <TextBlock Grid.Column="0"
                             Foreground="{Binding DataContext.PrimaryTextBrush, ElementName=Root}"
                             Text="{Binding DisplayName}"
                             TextWrapping="NoWrap"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Margin="12,0,0,0"
                             Text="{Binding ValueText}"
                             Foreground="{Binding DataContext.SecondaryTextBrush, ElementName=Root}"
                             TextWrapping="Wrap"
                             VerticalAlignment="Center" />
                </Grid>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="3"
            Margin="0,10,0,0"
            Padding="10"
            Background="{Binding CardBackground}"
            BorderBrush="{Binding CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
      <StackPanel Spacing="4">
        <TextBlock FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="Selection" />
        <TextBlock FontSize="12" Foreground="{Binding PrimaryTextBrush}" Text="{Binding SelectionPath}" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </Grid>
</Window>

