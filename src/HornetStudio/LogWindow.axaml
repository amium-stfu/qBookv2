<Window
    x:Name="Root"
  x:Class="HornetStudio.LogWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Widgets"
    Background="{Binding WindowBackground}"
    Foreground="{Binding PrimaryTextBrush}"
    Width="900"
    Height="620"
    MinWidth="700"
    MinHeight="420"
    Title="Host Log">
  <Grid Margin="12">
    <controls:EditorLogControl
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
      DataContext="{Binding HostLogItem, ElementName=Root}" />
  </Grid>
</Window>