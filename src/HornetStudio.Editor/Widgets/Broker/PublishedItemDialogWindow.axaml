<Window
    x:Class="HornetStudio.Editor.Widgets.PublishedItemDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Controls"
    xmlns:viewModels="using:HornetStudio.Editor.Widgets"
    Width="980"
    MinWidth="880"
    Height="640"
    MinHeight="560"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="{Binding TitleText}"
    Background="{Binding DialogBackground}">
  <Window.Styles>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding ButtonBackground}" />
      <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeground}" />
    </Style>
  </Window.Styles>

  <controls:EditorShellControl Margin="16"
                               ShellBackground="{Binding DialogBackground}"
                               ShellBorderBrush="{Binding BorderColor}"
                               ShellBorderThickness="1"
                               ShellCornerRadius="10"
                               ShellPadding="16"
                               ShowHeader="True"
                               ShowFooter="True">
    <controls:EditorShellControl.HeaderContent>
      <StackPanel>
        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="{Binding TitleText}" />
        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="{Binding DescriptionText}" TextWrapping="Wrap" />
      </StackPanel>
    </controls:EditorShellControl.HeaderContent>

    <controls:EditorShellControl.BodyContent>
      <Grid ColumnDefinitions="360,*">
        <Border Grid.Column="0"
                Margin="0,0,12,0"
                Background="{Binding SectionBackground}"
                BorderBrush="{Binding BorderColor}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
          <Grid RowDefinitions="Auto,*">
            <TextBlock FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="{Binding RootPath}" TextWrapping="Wrap" />
            <ListBox Grid.Row="1"
                     Margin="0,10,0,0"
                     ItemsSource="{Binding Rows}"
                     SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                     Background="{Binding EditorBackground}"
                     BorderBrush="{Binding BorderColor}">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="viewModels:PublishedItemEditorRow">
                  <Border Padding="8" Margin="0,0,0,6" CornerRadius="6" Background="Transparent">
                    <Grid ColumnDefinitions="Auto,*">
                      <CheckBox VerticalAlignment="Top" IsChecked="{Binding Active, Mode=TwoWay}" />
                      <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="2">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" Text="{Binding DisplayName}" TextWrapping="Wrap" />
                        <TextBlock FontSize="11" Foreground="{Binding DataContext.SecondaryTextBrush, ElementName=Root}" Text="{Binding Summary}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="{Binding SectionBackground}"
                BorderBrush="{Binding BorderColor}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
          <Grid>
            <TextBlock IsVisible="{Binding ShowEmptyState}"
                       Foreground="{Binding SecondaryTextBrush}"
                       Text="No local registry item is available."
                       TextWrapping="Wrap" />

            <ScrollViewer IsVisible="{Binding HasSelectedRow}" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                  <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Active" />
                  <CheckBox Grid.Column="1" Margin="10,0,0,0" IsChecked="{Binding SelectedRow.Active, Mode=TwoWay}" VerticalAlignment="Center" />

                  <TextBlock Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="BrokerPath" />
                  <TextBox Grid.Row="1" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.BrokerPath}" />

                  <TextBlock Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="PublishMode" />
                  <ComboBox Grid.Row="2" Grid.Column="1" Margin="10,8,0,0" ItemsSource="{Binding PublishModeOptions}" SelectedItem="{Binding SelectedRow.PublishMode, Mode=TwoWay}" />

                  <TextBlock Grid.Row="3" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="PublishIntervalMs" />
                  <TextBox Grid.Row="3" Grid.Column="1" Margin="10,8,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.PublishIntervalMsText, Mode=TwoWay}" />

                  <TextBlock Grid.Row="4" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Writable" />
                  <CheckBox Grid.Row="4" Grid.Column="1" Margin="10,8,0,0" IsChecked="{Binding SelectedRow.Writable, Mode=TwoWay}" VerticalAlignment="Center" />
                </Grid>

                <TextBlock FontSize="12" Foreground="#B42318" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </controls:EditorShellControl.BodyContent>

    <controls:EditorShellControl.FooterContent>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Classes="dialog-button" Content="Save" Click="OnSaveClicked" />
        <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
      </StackPanel>
    </controls:EditorShellControl.FooterContent>
  </controls:EditorShellControl>
</Window>
