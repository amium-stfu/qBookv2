<editorUi:EditorTemplateControl
    x:Class="HornetStudio.Editor.Widgets.MonitorControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Widgets"
    xmlns:editorUi="using:HornetStudio.Editor.Controls">
  <controls:MonitorControl.HeaderActionsContent>
    <Button Padding="6,2"
            Classes="toolbar"
            Click="OnAddRuleClicked">
      <TextBlock FontSize="11" FontWeight="SemiBold" Text="Add" />
    </Button>
  </controls:MonitorControl.HeaderActionsContent>

  <controls:MonitorControl.BodyContent>
    <Border Padding="10,8"
            Background="{Binding EffectiveBodyBackgroundBrush}"
            BorderBrush="{Binding EffectiveBodyBorderBrush}"
            BorderThickness="{Binding EffectiveBodyBorderThickness}"
            CornerRadius="10">
      <Grid RowDefinitions="*,Auto">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding DisplayRules, RelativeSource={RelativeSource AncestorType=controls:MonitorControl}}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,6"
                        Padding="6,4"
                        CornerRadius="6"
                        Background="{Binding RowBackground}"
                        BorderBrush="{Binding RowBorderBrush}"
                        BorderThickness="1"
                        ToolTip.Tip="{Binding RowTooltip}">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0"
                             Margin="0,0,8,0"
                               MinWidth="40"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{Binding SecondaryForeground}"
                               Text="{Binding EventIdText}"
                               TextWrapping="NoWrap" />

                    <TextBlock Grid.Column="1"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{Binding PrimaryForeground}"
                               Text="{Binding EventDisplayText}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />

                    <Button Grid.Column="2"
                            Width="26"
                            Height="26"
                            MinWidth="26"
                            MinHeight="26"
                            Padding="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Click="OnRuleActionsClicked"
                            Tag="{Binding .}"
                            ToolTip.Tip="{Binding ActionTooltip}">
                      <editorUi:ThemeSvgIcon Width="12"
                                             Height="12"
                                             IconPath="avares://HornetStudio.Editor/EditorIcons/cog.svg"
                                             TintColor="{Binding PrimaryForeground}" />
                      <Button.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="Edit" Click="OnEditRuleClicked" CommandParameter="{Binding}" />
                          <MenuItem Header="Delete" Click="OnDeleteRuleClicked" CommandParameter="{Binding}" />
                        </ContextMenu>
                      </Button.ContextMenu>
                    </Button>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="1"
                   FontSize="11"
                   Foreground="{Binding EffectiveMutedForegroundBrush}"
                   Text="No monitor rules configured. Add timeout, threshold, or expression-based rules here."
                   IsVisible="{Binding HasNoRules, RelativeSource={RelativeSource AncestorType=controls:MonitorControl}}" />
      </Grid>
    </Border>
  </controls:MonitorControl.BodyContent>

  <controls:MonitorControl.FooterContent>
    <Border Padding="8,4">
      <TextBlock FontSize="11"
                 Foreground="{Binding EffectiveFooterForegroundBrush}"
                 Text="{Binding Footer}"
                 TextWrapping="Wrap" />
    </Border>
  </controls:MonitorControl.FooterContent>
</editorUi:EditorTemplateControl>
