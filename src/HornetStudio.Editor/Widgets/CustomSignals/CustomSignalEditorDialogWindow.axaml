<Window
    x:Class="HornetStudio.Editor.Widgets.CustomSignalEditorDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Controls"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
    xmlns:widgets="using:HornetStudio.Editor.Widgets"
    Width="820"
    MinWidth="760"
    Height="760"
    MinHeight="680"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="Custom Signal"
    Background="{Binding DialogBackground}">
  <Window.Styles>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding ButtonBackground}" />
      <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeground}" />
    </Style>

    <Style Selector="Button.token-button">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="34" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
  </Window.Styles>

  <controls:EditorShellControl Margin="16"
                               ShellBackground="{Binding DialogBackground}"
                               ShellBorderBrush="{Binding BorderColor}"
                               ShellBorderThickness="1"
                               ShellCornerRadius="10"
                               ShellPadding="16"
                               ShowHeader="True"
                               ShowFooter="True">
    <controls:EditorShellControl.HeaderContent>
      <StackPanel>
        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Custom Signal" />
        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="Configure an input or computed project signal with simple formulas and variable pickers." TextWrapping="Wrap" />
      </StackPanel>
    </controls:EditorShellControl.HeaderContent>

    <controls:EditorShellControl.BodyContent>
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">
          <Border Padding="12"
                  Background="{Binding SectionBackground}"
                  BorderBrush="{Binding BorderColor}"
                  BorderThickness="1"
                  CornerRadius="8">
            <Grid ColumnDefinitions="160,*,Auto"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Name" />
              <TextBox Grid.Column="1" Grid.ColumnSpan="2" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding Name, Mode=TwoWay}" />

               <TextBlock Grid.Row="1" Margin="0,5,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Mode" />
              <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,5,0,0" Foreground="{Binding PrimaryTextBrush}" ItemsSource="{Binding ModeOptions}" SelectedItem="{Binding SelectedMode, Mode=TwoWay}" />

               <TextBlock Grid.Row="2" Margin="0,5,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Type" />
               <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,5,0,0" Foreground="{Binding PrimaryTextBrush}" ItemsSource="{Binding AvailableDataTypeOptions}" SelectedItem="{Binding SelectedDataType, Mode=TwoWay}" />

               <TextBlock Grid.Row="3" Margin="0,5,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Readonly" IsVisible="{Binding IsWritableVisible}" />
               <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,5,0,0" Foreground="{Binding PrimaryTextBrush}" ItemsSource="{Binding ReadOnlyValueOptions}" SelectedItem="{Binding SelectedReadOnlyValue, Mode=TwoWay}" IsVisible="{Binding IsWritableVisible}" />

               <TextBlock Grid.Row="4" Margin="0,5,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Write Mode" IsVisible="{Binding IsWriteConfigurationVisible}" />
               <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,5,0,0" Foreground="{Binding PrimaryTextBrush}" ItemsSource="{Binding WriteModeOptions}" SelectedItem="{Binding SelectedWriteMode, Mode=TwoWay}" IsVisible="{Binding IsWriteConfigurationVisible}" />

               <TextBlock Grid.Row="5" Margin="0,5,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Write Target" IsVisible="{Binding IsWriteConfigurationVisible}" />
               <TextBox Grid.Row="5" Grid.Column="1" Margin="0,5,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding WritePath, Mode=TwoWay}" IsVisible="{Binding IsWriteConfigurationVisible}" />
               <Button Grid.Row="5" Grid.Column="2" Margin="8,5,0,0" Classes="dialog-button" Content="Pick" Click="OnPickWriteTargetClicked" IsVisible="{Binding IsWriteConfigurationVisible}" />

               <TextBlock Grid.Row="6" Margin="0,5,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Unit" />
               <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,5,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding Unit, Mode=TwoWay}" />

               <TextBlock Grid.Row="7" Margin="0,5,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Format" />
               <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,5,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding Format, Mode=TwoWay}" />

               <TextBlock Grid.Row="8" Margin="0,5,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Value" IsVisible="{Binding IsValueVisible}" />
               <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,5,0,0" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding ValueText, Mode=TwoWay}" IsVisible="{Binding IsValueVisible}" />
            </Grid>
          </Border>

          <Border Padding="12"
                  Background="{Binding SectionBackground}"
                  BorderBrush="{Binding BorderColor}"
                  BorderThickness="1"
                  CornerRadius="8"
                  IsVisible="{Binding IsTriggerVisible}">
            <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto">
              <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Trigger" />
              <ComboBox Grid.Column="1" ItemsSource="{Binding TriggerOptions}" SelectedItem="{Binding SelectedTrigger, Mode=TwoWay}" />

              <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Interval (s)" IsVisible="{Binding IsTimerTrigger}" />
              <TextBox Grid.Row="1" Grid.Column="1" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding TriggerIntervalText, Mode=TwoWay}" IsVisible="{Binding IsTimerTrigger}" />
            </Grid>
          </Border>

          <Border Padding="12"
                  Background="{Binding SectionBackground}"
                  BorderBrush="{Binding BorderColor}"
                  BorderThickness="1"
                  CornerRadius="8"
                  IsVisible="{Binding ShowComputedEditor}">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Variables" />
                <Button Grid.Column="1"
                        Width="40"
                        Height="40"
                        Classes="dialog-button"
                        Background="{Binding ButtonBackground}"
                        BorderBrush="{Binding ButtonBorderBrush}"
                        Foreground="{Binding ButtonForeground}"
                        ToolTip.Tip="Variable hinzufügen"
                        Click="OnAddVariableClicked">
                  <svg:Svg Width="26"
                           Height="26"
                           Path="{Binding AddVariableIconPath}" />
                </Button>
              </Grid>

              <ItemsControl ItemsSource="{Binding Variables}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="widgets:CustomSignalVariableEntryViewModel">
                    <Grid ColumnDefinitions="92,*,76,76" Margin="0,10,0,8">
                      <TextBox Background="{Binding DataContext.EditorBackground, ElementName=Root}"
                               BorderBrush="{Binding DataContext.BorderColor, ElementName=Root}"
                               Foreground="{Binding DataContext.EditorForeground, ElementName=Root}"
                               Text="{Binding Name, Mode=TwoWay}" />
                      <TextBox Grid.Column="1"
                               Margin="8,0,0,0"
                               Background="{Binding DataContext.EditorBackground, ElementName=Root}"
                               BorderBrush="{Binding DataContext.BorderColor, ElementName=Root}"
                               Foreground="{Binding DataContext.EditorForeground, ElementName=Root}"
                               Text="{Binding SourcePath, Mode=TwoWay}" />
                      <Button Grid.Column="2"
                              Margin="8,0,0,0"
                              Classes="dialog-button"
                              Foreground="{Binding DataContext.ButtonForeground, ElementName=Root}"
                              Content="Pick"
                              Click="OnPickVariableSourceClicked"
                              CommandParameter="{Binding .}" />
                      <Button Grid.Column="3"
                              Margin="8,0,0,0"
                              Classes="dialog-button"
                              Foreground="{Binding DataContext.ButtonForeground, ElementName=Root}"
                              Content="Delete"
                              Click="OnDeleteVariableClicked"
                              CommandParameter="{Binding .}" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock FontSize="11" Foreground="{Binding SecondaryTextBrush}" Text="Use short variable names like A, B or Speed and pick the source path for each variable." TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border Padding="12"
                  Background="{Binding SectionBackground}"
                  BorderBrush="{Binding BorderColor}"
                  BorderThickness="1"
                  CornerRadius="8"
                  IsVisible="{Binding ShowComputedEditor}">
            <StackPanel Spacing="10">
              <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Formula" />

              <Grid ColumnDefinitions="*,260" VerticalAlignment="Top">
                <Grid RowDefinitions="Auto,*">
                  <ItemsControl ItemsSource="{Binding VariableButtons}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="widgets:FormulaInsertButtonDefinition">
                        <Button Margin="0,0,6,6"
                                Classes="token-button"
                                Background="{Binding DataContext.TokenButtonBackground, ElementName=Root}"
                                BorderBrush="{Binding DataContext.TokenButtonBorderBrush, ElementName=Root}"
                                Foreground="{Binding DataContext.TokenButtonForeground, ElementName=Root}"
                                Content="{Binding Label}"
                                ToolTip.Tip="{Binding ToolTip}"
                                Click="OnInsertFormulaTokenClicked"
                                CommandParameter="{Binding .}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Border Grid.Row="1"
                          Margin="0,8,0,0"
                          Background="{Binding FormulaPanelBackground}"
                          BorderBrush="{Binding BorderColor}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="0">
                    <TextBox x:Name="FormulaEditorTextBox"
                             AcceptsReturn="True"
                             MinHeight="150"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{Binding EditorForeground}"
                             Padding="12"
                             Text="{Binding FormulaText, Mode=TwoWay}" />
                  </Border>
                </Grid>

                <ItemsControl Grid.Column="1" Margin="12,50,0,0" ItemsSource="{Binding OperatorButtons}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <UniformGrid Columns="5" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="widgets:FormulaInsertButtonDefinition">
                      <Button Margin="0,0,4,4"
                              Classes="token-button"
                              Background="{Binding DataContext.TokenButtonBackground, ElementName=Root}"
                              BorderBrush="{Binding DataContext.TokenButtonBorderBrush, ElementName=Root}"
                              Foreground="{Binding DataContext.TokenButtonForeground, ElementName=Root}"
                              Content="{Binding Label}"
                              ToolTip.Tip="{Binding ToolTip}"
                              Click="OnInsertFormulaTokenClicked"
                              CommandParameter="{Binding .}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>

              <TextBlock FontSize="11" Foreground="{Binding SecondaryTextBrush}" Text="{Binding ExampleText}" TextWrapping="Wrap" />
              <TextBlock FontSize="11" Foreground="{Binding FormulaStatusBrush}" Text="{Binding FormulaStatusMessage}" TextWrapping="Wrap" IsVisible="{Binding ShowFormulaStatus}" />
            </StackPanel>
          </Border>

          <Border Padding="10" Background="{Binding SectionBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="4">
              <TextBlock FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="Published path" />
              <TextBlock FontSize="12" Foreground="{Binding PrimaryTextBrush}" Text="{Binding PreviewPath}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <TextBlock FontSize="12" Foreground="{Binding ValidationErrorBrush}" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
        </StackPanel>
      </ScrollViewer>
    </controls:EditorShellControl.BodyContent>

    <controls:EditorShellControl.FooterContent>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Classes="dialog-button" Content="Save" Click="OnSaveClicked" />
        <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
      </StackPanel>
    </controls:EditorShellControl.FooterContent>
  </controls:EditorShellControl>
</Window>