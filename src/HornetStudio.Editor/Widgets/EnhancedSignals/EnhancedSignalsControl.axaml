<editorUi:EditorTemplateControl
    x:Class="HornetStudio.Editor.Widgets.EnhancedSignalsControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Widgets"
    xmlns:editorUi="using:HornetStudio.Editor.Controls">
  <controls:EnhancedSignalsControl.HeaderActionsContent>
    <Button Padding="6,2"
            Classes="toolbar"
            Click="OnAddSignalClicked">
      <TextBlock FontSize="11" FontWeight="SemiBold" Text="Add" />
    </Button>
  </controls:EnhancedSignalsControl.HeaderActionsContent>

  <controls:EnhancedSignalsControl.BodyContent>
    <Border Padding="10,8"
            Background="{Binding EffectiveBodyBackgroundBrush}"
            BorderBrush="{Binding EffectiveBodyBorderBrush}"
            BorderThickness="{Binding EffectiveBodyBorderThickness}"
            CornerRadius="10">
      <Grid RowDefinitions="*,Auto">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding Signals, RelativeSource={RelativeSource AncestorType=controls:EnhancedSignalsControl}}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8"
                        Padding="8,6"
                        CornerRadius="8"
                        Background="{Binding RowBackground}"
                        BorderBrush="{Binding RowBorderBrush}"
                        BorderThickness="1">
                  <Grid RowDefinitions="Auto,Auto">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                      <TextBlock Grid.Column="0"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="{Binding PrimaryForeground}"
                                 Text="{Binding Name}" />

                      <Button Grid.Column="1"
                              Margin="6,0,0,0"
                              Padding="8,2"
                              Classes="toolbar"
                              Click="OnEditSignalClicked"
                              CommandParameter="{Binding .}">
                        <TextBlock FontSize="11" Text="Edit" />
                      </Button>

                      <Button Grid.Column="2"
                              Margin="6,0,0,0"
                              Padding="8,2"
                              Classes="toolbar"
                              Click="OnDeleteSignalClicked"
                              CommandParameter="{Binding .}">
                        <TextBlock FontSize="11" Text="Delete" />
                      </Button>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Margin="0,4,0,0"
                               FontSize="11"
                               Foreground="{Binding SecondaryForeground}"
                               Text="{Binding SourceText}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="1"
                               Margin="0,24,0,0"
                               FontSize="11"
                               Foreground="{Binding SecondaryForeground}"
                               Text="{Binding AlertText}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasAlert}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="1"
             FontSize="11"
             Foreground="{Binding EffectiveMutedForegroundBrush}"
             Text="No enhanced signals configured. Add host-backed enhanced modules here."
             IsVisible="{Binding HasNoSignals, RelativeSource={RelativeSource AncestorType=controls:EnhancedSignalsControl}}" />
      </Grid>
    </Border>
  </controls:EnhancedSignalsControl.BodyContent>

  <controls:EnhancedSignalsControl.FooterContent>
    <Border Padding="8,4">
      <TextBlock FontSize="11"
                 Foreground="{Binding EffectiveFooterForegroundBrush}"
                 Text="{Binding Footer}"
                 TextWrapping="Wrap" />
    </Border>
  </controls:EnhancedSignalsControl.FooterContent>
</editorUi:EditorTemplateControl>