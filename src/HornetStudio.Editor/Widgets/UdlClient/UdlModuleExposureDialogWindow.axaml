<Window
    x:Class="HornetStudio.Editor.Widgets.UdlModuleExposureDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Controls"
    xmlns:viewModels="using:HornetStudio.Editor.Widgets"
    Width="980"
    MinWidth="900"
    Height="700"
    MinHeight="620"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="{Binding TitleText}"
    Background="{Binding DialogBackground}">
  <Window.Styles>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding ButtonBackground}" />
      <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeground}" />
    </Style>
  </Window.Styles>

  <controls:EditorShellControl Margin="16"
                               ShellBackground="{Binding DialogBackground}"
                               ShellBorderBrush="{Binding BorderColor}"
                               ShellBorderThickness="1"
                               ShellCornerRadius="10"
                               ShellPadding="16"
                               ShowHeader="True"
                               ShowFooter="True">
    <controls:EditorShellControl.HeaderContent>
      <StackPanel>
        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="{Binding TitleText}" />
        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="{Binding DescriptionText}" TextWrapping="Wrap" />
      </StackPanel>
    </controls:EditorShellControl.HeaderContent>

    <controls:EditorShellControl.BodyContent>
      <Grid>
        <Grid IsVisible="{Binding IsGenericChannelView}" ColumnDefinitions="320,*">
          <Border Grid.Column="0"
                  Margin="0,0,12,0"
                  Background="{Binding SectionBackground}"
                  BorderBrush="{Binding BorderColor}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10">
            <Grid RowDefinitions="Auto,*">
              <TextBlock FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="Detected channels plus saved rules." TextWrapping="Wrap" />

              <ListBox Grid.Row="1"
                       Margin="0,10,0,0"
                       ItemsSource="{Binding Rows}"
                       SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                       Background="{Binding EditorBackground}"
                       BorderBrush="{Binding BorderColor}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="viewModels:UdlModuleExposureEditorRow">
                    <Border Padding="8" Margin="0,0,0,6" CornerRadius="6" Background="Transparent">
                      <StackPanel Spacing="2">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" Text="{Binding DisplayName}" />
                        <TextBlock FontSize="11" Foreground="{Binding DataContext.SecondaryTextBrush, ElementName=Root}" Text="{Binding Summary}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>

          <Border Grid.Column="1"
                  Background="{Binding SectionBackground}"
                  BorderBrush="{Binding BorderColor}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12">
            <Grid>
              <TextBlock IsVisible="{Binding ShowEmptyState}"
                         Foreground="{Binding SecondaryTextBrush}"
                         Text="No runtime channels are available yet. Connect the client to discover modules, or keep saved definitions for later." />

              <ScrollViewer IsVisible="{Binding HasSelectedRow}" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Module" />
                    <TextBox Grid.Column="1" Margin="10,0,0,0" IsReadOnly="True" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.ModuleName}" />

                    <TextBlock Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Channel" />
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding SelectedRow.ChannelName}" />

                    <TextBlock Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Format" />
                    <ComboBox Grid.Row="2"
                              Grid.Column="1"
                              Margin="10,8,0,0"
                              ItemsSource="{Binding FormatOptions}"
                              SelectedItem="{Binding SelectedRow.SelectedFormatKind, Mode=TwoWay}" />

                    <TextBlock Grid.Row="3" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="FormatParameter" />
                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             Margin="10,8,0,0"
                             Background="{Binding EditorBackground}"
                             BorderBrush="{Binding BorderColor}"
                             Foreground="{Binding EditorForeground}"
                             Text="{Binding SelectedRow.FormatParameter, Mode=TwoWay}"
                             ToolTip.Tip="{Binding SelectedRow.FormatParameterToolTip}" />

                    <TextBlock Grid.Row="4" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Unit" />
                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             Margin="10,8,0,0"
                             Background="{Binding EditorBackground}"
                             BorderBrush="{Binding BorderColor}"
                             Foreground="{Binding EditorForeground}"
                             Text="{Binding SelectedRow.Unit, Mode=TwoWay}" />

                    <TextBlock Grid.Row="5" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Supports Bits" />
                    <CheckBox Grid.Row="5" Grid.Column="1" Margin="10,8,0,0" IsEnabled="False" IsChecked="{Binding SelectedRow.SupportsBitExposure}" VerticalAlignment="Center" />

                    <TextBlock Grid.Row="6" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Expose Bits" IsVisible="{Binding SelectedRow.SupportsBitExposure}" />
                    <CheckBox Grid.Row="6" Grid.Column="1" Margin="10,8,0,0" IsChecked="{Binding SelectedRow.ExposeBits, Mode=TwoWay}" VerticalAlignment="Center" IsVisible="{Binding SelectedRow.SupportsBitExposure}" />
                  </Grid>

                  <Grid ColumnDefinitions="170,*" RowDefinitions="Auto">
                    <TextBlock Grid.Row="0" Margin="0,8,0,0" VerticalAlignment="Top" Foreground="{Binding PrimaryTextBrush}" Text="Bit Labels" IsVisible="{Binding SelectedRow.ShowBitLabelsEditor}" />
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Margin="10,8,0,0"
                             MinHeight="120"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             Background="{Binding EditorBackground}"
                             BorderBrush="{Binding BorderColor}"
                             Foreground="{Binding EditorForeground}"
                             Text="{Binding SelectedRow.BitLabels, Mode=TwoWay}"
                             Watermark="Bit0=Ready&#10;Bit1=Fault"
                             IsVisible="{Binding SelectedRow.ShowBitLabelsEditor}" />
                  </Grid>

                  <Border Padding="10" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="8">
                      <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Behavior" />
                      <TextBlock FontSize="11" Foreground="{Binding SecondaryTextBrush}" Text="Supported bit formats are b4, b8 and b16. The UdlClient publishes helper items under its own runtime branch and converts bool writes back into the underlying source channel." TextWrapping="Wrap" />
                      <TextBlock FontSize="11" Foreground="{Binding SecondaryTextBrush}" Text="If the effective format is no longer a bit format, helper items disappear until the format becomes compatible again." TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>

                  <TextBlock FontSize="12" Foreground="#B42318" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
                </StackPanel>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>

        <ScrollViewer IsVisible="{Binding IsModuleScopedView}" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
          <Border Background="{Binding SectionBackground}"
                  BorderBrush="{Binding BorderColor}"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="14">
            <StackPanel Spacing="10">
              <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Main" />
              <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Module" />
                <TextBox Grid.Column="1" Margin="10,0,0,0" IsReadOnly="True" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding ModuleCard.ModuleName}" />

                <TextBlock Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Type" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding ModuleCard.Type}" />

                <TextBlock Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="S/N" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding ModuleCard.SerialNumber}" />

                <TextBlock Grid.Row="3" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Version" />
                <TextBox Grid.Row="3" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Background="{Binding EditorBackground}" BorderBrush="{Binding BorderColor}" Foreground="{Binding EditorForeground}" Text="{Binding ModuleCard.Version}" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="{Binding SectionBackground}"
                  BorderBrush="{Binding BorderColor}"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="14">
            <StackPanel Spacing="10">
              <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Bitmask" />
              <ItemsControl ItemsSource="{Binding BitmaskRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="viewModels:UdlModuleExposureBitmaskRow">
                    <Grid ColumnDefinitions="160,110,60" Margin="0,4,0,0">
                      <TextBlock VerticalAlignment="Center" Foreground="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" Text="{Binding Label}" />
                      <CheckBox Grid.Column="1"
                                Content="Publish Bits"
                                IsChecked="{Binding ExposeBits, Mode=TwoWay}"
                                IsEnabled="{Binding IsEditable}"
                                VerticalAlignment="Center" />
                      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
                        <TextBlock VerticalAlignment="Center" Foreground="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" Text="Count" />
                        <TextBox Width="44"
                                 HorizontalContentAlignment="Center"
                                 Background="{Binding DataContext.EditorBackground, ElementName=Root}"
                                 BorderBrush="{Binding DataContext.BorderColor, ElementName=Root}"
                                 Foreground="{Binding DataContext.EditorForeground, ElementName=Root}"
                                 Text="{Binding BitCountText, Mode=TwoWay}" />
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Grid ColumnDefinitions="230,*" Margin="0,4,0,0">
                <TextBlock VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Read helper bits route to Set" />
                <CheckBox Grid.Column="1"
                          Content="True/False"
                          IsChecked="{Binding ReadInputRouteToSetRequest}"
                          VerticalAlignment="Center" />
              </Grid>

            </StackPanel>
          </Border>

          <Border Background="{Binding SectionBackground}"
                  BorderBrush="{Binding BorderColor}"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="14">
            <StackPanel Spacing="10">
              <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Settings" />
              <Grid ColumnDefinitions="120,*,*" RowDefinitions="Auto,*">
                <Border Grid.RowSpan="2" Background="Transparent" />
                <TextBlock Grid.Column="1" HorizontalAlignment="Center" Foreground="{Binding SecondaryTextBrush}" Text="Value" />
                <TextBlock Grid.Column="2" HorizontalAlignment="Center" Foreground="{Binding SecondaryTextBrush}" Text="Info" />

                <ItemsControl Grid.Row="1" Grid.ColumnSpan="3" ItemsSource="{Binding SettingsRows}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="viewModels:UdlModuleExposurePreparedFieldRow">
                      <Grid ColumnDefinitions="120,*,*" Margin="0,4,0,0">
                        <TextBlock VerticalAlignment="Center" Foreground="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" Text="{Binding Label}" />
                        <TextBox Grid.Column="1"
                                 Margin="10,0,10,0"
                                 IsReadOnly="True"
                                 Background="{Binding DataContext.EditorBackground, ElementName=Root}"
                                 BorderBrush="{Binding DataContext.BorderColor, ElementName=Root}"
                                 Foreground="{Binding DataContext.EditorForeground, ElementName=Root}"
                                 Text="{Binding ValuePlaceholder}" />
                        <TextBox Grid.Column="2"
                                 IsReadOnly="True"
                                 Background="{Binding DataContext.EditorBackground, ElementName=Root}"
                                 BorderBrush="{Binding DataContext.BorderColor, ElementName=Root}"
                                 Foreground="{Binding DataContext.EditorForeground, ElementName=Root}"
                                 Text="{Binding InfoPlaceholder}" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="{Binding SectionBackground}"
                  BorderBrush="{Binding BorderColor}"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="14">
            <StackPanel Spacing="10">
              <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Adjust" />
              <Grid ColumnDefinitions="120,*,*" RowDefinitions="Auto,*">
                <Border Grid.RowSpan="2" Background="Transparent" />
                <TextBlock Grid.Column="1" HorizontalAlignment="Center" Foreground="{Binding SecondaryTextBrush}" Text="X" />
                <TextBlock Grid.Column="2" HorizontalAlignment="Center" Foreground="{Binding SecondaryTextBrush}" Text="Y" />

                <ItemsControl Grid.Row="1" Grid.ColumnSpan="3" ItemsSource="{Binding AdjustRows}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="viewModels:UdlModuleExposureAdjustRow">
                      <Grid ColumnDefinitions="120,*,*" Margin="0,4,0,0">
                        <TextBlock VerticalAlignment="Center" Foreground="{Binding DataContext.PrimaryTextBrush, ElementName=Root}" Text="{Binding Label}" />
                        <TextBox Grid.Column="1"
                                 Margin="10,0,10,0"
                                 IsReadOnly="True"
                                 Background="{Binding DataContext.EditorBackground, ElementName=Root}"
                                 BorderBrush="{Binding DataContext.BorderColor, ElementName=Root}"
                                 Foreground="{Binding DataContext.EditorForeground, ElementName=Root}"
                                 Text="{Binding XPlaceholder}" />
                        <TextBox Grid.Column="2"
                                 IsReadOnly="True"
                                 Background="{Binding DataContext.EditorBackground, ElementName=Root}"
                                 BorderBrush="{Binding DataContext.BorderColor, ElementName=Root}"
                                 Foreground="{Binding DataContext.EditorForeground, ElementName=Root}"
                                 Text="{Binding YPlaceholder}" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>

              <Button Classes="dialog-button"
                      HorizontalAlignment="Right"
                      Content="Add Point"
                      IsEnabled="False" />
            </StackPanel>
          </Border>

            <TextBlock FontSize="12" Foreground="#B42318" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </controls:EditorShellControl.BodyContent>

    <controls:EditorShellControl.FooterContent>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Classes="dialog-button" Content="Save" Click="OnSaveClicked" />
        <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
      </StackPanel>
    </controls:EditorShellControl.FooterContent>
  </controls:EditorShellControl>
</Window>