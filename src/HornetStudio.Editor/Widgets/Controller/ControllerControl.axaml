<editorUi:EditorTemplateControl
    x:Class="HornetStudio.Editor.Widgets.ControllerControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Widgets"
    xmlns:editorUi="using:HornetStudio.Editor.Controls">
  <controls:ControllerControl.HeaderActionsContent>
    <Button Padding="6,2"
            Classes="toolbar"
            Click="OnAddControllerClicked">
      <TextBlock FontSize="11" FontWeight="SemiBold" Text="Add" />
    </Button>
  </controls:ControllerControl.HeaderActionsContent>

  <controls:ControllerControl.BodyContent>
    <Border Padding="10,8"
            Background="{Binding EffectiveBodyBackgroundBrush}"
            BorderBrush="{Binding EffectiveBodyBorderBrush}"
            BorderThickness="{Binding EffectiveBodyBorderThickness}"
            CornerRadius="10">
      <Grid RowDefinitions="*,Auto">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding Controllers, RelativeSource={RelativeSource AncestorType=controls:ControllerControl}}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8"
                        Padding="8,6"
                        CornerRadius="8"
                        Background="{Binding RowBackground}"
                        BorderBrush="{Binding RowBorderBrush}"
                        BorderThickness="1"
                        ToolTip.Tip="{Binding DetailToolTip}">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <Border Grid.Column="0"
                        Margin="0,0,8,0"
                            Padding="6,2"
                            CornerRadius="4"
                            Background="{Binding RowBorderBrush}">
                      <TextBlock FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="{Binding PrimaryForeground}"
                                 Text="{Binding TypeDisplayText}" />
                    </Border>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{Binding PrimaryForeground}"
                               Text="{Binding Name}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />

                    <Button Grid.Column="2"
                          Margin="8,0,0,0"
                            Padding="8,2"
                            Classes="toolbar"
                            Click="OnEditControllerClicked"
                            CommandParameter="{Binding .}">
                      <TextBlock FontSize="11" Text="Edit" />
                    </Button>

                    <Button Grid.Column="3"
                          Margin="8,0,0,0"
                            Padding="8,2"
                            Classes="toolbar"
                            Click="OnDeleteControllerClicked"
                            CommandParameter="{Binding .}">
                      <TextBlock FontSize="11" Text="Delete" />
                    </Button>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="1"
                   FontSize="11"
                   Foreground="{Binding EffectiveMutedForegroundBrush}"
                   Text="No PID controllers configured. Add runtime-backed controller definitions here."
                   IsVisible="{Binding HasNoControllers, RelativeSource={RelativeSource AncestorType=controls:ControllerControl}}" />
      </Grid>
    </Border>
  </controls:ControllerControl.BodyContent>

  <controls:ControllerControl.FooterContent>
    <Border Padding="8,4">
      <TextBlock FontSize="11"
                 Foreground="{Binding EffectiveFooterForegroundBrush}"
                 Text="{Binding Footer}"
                 TextWrapping="Wrap" />
    </Border>
  </controls:ControllerControl.FooterContent>
</editorUi:EditorTemplateControl>