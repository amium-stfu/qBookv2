<Window
    x:Class="HornetStudio.Editor.Widgets.TargetTreeSelectionDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Controls"
    xmlns:viewModels="using:HornetStudio.Editor.ViewModels"
    Width="640"
    MinWidth="560"
    MinHeight="420"
    MaxHeight="860"
    SizeToContent="Manual"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="Select Target"
    Background="{Binding DialogBackground, ElementName=Root}">
  <Window.Styles>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding ButtonBackground, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeground, ElementName=Root}" />
    </Style>
    <Style Selector="TreeView.dialog-tree">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{Binding PrimaryTextBrush, ElementName=Root}" />
    </Style>
    <Style Selector="TreeView.dialog-tree TreeViewItem">
      <Setter Property="Foreground" Value="{Binding PrimaryTextBrush, ElementName=Root}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,1,0,1" />
    </Style>
    <Style Selector="TreeView.dialog-tree TreeViewItem:pointerover">
      <Setter Property="Foreground" Value="{Binding PrimaryTextBrush, ElementName=Root}" />
    </Style>
    <Style Selector="TreeView.dialog-tree TreeViewItem:selected">
      <Setter Property="Foreground" Value="{Binding TabSelectForeColor, ElementName=Root}" />
      <Setter Property="Background" Value="{Binding TabSelectBackColor, ElementName=Root}" />
    </Style>
    <Style Selector="TreeView.dialog-tree ToggleButton">
      <Setter Property="Foreground" Value="{Binding PrimaryTextBrush, ElementName=Root}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
  </Window.Styles>
  <controls:EditorShellControl
      Margin="16"
      ShellBackground="{Binding DialogBackground, ElementName=Root}"
      ShellBorderBrush="{Binding BorderColor, ElementName=Root}"
      ShellBorderThickness="1"
      ShellCornerRadius="10"
      ShellPadding="14"
      ShowHeader="True"
      ShowFooter="True"
      HeaderPadding="0,0,0,10">
    <controls:EditorShellControl.HeaderContent>
      <StackPanel>
        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush, ElementName=Root}" Text="Select Target" />
        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="{Binding ScopeDescription}" TextWrapping="Wrap" />
      </StackPanel>
    </controls:EditorShellControl.HeaderContent>

    <controls:EditorShellControl.BodyContent>
      <StackPanel Spacing="10">
        <Border Padding="8"
                Background="{Binding EditorDialogSectionContentBackground, ElementName=Root}"
                BorderBrush="{Binding BorderColor, ElementName=Root}"
                BorderThickness="1"
                CornerRadius="8">
          <TextBlock FontSize="12" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="{Binding ScopePath}" TextWrapping="Wrap" />
        </Border>

        <Border Background="{Binding ParameterEditBackgrundColor, ElementName=Root}"
                BorderBrush="{Binding BorderColor, ElementName=Root}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
          <Grid RowDefinitions="Auto,Auto">
            <TextBlock FontSize="12" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Available targets" />
            <ScrollViewer Grid.Row="1"
                          Margin="0,8,0,0"
                          Height="480"
                          MaxHeight="480"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
              <TreeView x:Name="TargetTreeView"
                        Classes="dialog-tree"
                        ItemsSource="{Binding RootNodes}"
                        SelectionChanged="OnTreeSelectionChanged"
                        SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                <TreeView.ItemTemplate>
                  <TreeDataTemplate DataType="viewModels:TargetSelectionTreeNode" ItemsSource="{Binding Children}">
                    <Border Padding="6,4" CornerRadius="6">
                      <TextBlock Text="{Binding DisplayName}" TextWrapping="NoWrap" />
                    </Border>
                  </TreeDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </ScrollViewer>
          </Grid>
        </Border>
      </StackPanel>
    </controls:EditorShellControl.BodyContent>

    <controls:EditorShellControl.FooterContent>
      <StackPanel Spacing="10">
        <Border Padding="10"
                Background="{Binding EditorDialogSectionContentBackground, ElementName=Root}"
                BorderBrush="{Binding BorderColor, ElementName=Root}"
                BorderThickness="1"
                CornerRadius="8">
          <StackPanel Spacing="4">
            <TextBlock FontSize="12" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Selected target" />
            <TextBlock FontSize="12" Foreground="{Binding PrimaryTextBrush, ElementName=Root}" Text="{Binding SelectionPreviewPath}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
          <Button Classes="dialog-button" Content="Save" IsEnabled="{Binding CanSaveSelection}" Click="OnSaveClicked" />
          <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
        </StackPanel>
      </StackPanel>
    </controls:EditorShellControl.FooterContent>
  </controls:EditorShellControl>
</Window>