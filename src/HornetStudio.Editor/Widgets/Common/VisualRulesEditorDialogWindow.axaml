<Window
    x:Class="HornetStudio.Editor.Widgets.VisualRulesEditorDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Controls"
    xmlns:media="using:Avalonia.Media"
    xmlns:widgets="using:HornetStudio.Editor.Widgets"
    xmlns:viewModels="using:HornetStudio.Editor.ViewModels"
    Width="1200"
    MinWidth="1040"
    MinHeight="280"
    MaxHeight="780"
    SizeToContent="Height"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="Visual Rules"
    Background="{Binding DialogBackground, ElementName=Root}">
  <Window.Resources>
    <widgets:VisualRuleSourcePathDisplayConverter x:Key="VisualRuleSourcePathDisplayConverter" />
  </Window.Resources>
  <Window.Styles>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding ButtonBackground, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeground, ElementName=Root}" />
    </Style>
    <Style Selector="ComboBox.dialog-field">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Background" Value="{Binding InputBackground, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding InputForeground, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding BorderColor, ElementName=Root}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox.dialog-field">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Background" Value="{Binding InputBackground, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding InputForeground, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding BorderColor, ElementName=Root}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ComboBox.dialog-field:pointerover /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="ComboBox.dialog-field:focus /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.dialog-field:pointerover /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.dialog-field:focus /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
  </Window.Styles>

  <Grid>
    <controls:EditorShellControl
        Margin="16"
        ShellBackground="{Binding DialogBackground, ElementName=Root}"
        ShellBorderBrush="{Binding BorderColor, ElementName=Root}"
        ShellBorderThickness="1"
        ShellCornerRadius="10"
        ShellPadding="14"
        ShowHeader="True"
        ShowFooter="True"
        HeaderPadding="0,0,0,10">
      <controls:EditorShellControl.HeaderContent>
        <StackPanel>
          <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush, ElementName=Root}" Text="Visual Rules" />
          <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Apply widget-specific background colors and an optional blink effect from Monitor rule states." TextWrapping="Wrap" />
        </StackPanel>
      </controls:EditorShellControl.HeaderContent>

      <controls:EditorShellControl.BodyContent>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <StackPanel MinWidth="1020">
            <StackPanel Margin="0,0,0,8" Spacing="4">
              <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding SectionHeaderForeground, ElementName=Root}" Text="Configured" />
              <Border Height="1" Background="{Binding SectionBorderBrush, ElementName=Root}" />
            </StackPanel>

            <Border Background="{Binding EditorDialogSectionContentBackground, ElementName=Root}"
                    BorderBrush="{Binding BorderColor, ElementName=Root}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
              <ScrollViewer MaxHeight="380" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Rows}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="viewModels:ItemVisualRuleEditorRow">
                      <Grid ColumnDefinitions="140,300,140,120,170,170,Auto" Margin="0,0,0,8">
                        <ComboBox Classes="dialog-field" ItemsSource="{Binding SourceKindOptions}" SelectedItem="{Binding SourceKind, Mode=TwoWay}" />
                        <ComboBox Grid.Column="1" Margin="8,0,0,0" Classes="dialog-field" ItemsSource="{Binding SourceOptions}" SelectedItem="{Binding SourcePath, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding Converter={StaticResource VisualRuleSourcePathDisplayConverter}}" ToolTip.Tip="{Binding}" />
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox Grid.Column="2" Margin="8,0,0,0" Classes="dialog-field" ItemsSource="{Binding PropertyOptions}" SelectedItem="{Binding PropertyName, Mode=TwoWay}" />
                        <ComboBox Grid.Column="3" Margin="8,0,0,0" Classes="dialog-field" ItemsSource="{Binding EffectOptions}" SelectedItem="{Binding Effect, Mode=TwoWay}" />
                        <Grid Grid.Column="4" Margin="8,0,0,0" ColumnDefinitions="*,Auto">
                          <TextBox Classes="dialog-field" Text="{Binding ActiveValue, Mode=TwoWay}" Watermark="Active color" />
                          <Button Grid.Column="1" Margin="8,0,0,0" Classes="dialog-button" Click="OnRowActiveColorPickerClicked">
                            <controls:ThemeSvgIcon
                                Width="14"
                                Height="14"
                                IconPath="avares://HornetStudio.Editor/EditorIcons/pipette.svg"
                                TintColor="{Binding PrimaryTextBrush, ElementName=Root}" />
                          </Button>
                        </Grid>
                        <Grid Grid.Column="5" Margin="8,0,0,0" ColumnDefinitions="*,Auto">
                          <TextBox Classes="dialog-field" Text="{Binding InactiveValue, Mode=TwoWay}" Watermark="Inactive color (optional)" />
                          <Button Grid.Column="1" Margin="8,0,0,0" Classes="dialog-button" Click="OnRowInactiveColorPickerClicked">
                            <controls:ThemeSvgIcon
                                Width="14"
                                Height="14"
                                IconPath="avares://HornetStudio.Editor/EditorIcons/pipette.svg"
                                TintColor="{Binding PrimaryTextBrush, ElementName=Root}" />
                          </Button>
                        </Grid>
                        <Button Grid.Column="6" Margin="8,0,0,0" Classes="dialog-button" Content="Remove" Click="OnRemoveClicked" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>

            <StackPanel Margin="0,14,0,0" Spacing="8">
              <StackPanel Spacing="4">
                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding SectionHeaderForeground, ElementName=Root}" Text="New" />
                <Border Height="1" Background="{Binding SectionBorderBrush, ElementName=Root}" />
              </StackPanel>

              <Grid ColumnDefinitions="140,300,140,120,170,170,Auto" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Source kind" />
                <TextBlock Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Monitor rule source" />
                <TextBlock Grid.Row="0" Grid.Column="2" Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Property" />
                <TextBlock Grid.Row="0" Grid.Column="3" Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Effect" />
                <TextBlock Grid.Row="0" Grid.Column="4" Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Active color" />
                <TextBlock Grid.Row="0" Grid.Column="5" Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Inactive color" />

                <ComboBox Grid.Row="1" Margin="0,6,0,0" Classes="dialog-field" ItemsSource="{Binding SourceKindOptions}" SelectedItem="{Binding NewSourceKind, Mode=TwoWay}" />
                <ComboBox Grid.Row="1" Grid.Column="1" Margin="8,6,0,0" Classes="dialog-field" ItemsSource="{Binding SourceOptions}" SelectedItem="{Binding NewSourcePath, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Converter={StaticResource VisualRuleSourcePathDisplayConverter}}" ToolTip.Tip="{Binding}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox Grid.Row="1" Grid.Column="2" Margin="8,6,0,0" Classes="dialog-field" ItemsSource="{Binding PropertyOptions}" SelectedItem="{Binding NewPropertyName, Mode=TwoWay}" />
                <ComboBox Grid.Row="1" Grid.Column="3" Margin="8,6,0,0" Classes="dialog-field" ItemsSource="{Binding EffectOptions}" SelectedItem="{Binding NewEffect, Mode=TwoWay}" />
                <Grid Grid.Row="1" Grid.Column="4" Margin="8,6,0,0" ColumnDefinitions="*,Auto">
                  <TextBox Classes="dialog-field" Text="{Binding NewActiveValue, Mode=TwoWay}" Watermark="Active color" />
                  <Button Grid.Column="1" Margin="8,0,0,0" Classes="dialog-button" Click="OnNewActiveColorPickerClicked">
                    <controls:ThemeSvgIcon
                        Width="14"
                        Height="14"
                        IconPath="avares://HornetStudio.Editor/EditorIcons/pipette.svg"
                        TintColor="{Binding PrimaryTextBrush, ElementName=Root}" />
                  </Button>
                </Grid>
                <Grid Grid.Row="1" Grid.Column="5" Margin="8,6,0,0" ColumnDefinitions="*,Auto">
                  <TextBox Classes="dialog-field" Text="{Binding NewInactiveValue, Mode=TwoWay}" Watermark="Optional" />
                  <Button Grid.Column="1" Margin="8,0,0,0" Classes="dialog-button" Click="OnNewInactiveColorPickerClicked">
                    <controls:ThemeSvgIcon
                        Width="14"
                        Height="14"
                        IconPath="avares://HornetStudio.Editor/EditorIcons/pipette.svg"
                        TintColor="{Binding PrimaryTextBrush, ElementName=Root}" />
                  </Button>
                </Grid>
                <Button Grid.Row="1" Grid.Column="6" Margin="8,6,0,0" Classes="dialog-button" Content="Add" Click="OnAddClicked" />
              </Grid>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </controls:EditorShellControl.BodyContent>

      <controls:EditorShellControl.FooterContent>
        <StackPanel Spacing="10">
          <Border Height="1" Background="{Binding SectionBorderBrush, ElementName=Root}" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="dialog-button" Content="Save" Click="OnSaveClicked" />
            <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
          </StackPanel>
        </StackPanel>
      </controls:EditorShellControl.FooterContent>
    </controls:EditorShellControl>

    <Popup
        x:Name="ColorPopup"
        Placement="Right"
        IsLightDismissEnabled="True">
      <Border
          Width="248"
          Padding="12"
          Background="{Binding DialogBackground, ElementName=Root}"
          BorderBrush="{Binding BorderColor, ElementName=Root}"
          BorderThickness="1"
          CornerRadius="10"
          PointerPressed="OnInteractivePointerPressed">
        <StackPanel Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <controls:ThemeSvgIcon
                Width="16"
                Height="16"
                IconPath="avares://HornetStudio.Editor/EditorIcons/pipette.svg"
                TintColor="{Binding PrimaryTextBrush, ElementName=Root}" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{Binding PrimaryTextBrush, ElementName=Root}"
                Text="Color Picker" />
          </StackPanel>
          <WrapPanel Orientation="Horizontal" ItemWidth="110">
            <Button Classes="dialog-button" Content="Transparent" PointerPressed="OnInteractivePointerPressed" Click="OnTransparentColorClicked" />
            <Button Classes="dialog-button" Content="Theme" PointerPressed="OnInteractivePointerPressed" Click="OnDefaultColorClicked" />
          </WrapPanel>
          <WrapPanel x:Name="ColorPalettePanel" Orientation="Horizontal" />
          <Border Height="1" Background="{Binding BorderColor, ElementName=Root}" />
          <TextBox x:Name="ColorHexTextBox" Classes="dialog-field" PointerPressed="OnInteractivePointerPressed" KeyDown="OnColorHexTextBoxKeyDown" />
          <Button Classes="dialog-button" Content="Apply" PointerPressed="OnInteractivePointerPressed" Click="OnApplyHexColorClicked" />
        </StackPanel>
      </Border>
    </Popup>
  </Grid>
</Window>
