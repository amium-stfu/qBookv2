<Window
    x:Class="HornetStudio.Editor.Widgets.WidgetSelectionDialogWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1080"
    Height="720"
    MinWidth="920"
    MinHeight="620"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="Select Widget Type"
    Background="{Binding DialogBackground}"
    KeyDown="OnWindowKeyDown">
  <Grid Margin="16" ColumnDefinitions="300,16,*" RowDefinitions="*,Auto">
    <Border Grid.Row="0"
            Grid.Column="0"
            Padding="12"
            Background="{Binding PanelBackground}"
            BorderBrush="{Binding BorderColor}"
            BorderThickness="1"
            CornerRadius="12">
      <Grid RowDefinitions="Auto,12,*">
        <StackPanel Spacing="8">
          <TextBlock FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{Binding PrimaryTextBrush}"
                     Text="Filter" />
          <TextBox Background="{Binding EditorBackground}"
                   BorderBrush="{Binding BorderColor}"
                   Foreground="{Binding EditorForeground}"
                   Watermark="Search widget"
                   Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="{Binding EditorBackground}"
                BorderBrush="{Binding BorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="4">
          <ListBox ItemsSource="{Binding Widgets}"
                   SelectedItem="{Binding SelectedWidget, Mode=TwoWay}"
                   Background="Transparent"
                   BorderThickness="0"
                   Foreground="{Binding PrimaryTextBrush}"
                   DoubleTapped="OnWidgetListDoubleTapped">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="8,6" CornerRadius="8">
                  <StackPanel Spacing="2">
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{Binding DataContext.PrimaryTextBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                               Text="{Binding DisplayName}" />
                    <TextBlock FontSize="12"
                               Foreground="{Binding DataContext.SecondaryTextBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                               TextWrapping="Wrap"
                               Text="{Binding Summary}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="0"
            Grid.Column="2"
            Padding="12"
            Background="{Binding PanelBackground}"
            BorderBrush="{Binding BorderColor}"
            BorderThickness="1"
            CornerRadius="12">
      <Grid RowDefinitions="Auto,12,300,12,Auto,8,*">
        <StackPanel Spacing="4">
          <TextBlock FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{Binding SecondaryTextBrush}"
                     Text="Selected widget" />
          <TextBlock FontSize="24"
                     FontWeight="Bold"
                     Foreground="{Binding PrimaryTextBrush}"
                     Text="{Binding SelectedWidgetTitle}" />
          <TextBlock FontSize="13"
                     Foreground="{Binding SecondaryTextBrush}"
                     TextWrapping="Wrap"
                     Text="{Binding SelectedWidgetSummary}" />
        </StackPanel>

        <Border Grid.Row="2"
                Padding="16"
                Background="{Binding EditorBackground}"
                BorderBrush="{Binding BorderColor}"
                BorderThickness="1"
                CornerRadius="12">
          <ContentPresenter HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Content="{Binding PreviewContent}" />
        </Border>

        <TextBlock Grid.Row="4"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{Binding SecondaryTextBrush}"
                   Text="Description" />

        <ScrollViewer Grid.Row="6"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <TextBox IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Background="{Binding EditorBackground}"
                   BorderBrush="{Binding BorderColor}"
                   Foreground="{Binding EditorForeground}"
                   Text="{Binding DescriptionText}" />
        </ScrollViewer>
      </Grid>
    </Border>

    <StackPanel Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="0,12,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Width="96"
              Background="{Binding ButtonBackground}"
              BorderBrush="{Binding ButtonBorderBrush}"
              Foreground="{Binding ButtonForeground}"
              Content="Cancel"
              Click="OnCancelClicked" />
      <Button Width="96"
              Background="{Binding ButtonBackground}"
              BorderBrush="{Binding ButtonBorderBrush}"
              Foreground="{Binding ButtonForeground}"
              Content="{Binding ConfirmButtonText}"
              IsEnabled="{Binding CanSelect}"
              Click="OnSelectClicked" />
    </StackPanel>
  </Grid>
</Window>