<Window
    x:Class="HornetStudio.Editor.Widgets.InteractionRulesEditorDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Controls"
    xmlns:widgets="using:HornetStudio.Editor.Widgets"
    xmlns:viewModels="using:HornetStudio.Editor.ViewModels"
    Width="1220"
    MinWidth="1080"
    MinHeight="260"
    MaxHeight="760"
    SizeToContent="Height"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="Interaction Rules"
    Background="{Binding DialogBackground, ElementName=Root}">
  <Window.Resources>
    <widgets:PythonInteractionTargetDisplayConverter x:Key="PythonInteractionTargetDisplayConverter" />
  </Window.Resources>
  <Window.Styles>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding ButtonBackground, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeground, ElementName=Root}" />
    </Style>
    <Style Selector="ComboBox.dialog-field">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Background" Value="{Binding InputBackground, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding InputForeground, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding BorderColor, ElementName=Root}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox.dialog-field">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Background" Value="{Binding InputBackground, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding InputForeground, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding BorderColor, ElementName=Root}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ComboBox.dialog-field:pointerover /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="ComboBox.dialog-field:focus /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.dialog-field:pointerover /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.dialog-field:focus /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.dialog-field:readonly /template/ Border">
      <Setter Property="Background" Value="{Binding InputBackground, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding BorderColor, ElementName=Root}" />
    </Style>
    <Style Selector="ComboBox.dialog-field /template/ ToggleButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{Binding InputForeground, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ComboBox.dialog-field /template/ PathIcon">
      <Setter Property="Foreground" Value="{Binding InputForeground, ElementName=Root}" />
    </Style>
    <Style Selector="ComboBox.dialog-field /template/ Path">
      <Setter Property="Fill" Value="{Binding InputForeground, ElementName=Root}" />
    </Style>
  </Window.Styles>
  <controls:EditorShellControl
      Margin="16"
      ShellBackground="{Binding DialogBackground, ElementName=Root}"
      ShellBorderBrush="{Binding BorderColor, ElementName=Root}"
      ShellBorderThickness="1"
      ShellCornerRadius="10"
      ShellPadding="14"
      ShowHeader="True"
      ShowFooter="True"
      HeaderPadding="0,0,0,10">
    <controls:EditorShellControl.HeaderContent>
      <StackPanel>
        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush, ElementName=Root}" Text="Interaction Rules" />
        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Configure which action should run for each item interaction event." TextWrapping="Wrap" />
      </StackPanel>
    </controls:EditorShellControl.HeaderContent>

    <controls:EditorShellControl.BodyContent>
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
      <StackPanel MinWidth="1090">
        <StackPanel Margin="0,0,0,8" Spacing="4">
          <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding SectionHeaderForeground, ElementName=Root}" Text="Configured" />
          <Border Height="1" Background="{Binding SectionBorderBrush, ElementName=Root}" />
        </StackPanel>

        <Border Background="{Binding EditorDialogSectionContentBackground, ElementName=Root}"
                BorderBrush="{Binding BorderColor, ElementName=Root}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
          <ScrollViewer MaxHeight="360" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Rows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="viewModels:ItemInteractionEditorRow">
                  <Grid ColumnDefinitions="160,170,260,220,*,Auto" RowDefinitions="Auto,Auto" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                    <ComboBox Classes="dialog-field" ItemsSource="{Binding EventOptions}" SelectedItem="{Binding EventName, Mode=TwoWay}" />
                    <ComboBox Grid.Column="1" Margin="8,0,0,0" Classes="dialog-field" ItemsSource="{Binding ActionOptions}" SelectedItem="{Binding ActionName, Mode=TwoWay}" />
                    <Grid Grid.Column="2" Margin="8,0,0,0" ColumnDefinitions="*,Auto" IsVisible="{Binding UsesBrowseTargetSelection}">
                      <TextBox Classes="dialog-field" IsReadOnly="True" Text="{Binding TargetPath, Mode=OneWay}" />
                      <Button Grid.Column="1" Margin="8,0,0,0" Classes="dialog-button" ToolTip.Tip="Browse targets" Click="OnBrowseRowTargetClicked">
                        <controls:ThemeSvgIcon Width="14" Height="14" IconPath="avares://HornetStudio.Editor/EditorIcons/list.svg" TintColor="{Binding PrimaryTextBrush, ElementName=Root}" />
                      </Button>
                    </Grid>
                    <ComboBox Grid.Column="2" Margin="8,0,0,0" Classes="dialog-field" IsVisible="{Binding UsesComboTargetSelection}" ItemsSource="{Binding TargetOptions}" SelectedItem="{Binding TargetPath, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Converter={StaticResource PythonInteractionTargetDisplayConverter}}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Grid.Column="2" Margin="8,0,0,0" Classes="dialog-field" IsVisible="{Binding !ShowsTargetSelection}" IsEnabled="False" Text="-" />
                    <ComboBox Grid.Column="3" Margin="8,0,0,0" Classes="dialog-field" IsVisible="{Binding ShowsRunFunctionPicker}" ItemsSource="{Binding RunFunctionOptions}" SelectedItem="{Binding SelectedRunFunctionOption, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding DisplayText}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox Grid.Column="3" Margin="8,0,0,0" Classes="dialog-field" IsVisible="{Binding ShowsLegacyFunctionPicker}" ItemsSource="{Binding FunctionOptions}" SelectedItem="{Binding FunctionName, Mode=TwoWay}" />
                    <ComboBox Grid.Column="3" Margin="8,0,0,0" Classes="dialog-field" IsVisible="{Binding ShowsSetValueFunctionPicker}" ItemsSource="{Binding SetValueOperationOptions}" SelectedItem="{Binding SelectedSetValueOperation, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding DisplayText}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Grid.Column="3" Margin="8,0,0,0" Classes="dialog-field" IsVisible="{Binding ShowsFunctionPlaceholder}" IsEnabled="False" Text="-" />
                    <TextBox Grid.Column="4" Margin="8,0,0,0" Classes="dialog-field" IsVisible="{Binding ShowsArgumentEditor}" Text="{Binding Argument, Mode=TwoWay}" Watermark="Argument" />
                    <Grid Grid.Column="4" Margin="8,0,0,0" ColumnDefinitions="*,140" IsVisible="{Binding ShowsSetValueLiteralEditor}">
                      <TextBox Classes="dialog-field" Text="{Binding SetValueLiteralArgument, Mode=TwoWay}" Watermark="{Binding SetValueLiteralWatermark}" ToolTip.Tip="{Binding SetValueValidationMessage}" />
                      <TextBox Grid.Column="1" Margin="8,0,0,0" Classes="dialog-field" IsVisible="{Binding ShowsSetValueSeparatorEditor}" Text="{Binding SetValueSeparator, Mode=TwoWay}" Watermark="Separator" ToolTip.Tip="Optional separator used between current and appended text" />
                    </Grid>
                    <Grid Grid.Column="4" Margin="8,0,0,0" ColumnDefinitions="*,Auto" IsVisible="{Binding ShowsSetValueSourceEditor}">
                      <TextBox Classes="dialog-field" IsReadOnly="True" Text="{Binding SetValueSourcePath, Mode=OneWay}" Watermark="Source item" ToolTip.Tip="{Binding SetValueValidationMessage}" />
                      <Button Grid.Column="1" Margin="8,0,0,0" Classes="dialog-button" ToolTip.Tip="Browse source items" Click="OnBrowseRowSetValueSourceClicked">
                        <controls:ThemeSvgIcon Width="14" Height="14" IconPath="avares://HornetStudio.Editor/EditorIcons/list.svg" TintColor="{Binding PrimaryTextBrush, ElementName=Root}" />
                      </Button>
                    </Grid>
                    <TextBlock Grid.Row="1" Grid.Column="4" Margin="8,4,0,0" FontSize="11" Foreground="#FCA5A5" Text="{Binding SetValueValidationMessage}" TextWrapping="Wrap" IsVisible="{Binding HasSetValueValidationError}" />
                    <Button Grid.Column="5" Margin="8,0,0,0" Classes="dialog-button" Content="Remove" Click="OnRemoveClicked" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <StackPanel Margin="0,14,0,0" Spacing="8">
          <StackPanel Spacing="4">
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding SectionHeaderForeground, ElementName=Root}" Text="New" />
            <Border Height="1" Background="{Binding SectionBorderBrush, ElementName=Root}" />
          </StackPanel>

          <Grid ColumnDefinitions="160,170,260,220,*,Auto" RowDefinitions="Auto,Auto,Auto" HorizontalAlignment="Stretch">
            <TextBlock Grid.Row="0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Event" />
            <TextBlock Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Action" />
            <TextBlock Grid.Row="0" Grid.Column="2" Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Target" />
            <TextBlock Grid.Row="0" Grid.Column="3" Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Function" />
            <TextBlock Grid.Row="0" Grid.Column="4" Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding SecondaryTextBrush, ElementName=Root}" Text="Argument" />

            <ComboBox Grid.Row="1" Margin="0,6,0,0" Classes="dialog-field" ItemsSource="{Binding EventOptions}" SelectedItem="{Binding NewEventName, Mode=TwoWay}" />
            <ComboBox Grid.Row="1" Grid.Column="1" Margin="8,6,0,0" Classes="dialog-field" ItemsSource="{Binding ActionOptions}" SelectedItem="{Binding NewActionName, Mode=TwoWay}" />
            <Grid Grid.Row="1" Grid.Column="2" Margin="8,6,0,0" ColumnDefinitions="*,Auto" IsVisible="{Binding UsesBrowseTargetSelection}">
              <TextBox Classes="dialog-field" IsReadOnly="True" Text="{Binding NewTargetPath, Mode=OneWay}" />
              <Button Grid.Column="1" Margin="8,0,0,0" Classes="dialog-button" ToolTip.Tip="Browse targets" Click="OnBrowseNewTargetClicked">
                <controls:ThemeSvgIcon Width="14" Height="14" IconPath="avares://HornetStudio.Editor/EditorIcons/list.svg" TintColor="{Binding PrimaryTextBrush, ElementName=Root}" />
              </Button>
            </Grid>
            <ComboBox Grid.Row="1" Grid.Column="2" Margin="8,6,0,0" Classes="dialog-field" IsVisible="{Binding UsesComboTargetSelection}" ItemsSource="{Binding TargetOptions}" SelectedItem="{Binding NewTargetPath, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource PythonInteractionTargetDisplayConverter}}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBox Grid.Row="1" Grid.Column="2" Margin="8,6,0,0" Classes="dialog-field" IsVisible="{Binding !ShowsTargetSelection}" IsEnabled="False" Text="-" />
             <ComboBox Grid.Row="1" Grid.Column="3" Margin="8,6,0,0" Classes="dialog-field" IsVisible="{Binding ShowsNewRunFunctionPicker}" ItemsSource="{Binding NewRunFunctionOptions}" SelectedItem="{Binding SelectedNewRunFunctionOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayText}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="NewFunctionComboBox" Grid.Row="1" Grid.Column="3" Margin="8,6,0,0" Classes="dialog-field" IsVisible="{Binding ShowsLegacyFunctionPicker}" SelectedItem="{Binding NewFunctionName, Mode=TwoWay}" />
             <ComboBox Grid.Row="1" Grid.Column="3" Margin="8,6,0,0" Classes="dialog-field" IsVisible="{Binding ShowsNewSetValueFunctionPicker}" ItemsSource="{Binding NewSetValueOperationOptions}" SelectedItem="{Binding SelectedNewSetValueOperation, Mode=TwoWay}">
               <ComboBox.ItemTemplate>
                 <DataTemplate>
                   <TextBlock Text="{Binding DisplayText}" />
                 </DataTemplate>
               </ComboBox.ItemTemplate>
             </ComboBox>
             <TextBox Grid.Row="1" Grid.Column="3" Margin="8,6,0,0" Classes="dialog-field" IsVisible="{Binding ShowsNewFunctionPlaceholder}" IsEnabled="False" Text="-" />
            <TextBox Grid.Row="1" Grid.Column="4" Margin="8,6,0,0" Classes="dialog-field" IsVisible="{Binding ShowsArgumentEditor}" Text="{Binding NewArgument, Mode=TwoWay}" Watermark="Argument" />
              <Grid Grid.Row="1" Grid.Column="4" Margin="8,6,0,0" ColumnDefinitions="*,140" IsVisible="{Binding ShowsNewSetValueLiteralEditor}">
                <TextBox Classes="dialog-field" Text="{Binding NewSetValueLiteralArgument, Mode=TwoWay}" Watermark="{Binding NewSetValueLiteralWatermark}" ToolTip.Tip="{Binding NewSetValueValidationMessage}" />
                <TextBox Grid.Column="1" Margin="8,0,0,0" Classes="dialog-field" IsVisible="{Binding ShowsNewSetValueSeparatorEditor}" Text="{Binding NewSetValueSeparator, Mode=TwoWay}" Watermark="Separator" ToolTip.Tip="Optional separator used between current and appended text" />
              </Grid>
             <Grid Grid.Row="1" Grid.Column="4" Margin="8,6,0,0" ColumnDefinitions="*,Auto" IsVisible="{Binding ShowsNewSetValueSourceEditor}">
               <TextBox Classes="dialog-field" IsReadOnly="True" Text="{Binding NewSetValueSourcePath, Mode=OneWay}" Watermark="Source item" ToolTip.Tip="{Binding NewSetValueValidationMessage}" />
               <Button Grid.Column="1" Margin="8,0,0,0" Classes="dialog-button" ToolTip.Tip="Browse source items" Click="OnBrowseNewSetValueSourceClicked">
                 <controls:ThemeSvgIcon Width="14" Height="14" IconPath="avares://HornetStudio.Editor/EditorIcons/list.svg" TintColor="{Binding PrimaryTextBrush, ElementName=Root}" />
               </Button>
             </Grid>
             <TextBlock Grid.Row="2" Grid.Column="4" Margin="8,4,0,0" FontSize="11" Foreground="#FCA5A5" Text="{Binding NewSetValueValidationMessage}" TextWrapping="Wrap" IsVisible="{Binding HasNewSetValueValidationError}" />
            <Button Grid.Row="1" Grid.Column="5" Margin="8,6,0,0" Classes="dialog-button" Content="Add" IsEnabled="{Binding CanAdd}" Click="OnAddClicked" />
          </Grid>
        </StackPanel>
      </StackPanel>
      </ScrollViewer>
    </controls:EditorShellControl.BodyContent>

    <controls:EditorShellControl.FooterContent>
      <StackPanel Spacing="10">
        <Border Height="1" Background="{Binding SectionBorderBrush, ElementName=Root}" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
          <Button Classes="dialog-button" Content="Save" IsEnabled="{Binding CanSave}" Click="OnSaveClicked" />
          <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
        </StackPanel>
      </StackPanel>
    </controls:EditorShellControl.FooterContent>
  </controls:EditorShellControl>
</Window>
