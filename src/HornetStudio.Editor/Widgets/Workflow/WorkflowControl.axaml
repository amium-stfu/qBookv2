<editorUi:EditorTemplateControl
  x:Class="HornetStudio.Editor.Widgets.FunctionsControl"
  x:CompileBindings="False"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Widgets"
    xmlns:editorUi="using:HornetStudio.Editor.Controls">
  <controls:FunctionsControl.HeaderActionsContent>
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Padding="6,2"
              Classes="toolbar"
                Click="OnAddFunctionClicked">
              <TextBlock FontSize="11" FontWeight="SemiBold" Text="Add Function" />
      </Button>
      <Button Padding="6,2"
              Classes="toolbar"
              Click="OnRefreshClicked">
        <TextBlock FontSize="11" FontWeight="SemiBold" Text="Refresh" />
      </Button>
    </StackPanel>
  </controls:FunctionsControl.HeaderActionsContent>

  <controls:FunctionsControl.BodyContent>
  <Border Padding="10,8"
          Background="{Binding EffectiveBodyBackgroundBrush}"
          BorderBrush="{Binding EffectiveBodyBorderBrush}"
          BorderThickness="{Binding EffectiveBodyBorderThickness}"
          CornerRadius="10">
    <Grid RowDefinitions="Auto,Auto,*">
      <TextBlock FontSize="12"
                 Foreground="{Binding EffectiveMutedForegroundBrush}"
                 Text="Shows the central function catalog for YAML entries and read-only Python entries."
                 TextWrapping="Wrap" />

      <TextBlock x:Name="WorkflowDirectoryText"
                 Grid.Row="1"
                 Margin="0,10,0,10"
                 FontSize="12"
                 Foreground="{Binding EffectiveMutedForegroundBrush}"
                 TextWrapping="Wrap" />

      <Grid Grid.Row="2">
        <TextBlock x:Name="EmptyStateText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Foreground="{Binding EffectiveMutedForegroundBrush}"
                   Text="No function YAML files found." />

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      IsVisible="{Binding !IsVisible, ElementName=EmptyStateText}"
                      MaxHeight="320">
          <ItemsControl x:Name="WorkflowItemsControl"
                        ItemsSource="{Binding FunctionEntries, RelativeSource={RelativeSource AncestorType=controls:FunctionsControl}}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="controls:FunctionCatalogRow">
                <Border Margin="0,0,0,6"
                        Padding="8,6"
                        Background="Transparent"
                        BorderBrush="{Binding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        ToolTip.Tip="{Binding ToolTipText}">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
                        VerticalAlignment="Center">
                    <Border Padding="8,2"
                            Background="{Binding BadgeBackground}"
                            CornerRadius="999"
                            VerticalAlignment="Center">
                      <TextBlock FontSize="11"
                                 Foreground="{Binding BadgeForeground}"
                                 Text="{Binding DisplayKindText}" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="8,0,0,0"
                                Spacing="2"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{Binding ToolTipText}">
                      <TextBlock FontWeight="SemiBold"
                                 Foreground="{Binding TitleBrush}"
                                 MaxLines="1"
                                 Text="{Binding DisplayName}"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock FontSize="11"
                                 Foreground="{Binding SubtitleBrush}"
                                 MaxLines="1"
                                 Text="{Binding SourceText}"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Margin="10,0,0,0"
                               MinWidth="46"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{Binding StatusBrush}"
                               IsVisible="{Binding HasCompactStatus}"
                               Text="{Binding CompactStatusText}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding CompactStatusToolTipText}" />

                    <Button Grid.Column="3"
                            Margin="8,0,0,0"
                            Padding="8,3"
                            Classes="toolbar"
                            IsVisible="{Binding IsRunStopVisible}"
                            IsEnabled="{Binding IsRunStopEnabled}"
                            CommandParameter="{Binding}"
                            Click="OnRunStopFunctionClicked">
                      <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding RunStopActionText}" />
                    </Button>

                    <Button Grid.Column="4"
                            Margin="8,0,0,0"
                            Padding="8,3"
                            Classes="toolbar"
                            IsVisible="{Binding IsEditVisible}"
                            CommandParameter="{Binding}"
                            Click="OnEditFunctionClicked">
                      <TextBlock FontSize="11" FontWeight="SemiBold" Text="Edit" />
                    </Button>

                    <Button Grid.Column="5"
                            Margin="8,0,0,0"
                            Padding="8,3"
                            Classes="toolbar"
                            IsVisible="{Binding IsDeleteVisible}"
                            CommandParameter="{Binding}"
                            Click="OnDeleteFunctionClicked">
                      <TextBlock FontSize="11" FontWeight="SemiBold" Text="Delete" />
                    </Button>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Border>
  </controls:FunctionsControl.BodyContent>

  <controls:FunctionsControl.FooterContent>
    <Border Padding="8,4">
      <TextBlock FontSize="11"
                 Foreground="{Binding EffectiveFooterForegroundBrush}"
                 Text="{Binding Footer}"
                 TextWrapping="Wrap" />
    </Border>
  </controls:FunctionsControl.FooterContent>
</editorUi:EditorTemplateControl>
