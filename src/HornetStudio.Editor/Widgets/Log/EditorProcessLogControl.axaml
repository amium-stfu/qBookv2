<editorUi:EditorTemplateControl
    x:Class="HornetStudio.Editor.Widgets.EditorProcessLogControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HornetStudio.Editor.Widgets"
    xmlns:editorUi="using:HornetStudio.Editor.Controls">
  <controls:EditorProcessLogControl.BodyContent>
    <controls:EditorLogControl
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
      PageIsActive="{Binding PageIsActive, RelativeSource={RelativeSource AncestorType=controls:EditorProcessLogControl}}" />
  </controls:EditorProcessLogControl.BodyContent>
</editorUi:EditorTemplateControl>
