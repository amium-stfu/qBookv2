<UserControl
    x:Class="HornetStudio.Editor.Widgets.ApplicationExplorerSettingsDialogWindow"
    x:Name="EnvPanelRoot"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Margin="0,4,0,0"
          Background="Transparent"
          BorderBrush="Transparent"
          BorderThickness="0"
          CornerRadius="0"
          Padding="0">
    <StackPanel Spacing="10">
      <TextBlock FontSize="14"
             FontWeight="SemiBold"
             Foreground="{Binding PrimaryTextBrush, ElementName=EnvPanelRoot}"
             Text="Applications" />

            <Button x:Name="AddEnvironmentButton"
              Margin="0,4,0,4"
              Padding="10,6"
              Background="{Binding ButtonBackground, ElementName=EnvPanelRoot}"
              BorderBrush="{Binding ButtonBorderBrush, ElementName=EnvPanelRoot}"
              Foreground="{Binding ButtonForeground, ElementName=EnvPanelRoot}"
              HorizontalAlignment="Stretch"
              Click="OnAddEnvironmentClicked">
        <TextBlock FontSize="13"
             FontWeight="SemiBold"
             HorizontalAlignment="Center"
             Text="Add Application" />
      </Button>

      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    Height="160">
        <ItemsControl ItemsSource="{Binding Environments, ElementName=EnvPanelRoot}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,4,0,0"
                      Padding="6,4"
                      CornerRadius="6"
                      Background="{Binding SettingsRowBackground}"
                      BorderBrush="Transparent"
                      BorderThickness="0">
                    <Grid ColumnDefinitions="*,84,Auto,Auto,Auto">
                  <TextBlock Grid.Column="0"
                             FontSize="12"
                             VerticalAlignment="Center"
                             Foreground="{Binding PrimaryTextBrush, ElementName=EnvPanelRoot}"
                             Text="{Binding StatusText}" />

                  <Button Grid.Column="1"
                          Margin="6,0,0,0"
                      Background="Transparent"
                      BorderBrush="{Binding ButtonBorderBrush, ElementName=EnvPanelRoot}"
                      Foreground="{Binding ButtonForeground, ElementName=EnvPanelRoot}"
                      HorizontalContentAlignment="Stretch"
                      VerticalContentAlignment="Center"
                      MinHeight="24"
                      Padding="4,0">
                    <TextBox Background="Transparent"
                         BorderThickness="0"
                         Foreground="{Binding ButtonForeground, ElementName=EnvPanelRoot}"
                         HorizontalContentAlignment="Center"
                      Text="{Binding StartupDelayEditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      KeyDown="OnDelayEditorKeyDown"
                      LostFocus="OnDelayEditorLostFocus" />
                  </Button>

                  <Button Grid.Column="2"
                      Margin="6,0,0,0"
                      Padding="8,2"
                      Background="{Binding StartButtonBackground}"
                          BorderBrush="{Binding ButtonBorderBrush, ElementName=EnvPanelRoot}"
                      Foreground="{Binding StartButtonForeground}"
                      Command="{Binding ToggleCommand}">
                    <TextBlock FontSize="11" Text="{Binding ToggleButtonText}" />
                  </Button>

                  <Button Grid.Column="3"
                          Margin="6,0,0,0"
                          Padding="8,2"
                          Background="{Binding ButtonBackground, ElementName=EnvPanelRoot}"
                          BorderBrush="{Binding ButtonBorderBrush, ElementName=EnvPanelRoot}"
                          Foreground="{Binding ButtonForeground, ElementName=EnvPanelRoot}"
                          Command="{Binding EditCommand}">
                    <TextBlock FontSize="11" Text="Edit" />
                  </Button>

                  <Button Grid.Column="4"
                          Margin="6,0,0,0"
                          Padding="8,2"
                          Background="{Binding ButtonBackground, ElementName=EnvPanelRoot}"
                          BorderBrush="{Binding ButtonBorderBrush, ElementName=EnvPanelRoot}"
                          Foreground="{Binding ButtonForeground, ElementName=EnvPanelRoot}"
                          Click="OnDeleteEnvironmentClicked"
                          CommandParameter="{Binding .}">
                    <TextBlock FontSize="11" Text="Delete" />
                  </Button>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </StackPanel>
  </Border>
</UserControl>
