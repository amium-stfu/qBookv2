<UserControl
    x:Name="Root"
    x:Class="Amium.UiEditor.Widgets.EditorValueInputControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:Amium.UiEditor.Widgets"
  DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=controls:FolderEditorControl}}">
  <UserControl.Styles>
    <Style Selector="TextBox.input-field">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{Binding CardBorderBrush, ElementName=Root}" />
      <Setter Property="Background" Value="{Binding ParameterEditBackgrundColor, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding ParameterEditForeColor, ElementName=Root}" />
      <Setter Property="CaretBrush" Value="{Binding ParameterEditForeColor, ElementName=Root}" />
      <Setter Property="SelectionBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
      <Setter Property="SelectionForegroundBrush" Value="{Binding ParameterEditForeColor, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.input-field:pointerover">
      <Setter Property="Background" Value="{Binding ParameterEditBackgrundColor, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding ParameterEditForeColor, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.input-field:focus">
      <Setter Property="Background" Value="{Binding ParameterEditBackgrundColor, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding ParameterEditForeColor, ElementName=Root}" />
      <Setter Property="CaretBrush" Value="{Binding ParameterEditForeColor, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.input-field /template/ Border">
      <Setter Property="Background" Value="{Binding ParameterEditBackgrundColor, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding CardBorderBrush, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.input-field:pointerover /template/ Border">
      <Setter Property="Background" Value="{Binding ParameterEditBackgrundColor, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.input-field:focus /template/ Border">
      <Setter Property="Background" Value="{Binding ParameterEditBackgrundColor, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor, ElementName=Root}" />
    </Style>
    <Style Selector="TextBox.input-field /template/ ScrollViewer">
      <Setter Property="Background" Value="{Binding ParameterEditBackgrundColor, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding ParameterEditForeColor, ElementName=Root}" />
    </Style>

    <Style Selector="Button.input-key, Button.action-key, ToggleButton.bit-key">
      <Setter Property="Background" Value="{Binding ButtonBackColor, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding EditPanelButtonBorderBrush, ElementName=Root}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeColor, ElementName=Root}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.input-key /template/ Border, Button.action-key /template/ Border, ToggleButton.bit-key /template/ Border">
      <Setter Property="Background" Value="{Binding ButtonBackColor, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding EditPanelButtonBorderBrush, ElementName=Root}" />
    </Style>
    <Style Selector="Button.input-key /template/ ContentPresenter, Button.action-key /template/ ContentPresenter, ToggleButton.bit-key /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="{Binding ButtonForeColor, ElementName=Root}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.input-key:pointerover /template/ Border, Button.action-key:pointerover /template/ Border, ToggleButton.bit-key:pointerover /template/ Border">
      <Setter Property="Background" Value="{Binding ButtonHoverColor, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding EditPanelButtonBorderBrush, ElementName=Root}" />
    </Style>
    <Style Selector="Button.input-key:pointerover /template/ ContentPresenter, Button.action-key:pointerover /template/ ContentPresenter, ToggleButton.bit-key:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{Binding ButtonHoverColor, ElementName=Root}" />
      <Setter Property="TextElement.Foreground" Value="{Binding ButtonForeColor, ElementName=Root}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.input-key:pressed /template/ Border, Button.action-key:pressed /template/ Border, ToggleButton.bit-key:pressed /template/ Border">
      <Setter Property="Background" Value="{Binding ButtonBackColor, ElementName=Root}" />
      <Setter Property="BorderBrush" Value="{Binding EditPanelButtonBorderBrush, ElementName=Root}" />
    </Style>
    <Style Selector="Button.input-key:pressed /template/ ContentPresenter, Button.action-key:pressed /template/ ContentPresenter, ToggleButton.bit-key:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{Binding ButtonBackColor, ElementName=Root}" />
      <Setter Property="TextElement.Foreground" Value="{Binding ButtonForeColor, ElementName=Root}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
  </UserControl.Styles>

  <Border
      x:Name="RootBorder"
      IsVisible="{Binding IsValueInputOpen}"
      VerticalAlignment="Bottom"
      HorizontalAlignment="Stretch"
      Margin="16,0"
      Padding="16"
      Background="{Binding CardBackground}"
      BorderBrush="{Binding CardBorderBrush}"
      BorderThickness="1"
      CornerRadius="12"
      BoxShadow="0 10 24 0 #22000000"
      PointerPressed="OnInteractivePointerPressed">
    <Grid RowDefinitions="Auto,Auto,*">
      <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
        <TextBlock x:Name="TitleTextBlock" FontSize="17" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" />
        <TextBlock x:Name="FormatTextBlock" Foreground="{Binding SecondaryTextBrush}" />
      </StackPanel>

      <TextBox
          x:Name="InputTextBox"
          Grid.Row="1"
          Classes="input-field"
          MinHeight="52"
          Margin="0,0,0,12"
          FontSize="24"
          FontWeight="Bold"
          IsVisible="False"
          KeyDown="OnInputKeyDown"
          TextChanged="OnInputTextChanged"
          PointerPressed="OnInteractivePointerPressed" />

      <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto">
        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="380">
          <StackPanel Spacing="12" HorizontalAlignment="Stretch">
            <UniformGrid x:Name="InputButtonGrid" Columns="4" HorizontalAlignment="Center" IsVisible="False" />
            <Grid x:Name="HexInputGrid" HorizontalAlignment="Center" IsVisible="False" />
            <Viewbox x:Name="TextInputPadViewbox" HorizontalAlignment="Stretch" Stretch="Uniform" StretchDirection="DownOnly" IsVisible="False">
              <controls:EditorTextInputPad x:Name="TextInputPad" HorizontalAlignment="Center" />
            </Viewbox>
            <WrapPanel x:Name="BitButtonPanel" IsVisible="False" Orientation="Horizontal" />
          </StackPanel>
        </ScrollViewer>

        <StackPanel x:Name="ActionButtonPanel" Grid.Column="1" IsVisible="False" Margin="16,0,0,0" Orientation="Vertical" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Top" />
      </Grid>
    </Grid>
  </Border>
</UserControl>
