<Window
    x:Class="Amium.UiEditor.Widgets.EnhancedSignalEditorDialogWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="820"
    MinWidth="760"
    Height="980"
    MinHeight="820"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="Enhanced Signal"
    Background="{Binding DialogBackground}">
  <Window.Styles>
    <Style Selector="Border.dialog-section-shell">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.section-toggle">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="{Binding SectionHeaderForeground}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
    </Style>
    <Style Selector="Button.section-toggle:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.section-toggle:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.dialog-field">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{Binding BorderColor}" />
      <Setter Property="Background" Value="{Binding EditorBackground}" />
      <Setter Property="Foreground" Value="{Binding EditorForeground}" />
      <Setter Property="CaretBrush" Value="{Binding EditorForeground}" />
    </Style>
    <Style Selector="TextBox.dialog-field:pointerover">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor}" />
    </Style>
    <Style Selector="TextBox.dialog-field:focus">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor}" />
    </Style>
    <Style Selector="TextBox.dialog-field /template/ Border">
      <Setter Property="Background" Value="{Binding EditorBackground}" />
      <Setter Property="BorderBrush" Value="{Binding BorderColor}" />
    </Style>
    <Style Selector="TextBox.dialog-field:pointerover /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor}" />
    </Style>
    <Style Selector="TextBox.dialog-field:focus /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor}" />
    </Style>
    <Style Selector="TextBox.dialog-field /template/ ScrollViewer">
      <Setter Property="Background" Value="{Binding EditorBackground}" />
      <Setter Property="Foreground" Value="{Binding EditorForeground}" />
    </Style>
    <Style Selector="ComboBox.dialog-field">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{Binding BorderColor}" />
      <Setter Property="Background" Value="{Binding EditorBackground}" />
      <Setter Property="Foreground" Value="{Binding EditorForeground}" />
    </Style>
    <Style Selector="ComboBox.dialog-field:pointerover">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor}" />
    </Style>
    <Style Selector="ComboBox.dialog-field:focus">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor}" />
    </Style>
    <Style Selector="ComboBox.dialog-field /template/ Border">
      <Setter Property="Background" Value="{Binding EditorBackground}" />
      <Setter Property="BorderBrush" Value="{Binding BorderColor}" />
    </Style>
    <Style Selector="ComboBox.dialog-field:pointerover /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor}" />
    </Style>
    <Style Selector="ComboBox.dialog-field:focus /template/ Border">
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor}" />
    </Style>
    <Style Selector="Button.dialog-button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="{Binding ButtonBackground}" />
      <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush}" />
      <Setter Property="Foreground" Value="{Binding ButtonForeground}" />
    </Style>
    <Style Selector="TabItem.dialog-tab">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Background" Value="{Binding TabBackColor}" />
      <Setter Property="Foreground" Value="{Binding TabForeColor}" />
      <Setter Property="BorderBrush" Value="{Binding BorderColor}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,7" />
    </Style>
    <Style Selector="TabItem.dialog-tab:selected">
      <Setter Property="Background" Value="{Binding TabSelectBackColor}" />
      <Setter Property="Foreground" Value="{Binding TabSelectForeColor}" />
      <Setter Property="BorderBrush" Value="{Binding ParameterHoverColor}" />
    </Style>
  </Window.Styles>

  <Border MinWidth="564" Padding="12" Margin="16" Background="{Binding DialogBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="10">
    <Grid RowDefinitions="*,Auto">
      <TabControl Grid.Row="0" Margin="0,0,0,12">
        <TabItem Classes="dialog-tab" Header="Settings">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" AllowAutoHide="False" Padding="0,0,12,0">
            <StackPanel Margin="0,0,8,0" Spacing="8">
              <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Enhanced Signal" />
              <TextBlock FontSize="12" Foreground="{Binding SecondaryTextBrush}" Text="Configure a host-backed enhanced signal with a single source, optional adjustment, peak filtering, base filters, Kalman filter, and statistics outputs." TextWrapping="Wrap" />

              <Border Classes="dialog-section-shell">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0" Classes="section-toggle" Tag="Signal" Content="{Binding SignalSectionToggleGlyph}" Click="OnSectionToggleClicked" />
                    <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{Binding SectionHeaderForeground}" Text="{Binding SignalSectionTitle}" />
                  </Grid>
                  <Border IsVisible="{Binding IsSignalSectionExpanded}" Margin="0,6,0,6" Padding="10,10,10,8" Background="{Binding SectionContentBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnDefinitions="170,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                      <TextBlock Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Name" ToolTip.Tip="{Binding NameToolTip}" />
                      <TextBox Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" Classes="dialog-field" Text="{Binding Name, Mode=TwoWay}" ToolTip.Tip="{Binding NameToolTip}" />
                      <TextBlock Grid.Row="1" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Enabled" ToolTip.Tip="{Binding EnabledToolTip}" />
                      <CheckBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" IsChecked="{Binding Enabled, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding EnabledToolTip}" />
                      <TextBlock Grid.Row="2" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Writable" ToolTip.Tip="{Binding IsWritableToolTip}" />
                      <CheckBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" IsChecked="{Binding IsWritable, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding IsWritableToolTip}" />
                      <TextBlock Grid.Row="3" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Source" ToolTip.Tip="{Binding SourceToolTip}" />
                      <Grid Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" ColumnDefinitions="*,Auto">
                        <TextBox Classes="dialog-field" Text="{Binding SourcePath, Mode=TwoWay}" ToolTip.Tip="{Binding SourceToolTip}" />
                        <Button Grid.Column="1" Margin="8,0,0,0" Classes="dialog-button" Content="Pick" Click="OnPickSourceClicked" ToolTip.Tip="{Binding SourceToolTip}" />
                      </Grid>
                      <TextBlock Grid.Row="4" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Write Mode" ToolTip.Tip="{Binding WriteModeToolTip}" />
                      <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" Classes="dialog-field" ItemsSource="{Binding WriteModeOptions}" SelectedItem="{Binding SelectedWriteMode, Mode=TwoWay}" ToolTip.Tip="{Binding WriteModeToolTip}" />
                      <TextBlock Grid.Row="5" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Write Target" ToolTip.Tip="{Binding WritePathToolTip}" />
                      <Grid Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" ColumnDefinitions="*,Auto">
                        <TextBox Classes="dialog-field" Text="{Binding WritePath, Mode=TwoWay}" ToolTip.Tip="{Binding WritePathToolTip}" />
                        <Button Grid.Column="1" Margin="8,0,0,0" Classes="dialog-button" Content="Pick" Click="OnPickWriteTargetClicked" ToolTip.Tip="{Binding WritePathToolTip}" />
                      </Grid>
                      <TextBlock Grid.Row="6" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Unit" ToolTip.Tip="{Binding UnitToolTip}" />
                      <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" Classes="dialog-field" Text="{Binding Unit, Mode=TwoWay}" ToolTip.Tip="{Binding UnitToolTip}" />
                      <TextBlock Grid.Row="7" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Format" ToolTip.Tip="{Binding FormatToolTip}" />
                      <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" Classes="dialog-field" Text="{Binding Format, Mode=TwoWay}" ToolTip.Tip="{Binding FormatToolTip}" />
                      <TextBlock Grid.Row="8" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Scan Interval (ms)" ToolTip.Tip="{Binding ScanIntervalToolTip}" />
                      <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" Classes="dialog-field" Text="{Binding ScanIntervalMsText, Mode=TwoWay}" ToolTip.Tip="{Binding ScanIntervalToolTip}" />
                      <TextBlock Grid.Row="9" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Published Path" ToolTip.Tip="{Binding PublishedPathToolTip}" />
                      <TextBlock Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" Foreground="{Binding PrimaryTextBrush}" Text="{Binding PreviewPath}" TextWrapping="Wrap" ToolTip.Tip="{Binding PublishedPathToolTip}" />
                      <TextBlock Grid.Row="10" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Forward Child Writes" ToolTip.Tip="{Binding ForwardChildWritesToSourceToolTip}" />
                      <CheckBox Grid.Row="10" Grid.Column="1" Margin="0,0,0,6" IsChecked="{Binding ForwardChildWritesToSource, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding ForwardChildWritesToSourceToolTip}" />
                      <TextBlock Grid.Row="10" Grid.Column="2" FontSize="11" Foreground="{Binding SecondaryTextBrush}" Text="When enabled, non-signal-owned child writes are mapped relative to the source path. Internal enhanced-signal nodes stay local." TextWrapping="Wrap" />
                    </Grid>
                  </Border>
                </StackPanel>
              </Border>

              <Border Classes="dialog-section-shell">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0" Classes="section-toggle" Tag="Adjustment" Content="{Binding AdjustmentSectionToggleGlyph}" Click="OnSectionToggleClicked" />
                    <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{Binding SectionHeaderForeground}" Text="{Binding AdjustmentSectionTitle}" />
                  </Grid>
                  <Border IsVisible="{Binding IsAdjustmentSectionExpanded}" Margin="0,6,0,6" Padding="10,10,10,8" Background="{Binding SectionContentBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                      <TextBlock Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Enabled" ToolTip.Tip="{Binding AdjustmentEnabledToolTip}" />
                      <CheckBox x:Name="AdjustmentEnabledCheckBox" Grid.Column="1" Margin="0,0,0,6" IsChecked="{Binding AdjustmentEnabled, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding AdjustmentEnabledToolTip}" />
                      <TextBlock Grid.Row="1" Margin="0,0,0,6" IsVisible="{Binding ShowAdjustmentSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Mode" ToolTip.Tip="{Binding AdjustmentModeToolTip}" />
                      <ComboBox x:Name="AdjustmentModeComboBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowAdjustmentSettings}" ItemsSource="{Binding AdjustmentModeOptions}" SelectedItem="{Binding SelectedAdjustmentMode, Mode=TwoWay}" ToolTip.Tip="{Binding AdjustmentModeToolTip}" />
                      <TextBlock Grid.Row="2" Margin="0,0,0,6" IsVisible="{Binding ShowAffineAdjustmentSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Offset" ToolTip.Tip="{Binding OffsetToolTip}" />
                      <TextBox x:Name="AdjustmentOffsetTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowAffineAdjustmentSettings}" Text="{Binding AdjustmentOffsetText, Mode=TwoWay}" ToolTip.Tip="{Binding OffsetToolTip}" />
                      <TextBlock Grid.Row="3" Margin="0,0,0,6" IsVisible="{Binding ShowAffineAdjustmentSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Gain" ToolTip.Tip="{Binding GainToolTip}" />
                      <TextBox x:Name="AdjustmentGainTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowAffineAdjustmentSettings}" Text="{Binding AdjustmentGainText, Mode=TwoWay}" ToolTip.Tip="{Binding GainToolTip}" />
                      <TextBlock Grid.Row="4" Margin="0,0,0,6" IsVisible="{Binding ShowInverseMappingSetting}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Inverse Mapping" ToolTip.Tip="{Binding InverseMappingToolTip}" />
                      <CheckBox x:Name="InverseMappingCheckBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,6" IsVisible="{Binding ShowInverseMappingSetting}" IsChecked="{Binding SupportsInverseMapping, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding InverseMappingToolTip}" />
                      <TextBlock Grid.Row="5" Margin="0,0,0,6" IsVisible="{Binding ShowAdjustmentCurveEditor}" VerticalAlignment="Top" Foreground="{Binding PrimaryTextBrush}" Text="Curve Editor" ToolTip.Tip="{Binding SplinePointsToolTip}" />
                      <Border Grid.Row="5" Grid.Column="1" IsVisible="{Binding ShowAdjustmentCurveEditor}" Padding="10" Background="{Binding DialogBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="6">
                        <StackPanel Spacing="8">
                          <TextBlock Foreground="{Binding SecondaryTextBrush}" Text="{Binding AdjustmentCurveSummary}" TextWrapping="Wrap" />
                          <Button HorizontalAlignment="Left" Classes="dialog-button" Content="Edit Curve" Click="OnEditAdjustmentCurveClicked" />
                        </StackPanel>
                      </Border>
                    </Grid>
                  </Border>
                </StackPanel>
              </Border>

              <Border Classes="dialog-section-shell">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0" Classes="section-toggle" Tag="PeakFilter" Content="{Binding PeakFilterSectionToggleGlyph}" Click="OnSectionToggleClicked" />
                    <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{Binding SectionHeaderForeground}" Text="{Binding PeakFilterSectionTitle}" />
                  </Grid>
                  <Border IsVisible="{Binding IsPeakFilterSectionExpanded}" Margin="0,6,0,6" Padding="10,10,10,8" Background="{Binding SectionContentBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto">
                      <TextBlock Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Enabled" ToolTip.Tip="{Binding PeakFilterEnabledToolTip}" />
                      <CheckBox Grid.Column="1" Margin="0,0,0,6" IsChecked="{Binding PeakFilterEnabled, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding PeakFilterEnabledToolTip}" />
                      <TextBlock Grid.Row="1" Margin="0,0,0,6" IsVisible="{Binding ShowPeakFilterSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Threshold" ToolTip.Tip="{Binding PeakThresholdToolTip}" />
                      <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowPeakFilterSettings}" Text="{Binding PeakThresholdText, Mode=TwoWay}" ToolTip.Tip="{Binding PeakThresholdToolTip}" />
                      <TextBlock Grid.Row="2" IsVisible="{Binding ShowPeakFilterSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Max Length (ms)" ToolTip.Tip="{Binding PeakMaxLengthToolTip}" />
                      <TextBox Grid.Row="2" Grid.Column="1" Classes="dialog-field" IsVisible="{Binding ShowPeakFilterSettings}" Text="{Binding PeakMaxLengthMsText, Mode=TwoWay}" ToolTip.Tip="{Binding PeakMaxLengthToolTip}" />
                    </Grid>
                  </Border>
                </StackPanel>
              </Border>

              <Border Classes="dialog-section-shell">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0" Classes="section-toggle" Tag="BaseFilters" Content="{Binding BaseFiltersSectionToggleGlyph}" Click="OnSectionToggleClicked" />
                    <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{Binding SectionHeaderForeground}" Text="{Binding BaseFiltersSectionTitle}" />
                  </Grid>
                  <Border IsVisible="{Binding IsBaseFiltersSectionExpanded}" Margin="0,6,0,6" Padding="10,10,10,8" Background="{Binding SectionContentBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="10">
                      <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto">
                        <TextBlock Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Filter Mode" ToolTip.Tip="{Binding FilterModeToolTip}" />
                        <ComboBox Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" ItemsSource="{Binding FilterModeOptions}" SelectedItem="{Binding SelectedFilterMode, Mode=TwoWay}" ToolTip.Tip="{Binding FilterModeToolTip}" />
                        <TextBlock Grid.Row="1" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Record Interval" ToolTip.Tip="{Binding RecordIntervalToolTip}" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" Text="{Binding RecordIntervalText, Mode=TwoWay}" ToolTip.Tip="{Binding RecordIntervalToolTip}" />
                        <TextBlock Grid.Row="2" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Filter Time (ms)" ToolTip.Tip="{Binding FilterTimeToolTip}" />
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" Text="{Binding FilterTimeMsText, Mode=TwoWay}" ToolTip.Tip="{Binding FilterTimeToolTip}" />
                        <TextBlock Grid.Row="3" Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Pad Missing With Last" ToolTip.Tip="{Binding FillMissingWithLastValueToolTip}" />
                        <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" IsChecked="{Binding FillMissingWithLastValue, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding FillMissingWithLastValueToolTip}" />
                      </Grid>

                      <Border Background="{Binding DialogBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="6" Padding="10,8,10,6">
                        <StackPanel Spacing="8">
                          <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding PrimaryTextBrush}" Text="Dynamic Filter" />
                          <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Enabled" ToolTip.Tip="{Binding DynamicFilterEnabledToolTip}" />
                            <CheckBox Grid.Column="1" Margin="0,0,0,6" IsChecked="{Binding DynamicFilterEnabled, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding DynamicFilterEnabledToolTip}" />
                            <TextBlock Grid.Row="1" Margin="0,0,0,6" IsVisible="{Binding ShowDynamicFilterSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Detection Window (ms)" ToolTip.Tip="{Binding DynamicDetectionWindowToolTip}" />
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowDynamicFilterSettings}" Text="{Binding DynamicDetectionWindowMsText, Mode=TwoWay}" ToolTip.Tip="{Binding DynamicDetectionWindowToolTip}" />
                            <TextBlock Grid.Row="2" Margin="0,0,0,6" IsVisible="{Binding ShowDynamicFilterSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Absolute Slope Threshold" ToolTip.Tip="{Binding DynamicSlopeThresholdToolTip}" />
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowDynamicFilterSettings}" Text="{Binding DynamicSlopeThresholdText, Mode=TwoWay}" ToolTip.Tip="{Binding DynamicSlopeThresholdToolTip}" />
                            <TextBlock Grid.Row="3" Margin="0,0,0,6" IsVisible="{Binding ShowDynamicFilterSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Relative Slope Threshold (%)" ToolTip.Tip="{Binding DynamicRelativeSlopeThresholdToolTip}" />
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowDynamicFilterSettings}" Text="{Binding DynamicRelativeSlopeThresholdPercentText, Mode=TwoWay}" ToolTip.Tip="{Binding DynamicRelativeSlopeThresholdToolTip}" />
                            <TextBlock Grid.Row="4" Margin="0,0,0,6" IsVisible="{Binding ShowDynamicFilterSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Dynamic Filter Time (ms)" ToolTip.Tip="{Binding DynamicFilterTimeToolTip}" />
                            <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowDynamicFilterSettings}" Text="{Binding DynamicFilterTimeMsText, Mode=TwoWay}" ToolTip.Tip="{Binding DynamicFilterTimeToolTip}" />
                            <TextBlock Grid.Row="5" IsVisible="{Binding ShowDynamicFilterSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Hold Time (ms)" ToolTip.Tip="{Binding DynamicHoldTimeToolTip}" />
                            <TextBox Grid.Row="5" Grid.Column="1" Classes="dialog-field" IsVisible="{Binding ShowDynamicFilterSettings}" Text="{Binding DynamicHoldTimeMsText, Mode=TwoWay}" ToolTip.Tip="{Binding DynamicHoldTimeToolTip}" />
                          </Grid>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <Border Classes="dialog-section-shell">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0" Classes="section-toggle" Tag="KalmanFilter" Content="{Binding KalmanSectionToggleGlyph}" Click="OnSectionToggleClicked" />
                    <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{Binding SectionHeaderForeground}" Text="{Binding KalmanSectionTitle}" />
                  </Grid>
                  <Border IsVisible="{Binding IsKalmanSectionExpanded}" Margin="0,6,0,6" Padding="10,10,10,8" Background="{Binding SectionContentBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                      <TextBlock Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Enabled" ToolTip.Tip="{Binding KalmanEnabledToolTip}" />
                      <CheckBox Grid.Column="1" Margin="0,0,0,6" IsChecked="{Binding KalmanEnabled, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding KalmanEnabledToolTip}" />
                      <TextBlock Grid.Row="1" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanMainSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Measurement Noise R" ToolTip.Tip="{Binding KalmanMeasurementNoiseRToolTip}" />
                      <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowKalmanMainSettings}" Text="{Binding KalmanMeasurementNoiseRText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanMeasurementNoiseRToolTip}" />
                      <TextBlock Grid.Row="2" Margin="0,0,0,6" IsVisible="{Binding ShowStaticKalmanProcessNoiseQ}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Process Noise Q" ToolTip.Tip="{Binding KalmanProcessNoiseQToolTip}" />
                      <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowStaticKalmanProcessNoiseQ}" Text="{Binding KalmanProcessNoiseQText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanProcessNoiseQToolTip}" />
                      <TextBlock Grid.Row="3" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanMainSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Initial Error Covariance P" ToolTip.Tip="{Binding KalmanInitialErrorCovariancePToolTip}" />
                      <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowKalmanMainSettings}" Text="{Binding KalmanInitialErrorCovariancePText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanInitialErrorCovariancePToolTip}" />
                      <TextBlock Grid.Row="4" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanMainSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Teach Window (ms)" ToolTip.Tip="{Binding KalmanTeachWindowToolTip}" />
                      <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowKalmanMainSettings}" Text="{Binding KalmanTeachWindowMsText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanTeachWindowToolTip}" />
                      <TextBlock Grid.Row="5" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanMainSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Pause Teach On Dynamic" ToolTip.Tip="{Binding KalmanTeachPauseOnDynamicToolTip}" />
                      <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanMainSettings}" IsChecked="{Binding KalmanTeachPauseOnDynamic, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding KalmanTeachPauseOnDynamicToolTip}" />
                      <TextBlock Grid.Row="6" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanMainSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Teach Q Factor" ToolTip.Tip="{Binding KalmanTeachQFactorToolTip}" />
                      <TextBox Grid.Row="6" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowKalmanMainSettings}" Text="{Binding KalmanTeachQFactorText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanTeachQFactorToolTip}" />
                      <TextBlock Grid.Row="7" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanMainSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Teach Auto Apply" ToolTip.Tip="{Binding KalmanTeachAutoApplyToolTip}" />
                      <CheckBox Grid.Row="7" Grid.Column="1" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanMainSettings}" IsChecked="{Binding KalmanTeachAutoApply, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding KalmanTeachAutoApplyToolTip}" />
                      <TextBlock Grid.Row="8" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanMainSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Adaptive Q Enabled" ToolTip.Tip="{Binding KalmanDynamicQEnabledToolTip}" />
                      <CheckBox Grid.Row="8" Grid.Column="1" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanMainSettings}" IsChecked="{Binding KalmanDynamicQEnabled, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding KalmanDynamicQEnabledToolTip}" />
                      <TextBlock Grid.Row="9" Margin="0,0,0,6" IsVisible="{Binding ShowAdaptiveKalmanSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Dynamic Q Min" ToolTip.Tip="{Binding KalmanDynamicQMinToolTip}" />
                      <TextBox Grid.Row="9" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowAdaptiveKalmanSettings}" Text="{Binding KalmanDynamicQMinText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanDynamicQMinToolTip}" />
                      <TextBlock Grid.Row="10" Margin="0,0,0,6" IsVisible="{Binding ShowAdaptiveKalmanSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Dynamic Q Max" ToolTip.Tip="{Binding KalmanDynamicQMaxToolTip}" />
                      <TextBox Grid.Row="10" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowAdaptiveKalmanSettings}" Text="{Binding KalmanDynamicQMaxText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanDynamicQMaxToolTip}" />
                      <TextBlock Grid.Row="11" Margin="0,0,0,6" IsVisible="{Binding ShowAdaptiveKalmanSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Dynamic Q Hold (ms)" ToolTip.Tip="{Binding KalmanDynamicQHoldToolTip}" />
                      <TextBox Grid.Row="11" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowAdaptiveKalmanSettings}" Text="{Binding KalmanDynamicQHoldMsText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanDynamicQHoldToolTip}" />
                      <TextBlock Grid.Row="12" Margin="0,0,0,6" IsVisible="{Binding ShowAdaptiveKalmanSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Dynamic Buffer (ms)" ToolTip.Tip="{Binding KalmanDynamicDetectionWindowToolTip}" />
                      <TextBox Grid.Row="12" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowAdaptiveKalmanSettings}" Text="{Binding KalmanDynamicDetectionWindowMsText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanDynamicDetectionWindowToolTip}" />
                      <TextBlock Grid.Row="13" Margin="0,0,0,6" IsVisible="{Binding ShowAdaptiveKalmanSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Angle Threshold (deg)" ToolTip.Tip="{Binding KalmanDynamicAngleThresholdToolTip}" />
                      <TextBox Grid.Row="13" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowAdaptiveKalmanSettings}" Text="{Binding KalmanDynamicAngleThresholdText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanDynamicAngleThresholdToolTip}" />
                      <TextBlock Grid.Row="14" Margin="0,0,0,6" IsVisible="{Binding ShowAdaptiveKalmanSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Max Angle (deg)" ToolTip.Tip="{Binding KalmanDynamicAngleMaxToolTip}" />
                      <TextBox Grid.Row="14" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowAdaptiveKalmanSettings}" Text="{Binding KalmanDynamicAngleMaxText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanDynamicAngleMaxToolTip}" />
                      <TextBlock Grid.Row="15" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanReferenceFloor}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Reference Floor" ToolTip.Tip="{Binding KalmanDynamicReferenceFloorToolTip}" />
                      <TextBox Grid.Row="15" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowKalmanReferenceFloor}" Text="{Binding KalmanDynamicReferenceFloorText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanDynamicReferenceFloorToolTip}" />
                      <TextBlock Grid.Row="16" Margin="0,0,0,6" IsVisible="{Binding ShowKalmanNormalizationMode}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Normalization" ToolTip.Tip="{Binding KalmanDynamicNormalizationModeToolTip}" />
                      <ComboBox Grid.Row="16" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowKalmanNormalizationMode}" ItemsSource="{Binding KalmanDynamicNormalizationModeOptions}" SelectedItem="{Binding SelectedKalmanDynamicNormalizationMode, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanDynamicNormalizationModeToolTip}" />
                      <TextBlock Grid.Row="17" IsVisible="{Binding ShowKalmanResidualWeight}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Residual Weight" ToolTip.Tip="{Binding KalmanDynamicResidualWeightToolTip}" />
                      <TextBox Grid.Row="17" Grid.Column="1" Classes="dialog-field" IsVisible="{Binding ShowKalmanResidualWeight}" Text="{Binding KalmanDynamicResidualWeightText, Mode=TwoWay}" ToolTip.Tip="{Binding KalmanDynamicResidualWeightToolTip}" />
                    </Grid>
                  </Border>
                </StackPanel>
              </Border>

              <Border Classes="dialog-section-shell">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0" Classes="section-toggle" Tag="Statistics" Content="{Binding StatisticsSectionToggleGlyph}" Click="OnSectionToggleClicked" />
                    <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{Binding SectionHeaderForeground}" Text="{Binding StatisticsSectionTitle}" />
                  </Grid>
                  <Border IsVisible="{Binding IsStatisticsSectionExpanded}" Margin="0,6,0,6" Padding="10,10,10,8" Background="{Binding SectionContentBackground}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="8">
                    <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                      <TextBlock Margin="0,0,0,6" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Enabled" ToolTip.Tip="{Binding StatisticsEnabledToolTip}" />
                      <CheckBox Grid.Column="1" Margin="0,0,0,6" IsChecked="{Binding StatisticsEnabled, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding StatisticsEnabledToolTip}" />
                      <TextBlock Grid.Row="1" Margin="0,0,0,6" IsVisible="{Binding ShowStatisticsSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Publish Min" ToolTip.Tip="{Binding PublishMinToolTip}" />
                      <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" IsVisible="{Binding ShowStatisticsSettings}" IsChecked="{Binding PublishMin, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding PublishMinToolTip}" />
                      <TextBlock Grid.Row="2" Margin="0,0,0,6" IsVisible="{Binding ShowStatisticsSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Publish Max" ToolTip.Tip="{Binding PublishMaxToolTip}" />
                      <CheckBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" IsVisible="{Binding ShowStatisticsSettings}" IsChecked="{Binding PublishMax, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding PublishMaxToolTip}" />
                      <TextBlock Grid.Row="3" Margin="0,0,0,6" IsVisible="{Binding ShowStatisticsSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Publish Average" ToolTip.Tip="{Binding PublishAverageToolTip}" />
                      <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" IsVisible="{Binding ShowStatisticsSettings}" IsChecked="{Binding PublishAverage, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding PublishAverageToolTip}" />
                      <TextBlock Grid.Row="4" Margin="0,0,0,6" IsVisible="{Binding ShowStatisticsSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Publish StdDev" ToolTip.Tip="{Binding PublishStdDevToolTip}" />
                      <CheckBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,6" IsVisible="{Binding ShowStatisticsSettings}" IsChecked="{Binding PublishStdDev, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding PublishStdDevToolTip}" />
                      <TextBlock Grid.Row="5" IsVisible="{Binding ShowStatisticsSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Publish Integral" ToolTip.Tip="{Binding PublishIntegralToolTip}" />
                      <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,6" IsVisible="{Binding ShowStatisticsSettings}" IsChecked="{Binding PublishIntegral, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="{Binding PublishIntegralToolTip}" />
                      <TextBlock Grid.Row="6" Margin="0,0,0,6" IsVisible="{Binding ShowStatisticsSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="StdDev Window (ms)" ToolTip.Tip="{Binding StdDevWindowToolTip}" />
                      <TextBox Grid.Row="6" Grid.Column="1" Margin="0,0,0,6" Classes="dialog-field" IsVisible="{Binding ShowStatisticsSettings}" Text="{Binding StdDevWindowMsText, Mode=TwoWay}" ToolTip.Tip="{Binding StdDevWindowToolTip}" />
                      <TextBlock Grid.Row="7" IsVisible="{Binding ShowStatisticsSettings}" VerticalAlignment="Center" Foreground="{Binding PrimaryTextBrush}" Text="Integral Divisor (ms)" ToolTip.Tip="{Binding IntegralDivisorToolTip}" />
                      <TextBox Grid.Row="7" Grid.Column="1" Classes="dialog-field" IsVisible="{Binding ShowStatisticsSettings}" Text="{Binding IntegralDivisorMsText, Mode=TwoWay}" ToolTip.Tip="{Binding IntegralDivisorToolTip}" />
                    </Grid>
                  </Border>
                </StackPanel>
              </Border>

              <TextBlock FontSize="11" Foreground="{Binding SecondaryTextBrush}" Text="Spline mappings are edited in the separate curve editor. Gain and offset remain directly editable in this dialog and are also applied to the preview inside the curve editor." TextWrapping="Wrap" />
              <TextBlock FontSize="12" Foreground="#B42318" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>
      </TabControl>

      <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Classes="dialog-button" Content="Save" Click="OnSaveClicked" />
        <Button Classes="dialog-button" Content="Cancel" Click="OnCancelClicked" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
