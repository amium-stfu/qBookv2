<Window
  x:Class="Amium.UiEditor.Widgets.TextInputDialogWindow"
  x:Name="Root"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:widgets="using:Amium.UiEditor.Widgets"
  Width="1300"
  MinWidth="1300"
  Height="480"
  MinHeight="480"
  ShowInTaskbar="False"
  WindowStartupLocation="CenterOwner"
  CanResize="False"
  SystemDecorations="BorderOnly"
  Background="{Binding DialogBackground}"
  Title="Enter text">
  <Grid Margin="16" RowDefinitions="Auto,Auto,*" ColumnDefinitions="*">
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
      <TextBlock x:Name="HeaderTextBlock" FontSize="18" FontWeight="SemiBold" />
      <TextBlock x:Name="SubHeaderTextBlock" FontSize="13" />
    </StackPanel>

    <TextBox
        x:Name="InputTextBox"
        Grid.Row="1"
        MinHeight="48"
        FontSize="18"
        FontWeight="Bold"
        Margin="0,0,0,12"
        Background="{Binding ParameterEditBackgrundColor}"
        Foreground="{Binding ParameterEditForeColor}" />

    <Viewbox Grid.Row="2" Stretch="Uniform" StretchDirection="DownOnly">
      <widgets:EditorTextInputPad x:Name="TextInputPad" HorizontalAlignment="Center" />
    </Viewbox>
  </Grid>
</Window>
