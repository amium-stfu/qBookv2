<editorUi:EditorTemplateControl
    x:Class="Amium.UiEditor.Widgets.PythonClientControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Widgets"
    xmlns:editorUi="using:Amium.UiEditor.Controls">
  <controls:PythonClientControl.HeaderActionsContent>
    <Button Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Cursor="Hand"
            IsEnabled="{Binding CanToggleRuntime, RelativeSource={RelativeSource AncestorType=controls:PythonClientControl}}"
            Click="OnToggleRuntimeClicked"
            PointerPressed="OnInteractivePointerPressed">
      <Border Background="{Binding RuntimeStatusBackground, RelativeSource={RelativeSource AncestorType=controls:PythonClientControl}}"
              CornerRadius="6"
              Padding="8,2">
        <TextBlock FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{Binding RuntimeStatusForeground, RelativeSource={RelativeSource AncestorType=controls:PythonClientControl}}"
                   Text="{Binding RuntimeToggleText, RelativeSource={RelativeSource AncestorType=controls:PythonClientControl}}" />
      </Border>
    </Button>
  </controls:PythonClientControl.HeaderActionsContent>

  <controls:PythonClientControl.BodyContent>
    <Border Padding="10,8"
            Background="{Binding EffectiveBodyBackgroundBrush}"
            BorderBrush="{Binding EffectiveBodyBorderBrush}"
            BorderThickness="{Binding EffectiveBodyBorderThickness}"
            CornerRadius="10">
      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
        <Border Grid.RowSpan="2"
                Width="14"
                Height="14"
                Margin="0,0,10,0"
                CornerRadius="7"
                VerticalAlignment="Center"
                Background="{Binding RuntimeStatusBackground, RelativeSource={RelativeSource AncestorType=controls:PythonClientControl}}"
                BorderBrush="{Binding EffectiveBodyBorderBrush}"
                BorderThickness="1" />

        <TextBlock Grid.Column="1"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{Binding EffectiveBodyForegroundBrush}"
                   Text="{Binding RuntimeStatusText, RelativeSource={RelativeSource AncestorType=controls:PythonClientControl}}" />

        <TextBlock Grid.Row="1"
                   Grid.Column="1"
                   Margin="0,2,0,0"
                   FontSize="11"
                   Foreground="{Binding EffectiveMutedForegroundBrush}"
                   Text="{Binding RuntimeDetailText, RelativeSource={RelativeSource AncestorType=controls:PythonClientControl}}"
                   TextWrapping="Wrap" />
      </Grid>
    </Border>
  </controls:PythonClientControl.BodyContent>

  <controls:PythonClientControl.FooterContent>
    <Border Padding="8,4">
      <TextBlock FontSize="11"
                 Foreground="{Binding EffectiveFooterForegroundBrush}"
                 Text="{Binding Footer}"
                 TextWrapping="Wrap" />
    </Border>
  </controls:PythonClientControl.FooterContent>
</editorUi:EditorTemplateControl>