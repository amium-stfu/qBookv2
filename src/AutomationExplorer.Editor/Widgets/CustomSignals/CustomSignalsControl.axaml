<editorUi:EditorTemplateControl
    x:Class="Amium.UiEditor.Widgets.CustomSignalsControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Amium.UiEditor.Widgets"
    xmlns:editorUi="using:Amium.UiEditor.Controls">
  <controls:CustomSignalsControl.HeaderActionsContent>
    <Button Padding="6,2"
            Classes="toolbar"
            Click="OnAddSignalClicked">
      <TextBlock FontSize="11" FontWeight="SemiBold" Text="Add" />
    </Button>
  </controls:CustomSignalsControl.HeaderActionsContent>

  <controls:CustomSignalsControl.BodyContent>
    <Border Padding="10,8"
            Background="{Binding EffectiveBodyBackgroundBrush}"
            BorderBrush="{Binding EffectiveBodyBorderBrush}"
            BorderThickness="{Binding EffectiveBodyBorderThickness}"
            CornerRadius="10">
      <Grid RowDefinitions="*,Auto">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding Signals, RelativeSource={RelativeSource AncestorType=controls:CustomSignalsControl}}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8"
                        Padding="8,6"
                        CornerRadius="8"
                        Background="{Binding RowBackground}"
                        BorderBrush="{Binding RowBorderBrush}"
                        BorderThickness="1">
                  <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Column="0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{Binding PrimaryForeground}"
                               Text="{Binding Name}" />

                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="8,2"
                            Classes="toolbar"
                            IsEnabled="{Binding CanEditValue}"
                            Click="OnSetValueClicked"
                            CommandParameter="{Binding .}">
                      <TextBlock FontSize="11" Text="Set" />
                    </Button>

                    <Button Grid.Column="2"
                            Margin="6,0,0,0"
                            Padding="8,2"
                            Classes="toolbar"
                            Click="OnEditSignalClicked"
                            CommandParameter="{Binding .}">
                      <TextBlock FontSize="11" Text="Edit" />
                    </Button>

                    <Button Grid.Column="3"
                            Margin="6,0,0,0"
                            Padding="8,2"
                            Classes="toolbar"
                            Click="OnDeleteSignalClicked"
                            CommandParameter="{Binding .}">
                      <TextBlock FontSize="11" Text="Delete" />
                    </Button>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="4"
                               Margin="0,4,0,0"
                               FontSize="11"
                               Foreground="{Binding SecondaryForeground}"
                               Text="{Binding SummaryText}"
                               TextWrapping="Wrap" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="1"
                   FontSize="11"
                   Foreground="{Binding EffectiveMutedForegroundBrush}"
                   Text="No custom signals configured. Add input or computed signals here."
                   IsVisible="{Binding HasNoSignals, RelativeSource={RelativeSource AncestorType=controls:CustomSignalsControl}}" />
      </Grid>
    </Border>
  </controls:CustomSignalsControl.BodyContent>

  <controls:CustomSignalsControl.FooterContent>
    <Border Padding="8,4">
      <TextBlock FontSize="11"
                 Foreground="{Binding EffectiveFooterForegroundBrush}"
                 Text="{Binding Footer}"
                 TextWrapping="Wrap" />
    </Border>
  </controls:CustomSignalsControl.FooterContent>
</editorUi:EditorTemplateControl>