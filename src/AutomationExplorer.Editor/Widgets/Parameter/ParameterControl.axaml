<UserControl
    x:Name="Root"
    x:Class="Amium.UiEditor.Widgets.ParameterControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Amium.UiEditor.ViewModels">
  <UserControl.Styles>
    <!-- Einheitliches Verhalten fuer Bool-/Bit-Buttons im Body: statischer Hintergrund -->
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{Binding Background}" />
      <Setter Property="BorderBrush" Value="{Binding BorderBrush}" />
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="{Binding Background}" />
      <Setter Property="BorderBrush" Value="{Binding BorderBrush}" />
    </Style>
    <!-- Hover-/Pressed-Stil fuer Button-Content unterdruecken (kein Farbwechsel des Textes) -->
    <Style Selector="Button /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="{Binding Foreground}" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="{Binding Foreground}" />
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="{Binding Foreground}" />
    </Style>
  </UserControl.Styles>
  <Grid DataContext="{Binding #Root}" RowDefinitions="Auto,*">
    <TextBlock
        Grid.Row="0"
        Margin="0,0,0,4"
        FontSize="12"
        FontWeight="SemiBold"
        Foreground="{Binding Foreground}"
        IsVisible="{Binding Presentation.HasLabel}"
        Opacity="0.72"
        Text="{Binding Presentation.Label}" />

    <Grid Grid.Row="1">
      <Grid IsVisible="{Binding Presentation.IsText}">
        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
          <TextBlock IsVisible="{Binding InlineCaptionVisible}" Margin="0,0,8,0" VerticalAlignment="Bottom" FontFamily="Calibri" TextTrimming="CharacterEllipsis" FontSize="{Binding ResolvedValueFontSize}" FontWeight="Normal" Foreground="{Binding Foreground}" Opacity="0.82" Text="{Binding InlineCaptionText}" />
          <TextBlock Grid.Column="1" VerticalAlignment="Bottom" FontFamily="Calibri" TextTrimming="CharacterEllipsis" FontSize="{Binding ResolvedValueFontSize}" FontWeight="Bold" Foreground="{Binding Foreground}" Text="{Binding Presentation.ValueText}">
            <TextBlock.RenderTransform>
              <TranslateTransform Y="{Binding ValueVerticalOffset}" />
            </TextBlock.RenderTransform>
          </TextBlock>
          <TextBlock Grid.Column="2" IsVisible="{Binding Presentation.ShowUnit}" MaxWidth="{Binding UnitWidth}" Margin="4,0,6,0" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontFamily="Calibri" TextAlignment="Right" TextTrimming="CharacterEllipsis" FontSize="{Binding ResolvedUnitFontSize}" FontStyle="Italic" FontWeight="Normal" Foreground="{Binding Foreground}" Text="{Binding Presentation.UnitText}">
            <TextBlock.RenderTransform>
              <TranslateTransform Y="{Binding ResolvedUnitBaselineOffset}" />
            </TextBlock.RenderTransform>
          </TextBlock>
        </Grid>
      </Grid>

      <StackPanel IsVisible="{Binding Presentation.IsColor}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <Border Width="72" Height="72" CornerRadius="12" Background="{Binding Presentation.ColorBrush}" BorderBrush="{Binding Foreground}" BorderThickness="1" />
        <TextBlock HorizontalAlignment="Center" FontSize="{Binding UnitFontSize}" Foreground="{Binding Foreground}" Text="{Binding Presentation.ColorText}" />
      </StackPanel>

      <Grid IsVisible="{Binding Presentation.IsBool}" HorizontalAlignment="Stretch" VerticalAlignment="Center">
        <ItemsControl ItemsSource="{Binding Presentation.BoolOptions}" HorizontalAlignment="{Binding BoolChoiceHorizontalAlignment, ElementName=Root}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="viewModels:ParameterChoiceState">
              <Button MinWidth="72"
                      MinHeight="{Binding ChoiceHeight, ElementName=Root}"
                      HorizontalAlignment="{Binding BoolChoiceHorizontalAlignment, ElementName=Root}"
                      Width="{Binding BoolChoiceWidth, ElementName=Root}"
                      Padding="10,4"
                      Background="{Binding Background}"
                      BorderBrush="{Binding BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Tag="{Binding Index}"
                      Click="OnBoolChoiceClicked">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="{Binding ChoiceFontSize, ElementName=Root}" FontWeight="SemiBold" Foreground="{Binding Foreground}" Text="{Binding Label}" />
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>

      <ItemsControl IsVisible="{Binding Presentation.IsBits}" ItemsSource="{Binding Presentation.BitOptions}" HorizontalAlignment="Stretch" VerticalAlignment="Center">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="{Binding BitColumns}" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="viewModels:ParameterChoiceState">
            <Button HorizontalAlignment="Stretch" MinHeight="{Binding ChoiceHeight, ElementName=Root}" Margin="0,0,6,6" Padding="8,3" Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" BorderThickness="1" CornerRadius="8" Tag="{Binding Index}" Click="OnBitChoiceClicked">
              <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="{Binding ChoiceFontSize, ElementName=Root}" FontWeight="SemiBold" Foreground="{Binding Foreground}" Text="{Binding Label}" />
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>
  </Grid>
</UserControl>
